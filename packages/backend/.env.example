# Backend Environment Variables
# Copy to .env for local development

# Database (required)
DATABASE_URL="mysql://root:booth2gether@localhost:3308/booth2gether"

# Server
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# Cloudflare R2 (optional — uses local storage if not set)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Production examples:
# DATABASE_URL="mysql://user:pass@host:3306/booth2gether"
# CORS_ORIGIN="https://booth2gether.vercel.app"
# R2_ACCOUNT_ID="your_account_id"
# R2_ACCESS_KEY_ID="your_key"
# R2_SECRET_ACCESS_KEY="your_secret"
# R2_BUCKET_NAME="booth2gether"
# R2_PUBLIC_URL="https://pub-xxx.r2.dev"
