generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Room {
  id        String     @id @default(uuid()) @db.VarChar(36)
  code      String     @unique @db.VarChar(6)
  hostId    String?    @db.VarChar(36)
  state     String     @default("WAITING") @db.VarChar(20)
  stripUrl  String?    @db.Text
  expiresAt DateTime?  @db.DateTime
  endedAt   DateTime?  @db.DateTime
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users  User[]
  photos Photo[]

  @@index([code])
  @@map("rooms")
}

model User {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @db.VarChar(50)
  roomId      String   @db.VarChar(36)
  role        String   @db.VarChar(10)
  isReady     Boolean  @default(false)
  isConnected Boolean  @default(true)
  createdAt   DateTime @default(now())

  room   Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  photos Photo[]

  @@index([roomId])
  @@map("users")
}

model Photo {
  id        String   @id @default(uuid()) @db.VarChar(36)
  roomId    String   @db.VarChar(36)
  userId    String   @db.VarChar(36)
  imageUrl  String   @db.Text
  shotIndex Int      @db.Int
  order     Int      @db.Int
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([userId])
  @@unique([roomId, userId, shotIndex])
  @@map("photos")
}
