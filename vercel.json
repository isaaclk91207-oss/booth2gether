{
  "framework": "nextjs",
  "outputDirectory": "packages/frontend/.next",
  "buildCommand": "pnpm --filter @booth2gether/shared build && pnpm --filter @booth2gether/frontend build",
  "rewrites": [
    {
      "source": "/uploads/:path*",
      "destination": "https://booth2gether-api.onrender.com/uploads/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=*, microphone=*" }
      ]
    }
  ]
}
