    "var_262225c3bc3e": {
      "type": "variant",
      "label": "V2: Preview (Midnight)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 2375,
        "y": 0,
        "w": 375,
        "h": 812
      },
      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --color-onyx: #111111;\n        --color-violet: #301934;\n        --color-rose: #F56FA1;\n        --color-champagne: #F7E7CE;\n    }\n\n    body {\n        margin: 0;\n        padding: 0;\n        background-color: var(--color-onyx);\n        color: var(--color-champagne);\n        font-family: 'Inter', sans-serif;\n    }\n\n    .font-serif { font-family: 'Playfair Display', serif; }\n    .font-sans { font-family: 'Inter', sans-serif; }\n\n    .no-scrollbar::-webkit-scrollbar { display: none; }\n    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n    /* Gradient Mesh Background */\n    .mesh-bg {\n        background: radial-gradient(circle at 0% 0%, var(--color-violet) 0%, transparent 50%),\n                    radial-gradient(circle at 100% 100%, #1a0f1d 0%, transparent 50%),\n                    var(--color-onyx);\n    }\n\n    .glow-sphere {\n        position: absolute;\n        border-radius: 50%;\n        filter: blur(80px);\n        z-index: 0;\n        opacity: 0.12;\n        pointer-events: none;\n    }\n\n    /* Glassmorphism */\n    .glass {\n        background: rgba(255, 255, 255, 0.03);\n        backdrop-filter: blur(12px);\n        -webkit-backdrop-filter: blur(12px);\n        border: 1px solid rgba(255, 255, 255, 0.08);\n    }\n\n    .carousel-item {\n        scroll-snap-align: center;\n    }\n\n    /* Thumbnail Peek Animation Helper */\n    .thumbnail-peek-container {\n        position: relative;\n    }\n</style>\n<div class=\"mesh-bg relative w-[375px] h-[812px] overflow-hidden flex flex-col mx-auto shadow-2xl\" data-kid=\"1\" data-name=\"page layout container\">\n\n<div class=\"glow-sphere w-64 h-64 bg-[var(--color-rose)] top-[-10%] left-[-10%]\" data-kid=\"1-1\" data-name=\"decorative rose glow sphere\"></div>\n<div class=\"glow-sphere w-80 h-80 bg-[var(--color-violet)] bottom-[-20%] right-[-20%]\" data-kid=\"1-2\" data-name=\"decorative violet glow sphere\"></div>\n\n<header class=\"relative z-10 flex items-center justify-between px-6 pt-12 pb-2\" data-kid=\"1-3\" data-name=\"top header navigation\">\n<button class=\"w-10 h-10 rounded-full flex items-center justify-center glass text-[var(--color-champagne)] hover:bg-white/10 transition-colors\" data-kid=\"1-3-1\" data-name=\"back navigation button\">\n<i class=\"ti ti-chevron-left text-xl\" data-kid=\"1-3-1-1\" data-name=\"chevron left icon\"></i>\n</button>\n<div class=\"text-center\" data-kid=\"1-3-2\" data-name=\"title group container\">\n<h1 class=\"font-serif italic text-[26px] text-[var(--color-champagne)] tracking-tight leading-tight\" data-kid=\"1-3-2-1\" data-name=\"hero headline text\">The Gallery</h1>\n<p class=\"text-[8px] uppercase tracking-[0.4em] text-[var(--color-rose)]/90 font-bold mt-0.5\" data-kid=\"1-3-2-2\" data-name=\"sub-headline text\">Booth Together</p>\n</div>\n<button class=\"w-10 h-10 rounded-full flex items-center justify-center glass text-[var(--color-rose)] hover:bg-[var(--color-rose)]/10 transition-colors\" data-kid=\"1-3-3\" data-name=\"heart like button\">\n<i class=\"ti ti-heart-filled text-lg\" data-kid=\"1-3-3-1\" data-name=\"filled heart icon\"></i>\n</button>\n</header>\n\n<main class=\"relative z-10 flex-1 flex flex-col justify-center overflow-hidden py-2\" data-kid=\"1-4\" data-name=\"photo carousel main section\">\n<div class=\"flex overflow-x-auto snap-x snap-mandatory no-scrollbar gap-6 px-10\" data-kid=\"1-4-1\" data-name=\"photo carousel container\" id=\"photo-carousel\">\n\n<div class=\"carousel-item min-w-[305px] h-[465px] relative\" data-kid=\"1-4-1-1\" data-name=\"first photo slide\">\n<div class=\"photo-card w-full h-full rounded-[3rem] overflow-hidden border border-white/10 shadow-2xl relative\" data-kid=\"1-4-1-1-1\" data-name=\"photo card container\">\n<img alt=\"Couple Embracing\" class=\"w-full h-full object-cover transform scale-105\" data-kid=\"1-4-1-1-1-1\" data-name=\"couple photo image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/20580991/pexels-photo-20580991.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=800&amp;q=80\">\n<div class=\"absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent\" data-kid=\"1-4-1-1-1-2\" data-name=\"card shadow gradient\"></div>\n</div>\n\n<div class=\"absolute -bottom-1 -right-1 w-24 h-32 rounded-[2rem] overflow-hidden border-[2px] border-white/10 shadow-2xl z-20 group\" data-kid=\"1-4-1-1-2\" data-name=\"thumbnail peek container\">\n<img alt=\"Next Photo Peek\" class=\"w-full h-full object-cover grayscale brightness-40 group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-700\" data-kid=\"1-4-1-1-2-1\" data-name=\"thumbnail photo image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/20178565/pexels-photo-20178565.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=400&amp;q=80\">\n<div class=\"absolute inset-0 bg-gradient-to-br from-[var(--color-violet)]/50 to-transparent flex items-center justify-center backdrop-blur-[2px]\" data-kid=\"1-4-1-1-2-2\" data-name=\"more photos count overlay\">\n<span class=\"text-[var(--color-champagne)] font-serif italic text-xl drop-shadow-2xl\" data-kid=\"1-4-1-1-2-2-1\" data-name=\"count text\">+3</span>\n</div>\n</div>\n</div>\n\n<div class=\"carousel-item min-w-[280px] h-[440px] relative\" data-kid=\"1-4-1-2\" data-name=\"second photo slide\">\n<div class=\"photo-card w-full h-full rounded-[2rem] overflow-hidden border border-white/10 shadow-2xl relative\" data-kid=\"1-4-1-2-1\" data-name=\"photo card container\">\n<img alt=\"Night Portrait\" class=\"w-full h-full object-cover\" data-kid=\"1-4-1-2-1-1\" data-name=\"night portrait image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/20178565/pexels-photo-20178565.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=800&amp;q=80\">\n</div>\n</div>\n\n<div class=\"carousel-item min-w-[280px] h-[440px] relative\" data-kid=\"1-4-1-3\" data-name=\"third photo slide\">\n<div class=\"photo-card w-full h-full rounded-[2rem] overflow-hidden border border-white/10 shadow-2xl relative\" data-kid=\"1-4-1-3-1\" data-name=\"photo card container\">\n<img alt=\"City Kiss\" class=\"w-full h-full object-cover\" data-kid=\"1-4-1-3-1-1\" data-name=\"city kiss image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/9880055/pexels-photo-9880055.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=800&amp;q=80\">\n</div>\n</div>\n</div>\n\n<div class=\"mt-12 px-6\" data-kid=\"1-4-2\" data-name=\"filter pill navigation section\">\n<p class=\"font-serif italic text-center text-xs text-[var(--color-champagne)]/70 mb-5 tracking-widest\" data-kid=\"1-4-2-1\" data-name=\"editorial finishes section title\">Refine with Editorial Finishes</p>\n<div class=\"flex overflow-x-auto no-scrollbar gap-3 pb-2 px-1\" data-kid=\"1-4-2-2\" data-name=\"filter pill container\">\n<button class=\"filter-pill shrink-0 px-8 py-4 rounded-full glass border-[var(--color-rose)]/40 text-[var(--color-rose)] font-serif italic text-[13px] font-semibold bg-[var(--color-rose)]/10\" data-kid=\"1-4-2-2-1\" data-name=\"original filter button\">\n                    Original\n                </button>\n<button class=\"filter-pill shrink-0 px-8 py-4 rounded-full glass text-[var(--color-champagne)]/50 font-serif italic text-[13px] hover:bg-white/10 hover:text-[var(--color-champagne)] transition-colors\" data-kid=\"1-4-2-2-2\" data-name=\"noir filter button\">\n                    Noir\n                </button>\n<button class=\"filter-pill shrink-0 px-8 py-4 rounded-full glass text-[var(--color-champagne)]/50 font-serif italic text-[13px] hover:bg-white/10 hover:text-[var(--color-champagne)] transition-colors\" data-kid=\"1-4-2-2-3\" data-name=\"vintage filter button\">\n                    Vintage\n                </button>\n<button class=\"filter-pill shrink-0 px-8 py-4 rounded-full glass text-[var(--color-champagne)]/50 font-serif italic text-[13px] hover:bg-white/10 hover:text-[var(--color-champagne)] transition-colors\" data-kid=\"1-4-2-2-4\" data-name=\"glow filter button\">\n                    Glow\n                </button>\n<button class=\"filter-pill shrink-0 px-8 py-4 rounded-full glass text-[var(--color-champagne)]/50 font-serif italic text-[13px] hover:bg-white/10 hover:text-[var(--color-champagne)] transition-colors\" data-kid=\"1-4-2-2-5\" data-name=\"chrome filter button\">\n                    Chrome\n                </button>\n</div>\n</div>\n</main>\n\n<footer class=\"relative z-10 px-6 pb-10 flex flex-col gap-6\" data-kid=\"1-5\" data-name=\"bottom actions footer\">\n<div class=\"flex items-center justify-center gap-4\" data-kid=\"1-5-1\" data-name=\"actions button row\">\n<button class=\"action-btn w-14 h-14 rounded-full flex items-center justify-center glass border-white/5 text-[var(--color-champagne)] hover:text-[var(--color-rose)]\" data-kid=\"1-5-1-1\" data-name=\"download button\">\n<i class=\"ti ti-download text-xl\" data-kid=\"1-5-1-1-1\" data-name=\"download icon\"></i>\n</button>\n<button class=\"action-btn flex-1 h-14 rounded-2xl bg-[var(--color-rose)] text-[var(--color-onyx)] font-bold uppercase tracking-widest text-xs flex items-center justify-center gap-2 shadow-lg shadow-[var(--color-rose)]/20\" data-kid=\"1-5-1-2\" data-name=\"finish experience call-to-action button\">\n<span data-kid=\"1-5-1-2-1\" data-name=\"button label text\">Finish Experience</span>\n<i class=\"ti ti-chevron-right text-lg\" data-kid=\"1-5-1-2-2\" data-name=\"chevron icon\"></i>\n</button>\n<button class=\"action-btn w-14 h-14 rounded-full flex items-center justify-center glass border-white/5 text-[var(--color-champagne)] hover:text-[var(--color-rose)]\" data-kid=\"1-5-1-3\" data-name=\"share button\">\n<i class=\"ti ti-share-2 text-xl\" data-kid=\"1-5-1-3-1\" data-name=\"share icon\"></i>\n</button>\n</div>\n\n<div class=\"flex justify-center gap-1.5\" data-kid=\"1-5-2\" data-name=\"carousel scroll indicator\">\n<div class=\"w-8 h-1 rounded-full bg-[var(--color-rose)]\" data-kid=\"1-5-2-1\" data-name=\"active dot indicator\"></div>\n<div class=\"w-1.5 h-1 rounded-full bg-white/10\" data-kid=\"1-5-2-2\" data-name=\"inactive dot indicator\"></div>\n<div class=\"w-1.5 h-1 rounded-full bg-white/10\" data-kid=\"1-5-2-3\" data-name=\"inactive dot indicator\"></div>\n</div>\n\n</footer></div>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script data-kid=\"3\">\n    // Initial entrance animations\n    document.addEventListener('DOMContentLoaded', () => {\n        const tl = gsap.timeline();\n\n        // Animate glow spheres in background\n        gsap.to(\".glow-sphere\", {\n            x: \"random(-50, 50)\",\n            y: \"random(-50, 50)\",\n            duration: \"random(12, 24)\",\n            repeat: -1,\n            yoyo: true,\n            ease: \"sine.inOut\"\n        });\n\n        // Reveal photos with a mask wipe effect simulation\n        tl.from(\".photo-card\", {\n            clipPath: \"inset(0 100% 0 0)\",\n            duration: 1.6,\n            ease: \"power4.inOut\",\n            stagger: 0.2\n        });\n\n        tl.from(\"header, footer, .filter-pill\", {\n            opacity: 0,\n            y: 40,\n            duration: 1.2,\n            ease: \"power4.out\",\n            stagger: 0.1\n        }, \"-=1\");\n\n        // Hover effect for primary action button\n        const finishBtn = document.querySelector('.bg-\\\\[var\\\\(--color-rose\\\\)\\\\]');\n        finishBtn.addEventListener('mouseenter', () => {\n            gsap.to(finishBtn, {\n                boxShadow: \"0 12px 40px rgba(245, 111, 161, 0.4)\",\n                scale: 1.02,\n                duration: 0.3\n            });\n        });\n        finishBtn.addEventListener('mouseleave', () => {\n            gsap.to(finishBtn, {\n                boxShadow: \"0 2px 8px rgba(0,0,0,0.1)\",\n                scale: 1,\n                duration: 0.3\n            });\n        });\n\n        // Simple carousel snap logic (already handled by CSS, but could add JS if needed)\n    });\n</script>\n",
