      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;700&display=swap');\n\n  :root {\n    --magenta: #FF00FF;\n    --cyan: #00FFFF;\n    --yellow: #FFFF00;\n    --black: #000000;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    font-family: 'Space Grotesk', sans-serif;\n    background-color: var(--cyan);\n    overflow: hidden;\n  }\n\n  .font-anton { font-family: 'Anton', sans-serif; }\n  .font-space { font-family: 'Space Grotesk', sans-serif; }\n\n  .halftone-bg {\n    background-image: radial-gradient(var(--black) 20%, transparent 22%);\n    background-size: 12px 12px;\n    opacity: 0.15;\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n  }\n\n  .polaroid {\n    background: white;\n    padding: 10px 10px 32px 10px;\n    border: 3px solid var(--black);\n    box-shadow: 6px 6px 0px var(--black);\n    position: absolute;\n    width: 135px;\n    transition: none;\n    z-index: 10;\n  }\n\n  .starburst-btn {\n    clip-path: polygon(50% 0%, 56% 28%, 83% 10%, 68% 36%, 100% 40%, 72% 54%, 90% 82%, 60% 66%, 50% 100%, 40% 66%, 10% 82%, 28% 54%, 0% 40%, 32% 36%, 17% 10%, 44% 28%);\n    background: var(--yellow);\n    border: 4px solid var(--black);\n    animation: flash-pulse 0.45s infinite alternate;\n  }\n\n  @keyframes flash-pulse {\n    from { transform: scale(1); filter: drop-shadow(6px 6px 0px var(--black)); }\n    to { transform: scale(1.1); filter: drop-shadow(0 0 25px var(--magenta)); background-color: #f6ff00; }\n  }\n\n  .marquee-strip {\n    background: var(--magenta);\n    border-top: 3px solid var(--black);\n    border-bottom: 3px solid var(--black);\n    overflow: hidden;\n    white-space: nowrap;\n    width: 200%;\n    transform: rotate(-2deg);\n    position: absolute;\n    top: 50px;\n    left: -50px;\n    z-index: 0;\n  }\n\n  .marquee-content {\n    display: inline-block;\n    animation: marquee 15s linear infinite;\n    padding: 6px 0;\n  }\n\n  @keyframes marquee {\n    from { transform: translateX(0); }\n    to { transform: translateX(-50%); }\n  }\n\n  .sticker {\n    filter: drop-shadow(4px 4px 0px var(--black));\n    position: absolute;\n    z-index: 40;\n  }\n\n  /* Pattern #hard-offset utility */\n  .hard-offset {\n    border: 3px solid var(--black);\n    box-shadow: 6px 6px 0px var(--black);\n  }\n\n  .video-overlay {\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 40%);\n    pointer-events: none;\n  }\n\n  .dot-indicator {\n    width: 8px;\n    height: 8px;\n    border-radius: 999px;\n    background: #34D399; /* Green for ready */\n    border: 1px solid black;\n    display: inline-block;\n    margin-right: 4px;\n  }\n\n</style>\n<div class=\"relative w-full h-full min-h-screen bg-[var(--cyan)] overflow-hidden flex flex-col items-center\" data-kid=\"1\">\n\n<div class=\"halftone-bg\" data-kid=\"1-1\"></div>\n\n<div class=\"marquee-strip\" data-kid=\"1-2\">\n<div class=\"marquee-content font-anton text-2xl text-white uppercase italic\" data-kid=\"1-2-1\">\n      GET READY • BOOTH TOGETHER • GET READY • BOOTH TOGETHER • GET READY • BOOTH TOGETHER • GET READY • BOOTH TOGETHER • GET READY • BOOTH TOGETHER • GET READY • BOOTH TOGETHER •\n    </div>\n</div>\n\n<header class=\"relative z-10 pt-10 px-5 flex justify-between items-start\" data-kid=\"1-3\">\n<div class=\"header-box bg-white border-3 border-black p-2 rotate-[-2deg] shadow-[4px_4px_0_#000]\" data-kid=\"1-3-1\">\n<h1 class=\"font-anton text-2xl text-black leading-none uppercase m-0\" data-kid=\"1-3-1-1\">WAITING ROOM</h1>\n</div>\n<div class=\"flex flex-col gap-1 items-end\" data-kid=\"1-3-2\">\n<div class=\"header-badge bg-[var(--yellow)] border-2 border-black px-2 py-0.5 font-space font-bold text-[10px] uppercase rotate-[3deg] shadow-[2px_2px_0_#000]\" data-kid=\"1-3-2-1\">\n        4/6 READY\n      </div>\n<div class=\"header-badge bg-[var(--magenta)] border-2 border-black px-2 py-0.5 font-space font-bold text-[10px] text-white uppercase rotate-[-1deg] shadow-[2px_2px_0_#000]\" data-kid=\"1-3-2-2\">\n        ROOM #99\n      </div>\n</div>\n</header>\n\n<main class=\"relative w-full max-w-[375px] h-[380px] mt-2\" data-kid=\"1-4\">\n\n<div class=\"polaroid\" data-dynamic=\"true\" data-kid=\"1-4-1\" data-name=\"user polaroid frame\" data-reason=\"position and transform reinitialized by GSAP entry animation\" style=\"top: 5%; left: 5%; transform: rotate(-5deg); z-index: 30;\">\n<div class=\"relative w-full aspect-square bg-gray-200 border-2 border-black overflow-hidden\" data-kid=\"1-4-1-1\">\n<img alt=\"Self\" class=\"w-full h-full object-cover\" data-kid=\"1-4-1-1-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858880/pexels-photo-4858880.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=400&amp;q=80\">\n<div class=\"video-overlay\" data-kid=\"1-4-1-1-2\"></div>\n</div>\n<div class=\"mt-2 text-[10px] font-bold font-space flex items-center justify-center uppercase text-black\" data-kid=\"1-4-1-2\">\n<span class=\"dot-indicator\" data-kid=\"1-4-1-2-1\"></span> YOU\n      </div>\n</div>\n\n<div class=\"polaroid\" data-dynamic=\"true\" data-kid=\"1-4-2\" data-name=\"participant 1 polaroid frame\" data-reason=\"position and transform reinitialized by GSAP entry animation\" style=\"top: 2%; right: 5%; transform: rotate(8deg); z-index: 25;\">\n<div class=\"relative w-full aspect-square bg-gray-200 border-2 border-black overflow-hidden\" data-kid=\"1-4-2-1\">\n<img alt=\"Jamie\" class=\"w-full h-full object-cover\" data-kid=\"1-4-2-1-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858873/pexels-photo-4858873.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=400&amp;q=80\">\n<div class=\"video-overlay\" data-kid=\"1-4-2-1-2\"></div>\n</div>\n<div class=\"mt-2 text-[10px] font-bold font-space flex items-center justify-center uppercase text-black\" data-kid=\"1-4-2-2\">\n<span class=\"dot-indicator\" data-kid=\"1-4-2-2-1\"></span> JAMIE\n      </div>\n</div>\n\n<div class=\"polaroid\" data-dynamic=\"true\" data-kid=\"1-4-3\" data-name=\"participant 2 polaroid frame\" data-reason=\"position and transform reinitialized by GSAP entry animation\" style=\"top: 45%; left: 8%; transform: rotate(3deg); z-index: 20;\">\n<div class=\"relative w-full aspect-square bg-gray-200 border-2 border-black overflow-hidden\" data-kid=\"1-4-3-1\">\n<img alt=\"Miso\" class=\"w-full h-full object-cover\" data-kid=\"1-4-3-1-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858867/pexels-photo-4858867.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=400&amp;q=80\">\n<div class=\"video-overlay\" data-kid=\"1-4-3-1-2\"></div>\n</div>\n<div class=\"mt-2 text-[10px] font-bold font-space flex items-center justify-center uppercase text-black\" data-kid=\"1-4-3-2\">\n<span class=\"dot-indicator\" data-kid=\"1-4-3-2-1\"></span> MISO\n      </div>\n</div>\n\n<div class=\"polaroid\" data-dynamic=\"true\" data-kid=\"1-4-4\" data-name=\"participant 3 polaroid frame\" data-reason=\"position and transform reinitialized by GSAP entry animation\" style=\"top: 42%; right: 10%; transform: rotate(-6deg); z-index: 15;\">\n<div class=\"relative w-full aspect-square bg-gray-200 border-2 border-black overflow-hidden\" data-kid=\"1-4-4-1\">\n<img alt=\"Alex\" class=\"w-full h-full object-cover\" data-kid=\"1-4-4-1-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858870/pexels-photo-4858870.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=400&amp;q=80\">\n<div class=\"video-overlay\" data-kid=\"1-4-4-1-2\"></div>\n</div>\n<div class=\"mt-2 text-[10px] font-bold font-space flex items-center justify-center uppercase text-black\" data-kid=\"1-4-4-2\">\n<span class=\"dot-indicator bg-red-500\" data-kid=\"1-4-4-2-1\"></span> ALEX...\n      </div>\n</div>\n\n<div class=\"sticker top-[35%] left-[35%] z-40\" data-dynamic=\"true\" data-kid=\"1-4-5\" data-name=\"lightning bolt decorative sticker container\" data-reason=\"position animated by script\">\n<img class=\"w-16 h-16 rotate-[15deg] opacity-90\" data-kid=\"1-4-5-1\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/power-lightning.svg\" style=\"filter: drop-shadow(4px 4px 0 #000) brightness(1) sepia(1) saturate(100) hue-rotate(10deg);\">\n</div>\n<div class=\"sticker top-[25%] right-[38%] z-40\" data-dynamic=\"true\" data-kid=\"1-4-6\" data-name=\"star decorative sticker container\" data-reason=\"position animated by script\">\n<div class=\"bg-[var(--yellow)] w-10 h-10 rounded-full border-2 border-black flex items-center justify-center rotate-[-20deg]\" data-kid=\"1-4-6-1\">\n<i class=\"ti ti-zap text-xl text-black\" data-kid=\"1-4-6-1-1\"></i>\n</div>\n</div>\n<div class=\"sticker bottom-[5%] left-[2%] z-40\" data-dynamic=\"true\" data-kid=\"1-4-7\" data-name=\"smile decorative sticker container\" data-reason=\"position animated by script\">\n<div class=\"bg-[var(--magenta)] w-10 h-10 border-2 border-black flex items-center justify-center rotate-[30deg]\" data-kid=\"1-4-7-1\">\n<i class=\"ti ti-mood-smile text-2xl text-white\" data-kid=\"1-4-7-1-1\"></i>\n</div>\n</div>\n<div class=\"sticker bottom-[15%] right-[2%] z-40\" data-dynamic=\"true\" data-kid=\"1-4-8\" data-name=\"camera decorative sticker container\" data-reason=\"position animated by script\">\n<div class=\"bg-white w-12 h-12 border-2 border-black flex items-center justify-center rotate-[-15deg] shadow-[2px_2px_0_#000]\" data-kid=\"1-4-8-1\">\n<i class=\"ti ti-camera text-2xl text-black\" data-kid=\"1-4-8-1-1\"></i>\n</div>\n</div>\n<div class=\"sticker top-[5%] left-[45%] opacity-20 z-0\" data-dynamic=\"true\" data-kid=\"1-4-9\" data-name=\"decorative explosion icon container\" data-reason=\"position animated by script\">\n<img class=\"w-12 h-12\" data-kid=\"1-4-9-1\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/bright-explosion.svg\" style=\"filter: brightness(0);\">\n</div>\n</main>\n\n<footer class=\"absolute bottom-6 left-0 w-full flex flex-col items-center z-50 pointer-events-none\" data-kid=\"1-5\">\n<div class=\"relative w-52 h-52 flex items-center justify-center pointer-events-auto starburst-wrapper\" data-kid=\"1-5-1\">\n<button class=\"starburst-btn w-full h-full flex items-center justify-center cursor-pointer active:scale-90\" data-kid=\"1-5-1-1\">\n<span class=\"font-anton text-4xl text-black rotate-[-5deg] tracking-wider select-none\" data-kid=\"1-5-1-1-1\">READY</span>\n</button>\n\n<img class=\"absolute -top-4 -right-4 w-10 h-10 opacity-80 pointer-events-none\" data-kid=\"1-5-1-2\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/bright-explosion.svg\" style=\"filter: brightness(0);\">\n</div>\n<p class=\"font-space font-black text-[14px] uppercase mt-2 bg-white border-3 border-black px-4 py-1 rotate-[1deg] shadow-[4px_4px_0_#000] pointer-events-auto\" data-kid=\"1-5-2\">\n      TAP TO START THE CHAOS!\n    </p>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script data-kid=\"3\">\n    // GSAP Entrance\n    gsap.from(\".polaroid\", {\n      scale: 0,\n      rotation: -180,\n      duration: 0.8,\n      stagger: 0.1,\n      ease: \"back.out(1.5)\",\n      delay: 0.2\n    });\n\n    gsap.from(\".header-box\", {\n      x: -100,\n      opacity: 0,\n      duration: 0.6,\n      ease: \"power3.out\"\n    });\n\n    gsap.from(\".header-badge\", {\n      x: 100,\n      opacity: 0,\n      duration: 0.6,\n      stagger: 0.1,\n      ease: \"power3.out\"\n    });\n\n    // Polaroid Hovers using GSAP\n    document.querySelectorAll('.polaroid').forEach(el => {\n      const originalRotation = parseFloat(el.style.transform.replace('rotate(', '').replace('deg)', '')) || 0;\n      el.addEventListener('mouseenter', () => {\n        gsap.to(el, { scale: 1.1, rotation: 0, zIndex: 60, duration: 0.3, ease: \"power2.out\" });\n      });\n      el.addEventListener('mouseleave', () => {\n        gsap.to(el, { scale: 1, rotation: originalRotation, zIndex: el.style.zIndex, duration: 0.3, ease: \"power2.out\" });\n      });\n    });\n\n    // Starburst Hover Jiggle using GSAP on wrapper\n    const starburstWrapper = document.querySelector('.starburst-wrapper');\n    starburstWrapper.addEventListener('mouseenter', () => {\n      gsap.to(starburstWrapper, { rotate: 5, duration: 0.1, yoyo: true, repeat: 5 });\n    });\n    starburstWrapper.addEventListener('mouseleave', () => {\n      gsap.to(starburstWrapper, { rotate: 0, duration: 0.2 });\n    });\n\n    // Sticker Jiggles and Floating using GSAP\n    document.querySelectorAll('.sticker').forEach(sticker => {\n      sticker.addEventListener('mouseenter', () => {\n        gsap.to(sticker, { scale: 1.2, rotation: \"+=15\", duration: 0.3, ease: \"back.out(2)\" });\n      });\n      sticker.addEventListener('mouseleave', () => {\n        gsap.to(sticker, { scale: 1, rotation: \"-=15\", duration: 0.3 });\n      });\n      \n      // Floating animation\n      gsap.to(sticker, {\n        y: \"random(-10, 10)\",\n        x: \"random(-5, 5)\",\n        duration: 2 + Math.random(),\n        repeat: -1,\n        yoyo: true,\n        ease: \"sine.inOut\"\n      });\n    });\n  </script>\n<link data-kid=\"1-6\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\">\n</div>\n",
