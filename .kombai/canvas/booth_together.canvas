      "html": "<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@700&family=Nunito+Sans:wght@400;600;700;800&display=swap');\n    \n    .no-scrollbar::-webkit-scrollbar { display: none; }\n    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n    @keyframes ringPulse {\n        0%, 100% { border-color: rgba(255, 255, 255, 0.4); transform: scale(1); background-color: rgba(255, 255, 255, 0.05); }\n        50% { border-color: rgba(181, 126, 220, 0.6); transform: scale(1.05); background-color: rgba(181, 126, 220, 0.1); }\n    }\n    .shutter-pulse {\n        animation: ringPulse 3s infinite ease-in-out;\n    }\n\n    .countdown-shadow {\n        text-shadow: 0 0 40px rgba(181, 126, 220, 0.8), 0 0 80px rgba(137, 207, 240, 0.5), 0 10px 30px rgba(0,0,0,0.3);\n    }\n</style>\n<link data-kid=\"1\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.30.0/tabler-icons.min.css\" rel=\"stylesheet\">\n<section class=\"relative w-full h-[100dvh] bg-[#FDF5E6] overflow-hidden font-['Nunito_Sans'] flex items-center justify-center\" data-kid=\"2\" data-name=\"page layout container\">\n\n<div class=\"relative w-full max-w-[375px] h-full overflow-hidden bg-black flex flex-col shadow-2xl\" data-kid=\"2-1\" data-name=\"camera viewport container\">\n\n<div class=\"absolute inset-0 z-0\" data-kid=\"2-1-1\" data-name=\"live camera feed wrapper\">\n<img alt=\"Two friends laughing\" class=\"w-full h-full object-cover scale-110\" data-dynamic=\"true\" data-kid=\"2-1-1-1\" data-name=\"live camera feed image\" data-reason=\"scale animated by GSAP forever\" decoding=\"async\" id=\"live-feed\" loading=\"lazy\" src=\"https://images.pexels.com/photos/10549067/pexels-photo-10549067.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=1000&amp;q=80\">\n\n<div class=\"absolute inset-0 bg-black/20 backdrop-blur-[0.5px] pointer-events-none\" data-kid=\"2-1-1-2\"></div>\n</div>\n\n<header class=\"relative p-6 flex justify-between items-center z-50\" data-kid=\"2-1-2\" data-name=\"top navigation header\">\n<button class=\"w-11 h-11 flex items-center justify-center bg-black/20 backdrop-blur-xl rounded-full text-white border border-white/20 hover:bg-black/40 transition-all active:scale-90\" data-kid=\"2-1-2-1\" data-name=\"back navigation button\">\n<i class=\"ti ti-chevron-left text-2xl\" data-kid=\"2-1-2-1-1\" data-name=\"left chevron icon\"></i>\n</button>\n<div class=\"flex gap-3\" data-kid=\"2-1-2-2\" data-name=\"camera settings controls container\">\n<button class=\"w-11 h-11 flex items-center justify-center bg-black/20 backdrop-blur-xl rounded-full text-white border border-white/20 hover:bg-black/40 transition-all active:scale-90\" data-kid=\"2-1-2-2-1\" data-name=\"flash toggle button\">\n<i class=\"ti ti-bolt text-xl\" data-kid=\"2-1-2-2-1-1\" data-name=\"lightning bolt icon\"></i>\n</button>\n<button class=\"w-11 h-11 flex items-center justify-center bg-black/20 backdrop-blur-xl rounded-full text-white border border-white/20 hover:bg-black/40 transition-all active:scale-90\" data-kid=\"2-1-2-2-2\" data-name=\"camera rotation button\">\n<i class=\"ti ti-camera-rotate text-xl\" data-kid=\"2-1-2-2-2-1\" data-name=\"camera rotate icon\"></i>\n</button>\n</div>\n</header>\n\n<div class=\"flex-grow flex items-center justify-center z-30 pointer-events-none relative\" data-kid=\"2-1-3\" data-name=\"main interactive content container\" id=\"camera-viewport\">\n<div class=\"text-white text-[14rem] font-['Quicksand'] font-bold countdown-shadow leading-none select-none\" data-dynamic=\"true\" data-kid=\"2-1-3-1\" data-name=\"countdown text\" data-reason=\"text replaced every second by countdown script\" id=\"countdown\">\n                3\n            </div>\n</div>\n\n<footer class=\"relative z-40 bg-gradient-to-t from-black/80 via-black/30 to-transparent p-6 pb-14\" data-kid=\"2-1-4\" data-name=\"bottom controls UI footer\">\n<div class=\"flex flex-col items-center gap-10\" data-kid=\"2-1-4-1\" data-name=\"controls inner wrapper\">\n\n<div class=\"w-full flex items-center gap-8 overflow-x-auto no-scrollbar px-12 cursor-grab snap-x snap-mandatory\" data-kid=\"2-1-4-1-1\" data-name=\"filter selection reel\" id=\"filter-reel\">\n\n<div class=\"filter-item flex flex-col items-center gap-2 shrink-0 transition-all cursor-pointer\" data-filter=\"Normal\" data-kid=\"2-1-4-1-1-1\" data-name=\"natural filter item\">\n<div class=\"w-14 h-14 rounded-full border-2 border-white/30 bg-white/5 flex items-center justify-center\" data-kid=\"2-1-4-1-1-1-1\" data-name=\"natural filter icon container\">\n<i class=\"ti ti-circle-half-vertical text-white text-xl\" data-kid=\"2-1-4-1-1-1-1-1\" data-name=\"circle half-vertical icon\"></i>\n</div>\n<span class=\"text-white text-[10px] font-bold uppercase tracking-widest opacity-80\" data-kid=\"2-1-4-1-1-1-2\" data-name=\"natural filter label\">Natural</span>\n</div>\n\n<div class=\"filter-item flex flex-col items-center gap-2 shrink-0 transition-all scale-110 cursor-pointer\" data-filter=\"Glow\" data-kid=\"2-1-4-1-1-2\" data-name=\"glow filter item\">\n<div class=\"w-16 h-16 rounded-full border-4 border-[#B57EDC] ring-4 ring-white/10 bg-gradient-to-br from-[#B57EDC]/30 to-[#89CFF0]/30 flex items-center justify-center\" data-kid=\"2-1-4-1-1-2-1\" data-name=\"glow filter icon container\">\n<i class=\"ti ti-sparkles text-white text-2xl\" data-kid=\"2-1-4-1-1-2-1-1\" data-name=\"sparkles icon\"></i>\n</div>\n<span class=\"text-white text-[11px] font-extrabold uppercase tracking-widest\" data-kid=\"2-1-4-1-1-2-2\" data-name=\"glow filter label\">Glow</span>\n</div>\n\n<div class=\"filter-item flex flex-col items-center gap-2 shrink-0 opacity-50 transition-all cursor-pointer\" data-filter=\"Kawaii\" data-kid=\"2-1-4-1-1-3\" data-name=\"kawaii filter item\">\n<div class=\"w-14 h-14 rounded-full border-2 border-white/30 bg-white/5 flex items-center justify-center\" data-kid=\"2-1-4-1-1-3-1\" data-name=\"kawaii filter icon container\">\n<i class=\"ti ti-cat text-white text-xl\" data-kid=\"2-1-4-1-1-3-1-1\" data-name=\"cat icon\"></i>\n</div>\n<span class=\"text-white text-[10px] font-bold uppercase tracking-widest\" data-kid=\"2-1-4-1-1-3-2\" data-name=\"kawaii filter label\">Kawaii</span>\n</div>\n\n<div class=\"filter-item flex flex-col items-center gap-2 shrink-0 opacity-50 transition-all cursor-pointer\" data-filter=\"Retro\" data-kid=\"2-1-4-1-1-4\" data-name=\"retro filter item\">\n<div class=\"w-14 h-14 rounded-full border-2 border-white/30 bg-white/5 flex items-center justify-center\" data-kid=\"2-1-4-1-1-4-1\" data-name=\"retro filter icon container\">\n<i class=\"ti ti-history text-white text-xl\" data-kid=\"2-1-4-1-1-4-1-1\" data-name=\"history icon\"></i>\n</div>\n<span class=\"text-white text-[10px] font-bold uppercase tracking-widest\" data-kid=\"2-1-4-1-1-4-2\" data-name=\"retro filter label\">Retro</span>\n</div>\n\n<div class=\"filter-item flex flex-col items-center gap-2 shrink-0 opacity-50 transition-all cursor-pointer\" data-filter=\"Mono\" data-kid=\"2-1-4-1-1-5\" data-name=\"mono filter item\">\n<div class=\"w-14 h-14 rounded-full border-2 border-white/30 bg-white/5 flex items-center justify-center\" data-kid=\"2-1-4-1-1-5-1\" data-name=\"mono filter icon container\">\n<i class=\"ti ti-contrast text-white text-xl\" data-kid=\"2-1-4-1-1-5-1-1\" data-name=\"contrast icon\"></i>\n</div>\n<span class=\"text-white text-[10px] font-bold uppercase tracking-widest\" data-kid=\"2-1-4-1-1-5-2\" data-name=\"mono filter label\">Mono</span>\n</div>\n</div>\n\n<div class=\"relative\" data-kid=\"2-1-4-1-2\" data-name=\"shutter button wrapper\">\n<button class=\"relative group outline-hidden flex items-center justify-center\" data-kid=\"2-1-4-1-2-1\" data-name=\"shutter button\" id=\"shutter-btn\">\n\n<div class=\"w-24 h-24 rounded-full border-[6px] border-white/40 bg-white/10 backdrop-blur-md flex items-center justify-center transition-all duration-300 group-hover:scale-110 group-active:scale-95 shutter-pulse\" data-kid=\"2-1-4-1-2-1-1\" data-name=\"shutter ring shape\">\n\n<div class=\"w-16 h-16 rounded-full bg-white shadow-xl flex items-center justify-center\" data-kid=\"2-1-4-1-2-1-1-1\" data-name=\"shutter center button\">\n<div class=\"w-14 h-14 rounded-full border border-black/5\" data-kid=\"2-1-4-1-2-1-1-1-1\" data-name=\"shutter inner detail\"></div>\n</div>\n</div>\n\n<div class=\"absolute inset-0 bg-[#B57EDC]/30 rounded-full blur-2xl scale-125 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none\" data-kid=\"2-1-4-1-2-1-2\" data-name=\"outer shutter halo glow\"></div>\n</button>\n</div>\n</div>\n</footer>\n\n<div class=\"absolute inset-0 bg-white z-[100] opacity-0 pointer-events-none\" data-dynamic=\"true\" data-kid=\"2-1-5\" data-name=\"camera flash screen overlay\" data-reason=\"opacity set to 1 by triggerFlash function\" id=\"flash-overlay\"></div>\n</div>\n</section>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"3\"></script>\n<script data-kid=\"4\">\n    document.addEventListener('DOMContentLoaded', () => {\n        // Ken Burns feed effect\n        gsap.to('#live-feed', {\n            scale: 1.25,\n            duration: 20,\n            repeat: -1,\n            yoyo: true,\n            ease: \"sine.inOut\"\n        });\n\n        const countdownEl = document.getElementById('countdown');\n        const flashOverlay = document.getElementById('flash-overlay');\n        let count = 3;\n\n        const startCountdown = () => {\n            if (count > 0) {\n                countdownEl.innerText = count;\n                gsap.fromTo(countdownEl, \n                    { scale: 0.4, opacity: 0, y: 50, rotation: count % 2 === 0 ? -15 : 15 }, \n                    { scale: 1, opacity: 1, y: 0, rotation: 0, duration: 0.6, ease: \"elastic.out(1, 0.6)\" }\n                );\n                count--;\n                setTimeout(startCountdown, 1000);\n            } else {\n                countdownEl.innerText = \"SMILE!\";\n                gsap.to(countdownEl, { scale: 1.6, opacity: 0, duration: 0.3, delay: 0.2, ease: \"power4.in\" });\n                \n                // Flash & Shake Effect\n                const viewport = document.getElementById('camera-viewport').parentElement;\n                gsap.timeline()\n                    .to(flashOverlay, { opacity: 1, duration: 0.04 })\n                    .to(viewport, { x: 5, y: -5, duration: 0.05, repeat: 5, yoyo: true })\n                    .to(viewport, { x: 0, y: 0, duration: 0.1 })\n                    .to(flashOverlay, { opacity: 0, duration: 1.2, ease: \"power3.out\" });\n            }\n        };\n\n        // Delayed start for smoother experience\n        setTimeout(startCountdown, 1000);\n\n        // Filter Selection Logic\n        const filterItems = document.querySelectorAll('.filter-item');\n        filterItems.forEach(item => {\n            item.addEventListener('click', () => {\n                filterItems.forEach(i => {\n                    i.classList.add('opacity-50');\n                    i.classList.remove('scale-110');\n                    const innerCircle = i.querySelector('div');\n                    innerCircle.className = \"w-14 h-14 rounded-full border-2 border-white/30 bg-white/5 flex items-center justify-center\";\n                    const span = i.querySelector('span');\n                    span.className = \"text-white text-[10px] font-bold uppercase tracking-widest opacity-80\";\n                });\n                \n                item.classList.remove('opacity-50');\n                item.classList.add('scale-110');\n                const activeCircle = item.querySelector('div');\n                activeCircle.className = \"w-16 h-16 rounded-full border-4 border-[#B57EDC] ring-4 ring-white/10 bg-gradient-to-br from-[#B57EDC]/30 to-[#89CFF0]/30 flex items-center justify-center\";\n                const activeSpan = item.querySelector('span');\n                activeSpan.className = \"text-white text-[11px] font-extrabold uppercase tracking-widest\";\n            });\n        });\n\n        // Haptic feel on shutter\n        document.getElementById('shutter-btn').addEventListener('click', () => {\n            gsap.to('#shutter-btn', { scale: 0.85, duration: 0.1, yoyo: true, repeat: 1 });\n        });\n    });\n</script>",
