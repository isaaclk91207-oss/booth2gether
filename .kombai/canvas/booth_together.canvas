      },
      "html": "\n<div class=\"camera-screen min-h-screen bg-black text-white font-['Space_Grotesk'] overflow-x-clip relative select-none p-6 flex items-center justify-center\" data-kid=\"1\" data-name=\"camera application centered wrapper\">\n\n<div class=\"absolute inset-0 opacity-20 pointer-events-none\" data-kid=\"1-1\" data-name=\"background pattern overlay\" style=\"background-image: radial-gradient(circle, #ddd 1px, transparent 1px); background-size: 12px 12px;\"></div>\n\n<main class=\"relative w-full h-[calc(100vh-48px)] max-w-[375px] border-[16px] border-[#FF00FF] shadow-[0_0_0_8px_#00FFFF,0_0_0_16px_#FF00FF] flex flex-col overflow-hidden\" data-kid=\"1-2\" data-name=\"camera interface main container\">\n\n<div class=\"relative flex-1 bg-zinc-900 overflow-hidden\" data-kid=\"1-2-1\" data-name=\"camera viewfinder area\">\n<img alt=\"Camera View\" class=\"w-full h-full object-cover grayscale brightness-110 contrast-125 transition-transform duration-700 hover:scale-105\" data-kid=\"1-2-1-1\" data-name=\"live camera feed image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1746587224861-521244472226?auto=format&amp;w=800&amp;q=80&amp;fit=crop\">\n\n<div class=\"absolute inset-0 pointer-events-none opacity-10 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_2px,3px_100%]\" data-kid=\"1-2-1-2\" data-name=\"viewfinder CRT scanline effect\"></div>\n\n<div class=\"absolute inset-10 border-2 border-white/30 pointer-events-none rounded-xl\" data-kid=\"1-2-1-3\" data-name=\"camera focus brackets container\">\n<div class=\"absolute -top-1 -left-1 w-6 h-6 border-t-4 border-l-4 border-[#FFFF00]\" data-kid=\"1-2-1-3-1\" data-name=\"top-left focus bracket\"></div>\n<div class=\"absolute -top-1 -right-1 w-6 h-6 border-t-4 border-r-4 border-[#FFFF00]\" data-kid=\"1-2-1-3-2\" data-name=\"top-right focus bracket\"></div>\n<div class=\"absolute -bottom-1 -left-1 w-6 h-6 border-b-4 border-l-4 border-[#FFFF00]\" data-kid=\"1-2-1-3-3\" data-name=\"bottom-left focus bracket\"></div>\n<div class=\"absolute -bottom-1 -right-1 w-6 h-6 border-b-4 border-r-4 border-[#FFFF00]\" data-kid=\"1-2-1-3-4\" data-name=\"bottom-right focus bracket\"></div>\n</div>\n\n<div class=\"absolute inset-0 flex items-center justify-center pointer-events-none\" data-kid=\"1-2-1-4\" data-name=\"countdown timer overlay container\" id=\"countdown-container\">\n<span class=\"countdown-digit text-[#FFFF00] text-[200px] font-['Anton'] leading-none drop-shadow-[12px_12px_0_#000000]\" data-dynamic=\"true\" data-kid=\"1-2-1-4-1\" data-name=\"countdown digit text\" data-reason=\"text replaced by countdown sequence script\">3</span>\n</div>\n\n<div class=\"absolute top-6 left-6 right-6 flex justify-between items-start z-20\" data-kid=\"1-2-1-5\" data-name=\"top controls overlay container\">\n<div class=\"flex flex-col gap-2\" data-kid=\"1-2-1-5-1\" data-name=\"recording status and telemetry group\">\n<div class=\"bg-[#FFFF00] border-[3px] border-black px-4 py-1.5 font-bold text-black flex items-center gap-2 shadow-[4px_4px_0_#000] rotate-[-2deg]\" data-kid=\"1-2-1-5-1-1\" data-name=\"recording status badge\">\n<div class=\"w-2.5 h-2.5 bg-red-600 rounded-full animate-pulse shadow-[0_0_8px_red]\" data-kid=\"1-2-1-5-1-1-1\" data-name=\"recording pulse animation dot\"></div>\n<span class=\"text-sm tracking-tighter font-['Anton'] uppercase\" data-kid=\"1-2-1-5-1-1-2\" data-name=\"recording status text\">LIVE ROOM</span>\n</div>\n<div class=\"bg-[#00FFFF] border-2 border-black px-2 py-0.5 text-[10px] font-bold text-black w-fit shadow-[2px_2px_0_#000] ml-2\" data-kid=\"1-2-1-5-1-2\" data-name=\"camera settings telemetry text\">\n                        BT-0922X\n                    </div>\n</div>\n<div class=\"flex gap-2\" data-kid=\"1-2-1-5-2\" data-name=\"top right controls group\">\n<button class=\"icon-jiggle w-12 h-12 bg-white border-[3px] border-black text-black flex items-center justify-center shadow-[4px_4px_0_#FF00FF] active:scale-95\" data-kid=\"1-2-1-5-2-1\" data-name=\"flash toggle button\">\n<i class=\"ti ti-bolt text-2xl\" data-kid=\"1-2-1-5-2-1-1\" data-name=\"flash icon\"></i>\n</button>\n<button class=\"icon-jiggle w-12 h-12 bg-[#FF00FF] border-[3px] border-black text-white flex items-center justify-center shadow-[4px_4px_0_#00FFFF] active:scale-95\" data-kid=\"1-2-1-5-2-2\" data-name=\"close camera button\">\n<i class=\"ti ti-x text-2xl\" data-kid=\"1-2-1-5-2-2-1\" data-name=\"close icon\"></i>\n</button>\n</div>\n</div>\n\n<nav class=\"absolute left-4 top-1/2 -translate-y-1/2 flex flex-col gap-4 z-30\" data-kid=\"1-2-1-6\" data-name=\"filter menu sidebar navigation\">\n<div class=\"bg-[#FF00FF] border-[3px] border-black p-2 flex flex-col gap-3 shadow-[6px_6px_0_#000] rotate-[-1deg]\" data-kid=\"1-2-1-6-1\" data-name=\"filter icons container\">\n<button class=\"filter-btn w-12 h-12 bg-[#00FFFF] border-2 border-black flex items-center justify-center group active:scale-95 shadow-[3px_3px_0_#000]\" data-filter=\"glitch\" data-kid=\"1-2-1-6-1-1\" data-name=\"glitch filter select button\">\n<img alt=\"Star filter\" class=\"w-8 h-8 group-hover:rotate-90 transition-transform\" data-kid=\"1-2-1-6-1-1-1\" data-name=\"star filter icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/star-swirl.svg\" style=\"filter: invert(1);\">\n</button>\n<button class=\"filter-btn w-12 h-12 bg-[#FFFF00] border-2 border-black flex items-center justify-center group active:scale-95 shadow-[3px_3px_0_#000]\" data-filter=\"lightning\" data-kid=\"1-2-1-6-1-2\" data-name=\"lightning filter select button\">\n<img alt=\"Lightning filter\" class=\"w-8 h-8 group-hover:scale-110 transition-transform\" data-kid=\"1-2-1-6-1-2-1\" data-name=\"lightning filter icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/lightning-storm.svg\">\n</button>\n<button class=\"filter-btn w-12 h-12 bg-white border-2 border-black flex items-center justify-center group active:scale-95 shadow-[3px_3px_0_#000]\" data-filter=\"bubbles\" data-kid=\"1-2-1-6-1-3\" data-name=\"bubbles filter select button\">\n<img alt=\"Bubbles filter\" class=\"w-8 h-8 group-hover:translate-y-[-2px] transition-transform\" data-kid=\"1-2-1-6-1-3-1\" data-name=\"bubbles filter icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/bubbles.svg\">\n</button>\n<div class=\"h-[2px] bg-black/30 my-1\" data-kid=\"1-2-1-6-1-4\" data-name=\"separator line\"></div>\n<button class=\"w-12 h-12 bg-black text-[#FFFF00] border-2 border-[#FFFF00] flex items-center justify-center active:scale-95\" data-kid=\"1-2-1-6-1-5\" data-name=\"settings button\">\n<i class=\"ti ti-settings text-2xl\" data-kid=\"1-2-1-6-1-5-1\" data-name=\"settings gear icon\"></i>\n</button>\n</div>\n</nav>\n\n<div class=\"sticker-pop absolute top-1/4 right-2 rotate-[15deg] z-20 pointer-events-none\" data-kid=\"1-2-1-7\" data-name=\"decorative sticker container\">\n<div class=\"bg-[#FFFF00] border-3 border-black px-4 py-2 font-['Anton'] text-3xl text-black shadow-[6px_6px_0_#FF00FF]\" data-kid=\"1-2-1-7-1\" data-name=\"kawaii sticker text\">KAWAII!</div>\n</div>\n<div class=\"sticker-pop absolute bottom-1/3 right-6 -rotate-[12deg] z-20 pointer-events-none opacity-90\" data-kid=\"1-2-1-8\" data-name=\"decorative star sticker container\">\n<img alt=\"Sticker\" class=\"w-18 h-18 object-cover border-4 border-white shadow-lg rotate-6\" data-kid=\"1-2-1-8-1\" data-name=\"star sticker image\" src=\"https://images.unsplash.com/photo-1753430708971-892048584cf3?auto=format&amp;w=200&amp;q=80&amp;fit=crop\">\n</div>\n<div class=\"sticker-pop absolute bottom-1/4 left-12 rotate-[-8deg] z-20 pointer-events-none\" data-kid=\"1-2-1-9\" data-name=\"smiley sticker container\">\n<div class=\"bg-[#00FFFF] border-3 border-black p-2 shadow-[4px_4px_0_#FF00FF]\" data-kid=\"1-2-1-9-1\" data-name=\"smiley sticker badge\">\n<i class=\"ti ti-mood-smile-beam text-black text-4xl\" data-kid=\"1-2-1-9-1-1\" data-name=\"smiley icon\"></i>\n</div>\n</div>\n</div>\n\n<footer class=\"bg-black h-48 flex items-center justify-around px-6 relative border-t-[6px] border-[#FF00FF]\" data-kid=\"1-2-2\" data-name=\"bottom footer shutter controls\">\n\n<div class=\"absolute -top-5 left-1/4 w-20 h-10 bg-[#00FFFF]/60 -rotate-[4deg] z-40 pointer-events-none border-x-[3px] border-dashed border-black/30 shadow-[2px_2px_0_rgba(0,0,0,0.1)]\" data-kid=\"1-2-2-1\" data-name=\"washi tape decorative element\" style=\"background-image: repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(255,255,255,0.1) 5px, rgba(255,255,255,0.1) 10px);\"></div>\n\n<button class=\"icon-jiggle w-18 h-18 bg-[#111] border-3 border-[#FFFF00] p-1 shadow-[5px_5px_0_#000] group active:translate-x-0.5 active:translate-y-0.5 relative\" data-kid=\"1-2-2-2\" data-name=\"gallery thumbnail button\">\n<div class=\"w-full h-full overflow-hidden\" data-kid=\"1-2-2-2-1\" data-name=\"gallery image container\">\n<img alt=\"Gallery\" class=\"w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all\" data-kid=\"1-2-2-2-1-1\" data-name=\"gallery thumbnail image\" src=\"https://images.unsplash.com/photo-1625768376503-68d2495d78c5?auto=format&amp;w=200&amp;q=80&amp;fit=crop\">\n</div>\n<div class=\"absolute -top-3 -right-3 bg-[#FF00FF] text-black text-xs font-bold w-6 h-6 flex items-center justify-center border-2 border-black rotate-12 shadow-[2px_2px_0_#000]\" data-kid=\"1-2-2-2-2\" data-name=\"gallery item count badge\">8</div>\n</button>\n\n<div class=\"relative group cursor-pointer\" data-kid=\"1-2-2-3\" data-name=\"shutter trigger button container\" id=\"shutter-trigger\">\n\n<div class=\"absolute inset-[-24px] bg-[#FF00FF] rounded-full blur-3xl opacity-40 group-hover:opacity-70 transition-opacity duration-300\" data-kid=\"1-2-2-3-1\" data-name=\"shutter outer glow layer\"></div>\n<div class=\"absolute inset-[-12px] bg-[#00FFFF] rounded-full blur-xl opacity-20 scale-125 group-hover:opacity-50 transition-opacity duration-300\" data-kid=\"1-2-2-3-2\" data-name=\"shutter inner glow layer\"></div>\n\n<button class=\"relative w-36 h-36 rounded-full bg-[#FFFF00] border-[6px] border-black flex items-center justify-center shadow-[6px_6px_0_#000] active:scale-90 transition-transform duration-75\" data-kid=\"1-2-2-3-3\" data-name=\"shutter button element\">\n<div class=\"w-28 h-28 rounded-full border-4 border-black/20 flex items-center justify-center bg-white shadow-inner\" data-kid=\"1-2-2-3-3-1\" data-name=\"shutter button center ring\">\n<div class=\"w-20 h-20 rounded-full border-[8px] border-[#FF00FF] shadow-[0_0_20px_#FF00FF]\" data-kid=\"1-2-2-3-3-1-1\" data-name=\"shutter button inner ring\"></div>\n</div>\n</button>\n</div>\n\n<button class=\"icon-jiggle w-16 h-16 bg-black border-2 border-[#00FFFF] text-[#00FFFF] flex items-center justify-center shadow-[4px_4px_0_#00FFFF] active:translate-x-0.5 active:translate-y-0.5\" data-kid=\"1-2-2-4\" data-name=\"camera switch button\">\n<i class=\"ti ti-refresh text-4xl\" data-kid=\"1-2-2-4-1\" data-name=\"camera refresh icon\"></i>\n</button>\n</footer>\n</main>\n</div>\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@400;500;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    body {\n        margin: 0;\n        background-color: #000;\n        color: #fff;\n    }\n\n    /* Pattern Overrides & Custom Styles */\n    .neon-glow-cyan {\n        box-shadow: 0 0 12px rgba(0, 255, 255, 0.4), 0 0 36px rgba(0, 255, 255, 0.2);\n    }\n\n    .neon-glow-magenta {\n        box-shadow: 0 0 12px rgba(255, 0, 255, 0.4), 0 0 36px rgba(255, 0, 255, 0.2);\n    }\n\n    /* Custom Shutter Animation Pulse */\n    @keyframes shutter-pulse {\n        0%, 100% { transform: scale(1); opacity: 0.4; }\n        50% { transform: scale(1.05); opacity: 0.6; }\n    }\n    \n    .shutter-glow-animate {\n        animation: shutter-pulse 3s infinite ease-in-out;\n    }\n\n</style>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script type=\"module\" data-kid=\"3\">\n    import { animate } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    // GSAP Countdown & Sticker Animation\n    const countdownDigit = document.querySelector('.countdown-digit');\n    const stickers = document.querySelectorAll('.sticker-pop');\n    let count = 3;\n    \n    const startCountdown = () => {\n        // Initial Sticker Landing\n        stickers.forEach((sticker, i) => {\n            gsap.from(sticker, {\n                scale: 0,\n                rotation: i % 2 === 0 ? -45 : 45,\n                duration: 0.6,\n                delay: 0.2 + (i * 0.1),\n                ease: \"back.out(2)\"\n            });\n        });\n        gsap.fromTo(countdownDigit, \n            { scale: 0.5, opacity: 0, rotation: -20 },\n            { \n                scale: 1, \n                opacity: 1, \n                rotation: 0, \n                duration: 0.8, \n                ease: \"back.out(1.7)\",\n                onComplete: () => {\n                    setTimeout(() => {\n                        count--;\n                        if (count > 0) {\n                            countdownDigit.textContent = count;\n                            startCountdown();\n                        } else {\n                            countdownDigit.textContent = \"SMILE!\";\n                            gsap.to(countdownDigit, { \n                                scale: 1.5, \n                                opacity: 0, \n                                duration: 0.5, \n                                delay: 0.5,\n                                onComplete: () => {\n                                    countdownDigit.parentElement.style.display = 'none';\n                                }\n                            });\n                        }\n                    }, 1000);\n                }\n            }\n        );\n    };\n\n    window.addEventListener('DOMContentLoaded', startCountdown);\n\n    // Motion.js Hover Interactions\n    const jiggleIcons = document.querySelectorAll('.icon-jiggle');\n    jiggleIcons.forEach(el => {\n        el.addEventListener('mouseenter', () => {\n            animate(el, { rotate: [-8, 8, -5, 5, 0] }, { duration: 0.5, ease: \"easeOut\" });\n        });\n    });\n\n    const filterBtns = document.querySelectorAll('.filter-btn');\n    filterBtns.forEach(btn => {\n        btn.addEventListener('mouseenter', () => {\n            animate(btn, { x: [0, -4, 4, -2, 2, 0] }, { duration: 0.4 });\n        });\n    });\n\n    // Shutter Click Simulation\n    const shutter = document.getElementById('shutter-trigger');\n    shutter.addEventListener('click', () => {\n        // Shutter flash effect\n        const flash = document.createElement('div');\n        flash.className = 'absolute inset-0 bg-white z-[100]';\n        document.querySelector('main').appendChild(flash);\n        \n        gsap.to(flash, {\n            opacity: 0,\n            duration: 0.3,\n            ease: \"power2.out\",\n            onComplete: () => flash.remove()\n        });\n\n        // Haptic-like scale effect on the whole camera frame\n        animate(\"main\", { scale: [1, 0.98, 1] }, { duration: 0.2 });\n    });\n</script>\n",
