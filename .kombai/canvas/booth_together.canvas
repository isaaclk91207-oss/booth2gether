      },
      "html": "\n<div class=\"relative w-full h-screen bg-[#111111] font-['Inter'] text-[#F7E7CE] overflow-hidden\" data-kid=\"1\" data-name=\"page layout container\">\n\n<div class=\"absolute inset-0 z-0 select-none pointer-events-none\" data-kid=\"1-1\" data-name=\"camera viewfinder container\">\n<img alt=\"Romantic portrait\" class=\"w-full h-full object-cover grayscale-[0.1] contrast-[1.05]\" data-kid=\"1-1-1\" data-name=\"camera view image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/20178565/pexels-photo-20178565.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=1280&amp;q=80\">\n\n<div class=\"absolute inset-0 opacity-10\" data-kid=\"1-1-2\" data-name=\"viewfinder grid lines container\">\n<div class=\"absolute top-1/3 w-full h-[0.5px] bg-white\" data-kid=\"1-1-2-1\" data-name=\"horizontal grid line top\"></div>\n<div class=\"absolute top-2/3 w-full h-[0.5px] bg-white\" data-kid=\"1-1-2-2\" data-name=\"horizontal grid line bottom\"></div>\n<div class=\"absolute left-1/3 h-full w-[0.5px] bg-white\" data-kid=\"1-1-2-3\" data-name=\"vertical grid line left\"></div>\n<div class=\"absolute left-2/3 h-full w-[0.5px] bg-white\" data-kid=\"1-1-2-4\" data-name=\"vertical grid line right\"></div>\n</div>\n\n<div class=\"absolute inset-0 bg-radial-[at_50%_50%] from-transparent via-transparent to-black/40\" data-kid=\"1-1-3\" data-name=\"ambient vignette overlay\"></div>\n</div>\n\n<header class=\"absolute top-0 left-0 w-full px-6 pt-14 flex justify-between items-start z-30 pointer-events-none\" data-kid=\"1-2\" data-name=\"top ui header bar\">\n<div class=\"pointer-events-auto\" data-kid=\"1-2-1\" data-name=\"close button wrapper\">\n<button class=\"group w-11 h-11 rounded-full bg-black/10 backdrop-blur-xl flex items-center justify-center border border-white/10 active:scale-90 transition-transform cursor-pointer\" data-kid=\"1-2-1-1\" data-name=\"close action button\">\n<i class=\"ti ti-x text-xl group-hover:text-[#F56FA1] transition-colors\" data-kid=\"1-2-1-1-1\" data-name=\"x icon\"></i>\n</button>\n</div>\n<div class=\"flex flex-col items-center\" data-kid=\"1-2-2\" data-name=\"photo counter and status container\">\n<span class=\"photo-counter font-['Playfair_Display'] text-[42px] font-black italic tracking-tighter drop-shadow-[0_4px_12px_rgba(0,0,0,0.5)] leading-none\" data-dynamic=\"true\" data-kid=\"1-2-2-1\" data-name=\"photo counter text\" data-reason=\"text value updated to incremented number by script\">1/4</span>\n<div class=\"flex items-center gap-1.5 mt-2.5 px-2.5 py-0.5 bg-black/30 backdrop-blur-xl rounded-full border border-white/10 ring-1 ring-white/5 shadow-lg\" data-kid=\"1-2-2-2\" data-name=\"recording status indicator container\">\n<div class=\"w-1.5 h-1.5 rounded-full bg-[#F56FA1] shadow-[0_0_10px_#F56FA1] animate-pulse\" data-kid=\"1-2-2-2-1\" data-name=\"pulsing recording dot\"></div>\n<span class=\"text-[9px] uppercase tracking-[0.3em] font-black text-[#F7E7CE]/90\" data-kid=\"1-2-2-2-2\" data-name=\"recording status label\">Live</span>\n</div>\n</div>\n<div class=\"pointer-events-auto\" data-kid=\"1-2-3\" data-name=\"settings button wrapper\">\n<button class=\"group w-11 h-11 rounded-full bg-black/10 backdrop-blur-xl flex items-center justify-center border border-white/10 active:scale-90 transition-transform cursor-pointer\" data-kid=\"1-2-3-1\" data-name=\"settings action button\">\n<i class=\"ti ti-settings-2 text-xl group-hover:text-[#F56FA1] transition-colors\" data-kid=\"1-2-3-1-1\" data-name=\"settings icon\"></i>\n</button>\n</div>\n</header>\n\n<div class=\"side-tools absolute right-6 top-[55%] -translate-y-1/2 flex flex-col gap-4.5 z-30 pointer-events-auto\" data-kid=\"1-3\" data-name=\"side tools container\">\n<button class=\"flex flex-col items-center gap-1.5 group cursor-pointer\" data-kid=\"1-3-1\" data-name=\"flash settings button\">\n<div class=\"w-11 h-11 rounded-xl bg-black/15 backdrop-blur-2xl flex items-center justify-center border border-white/10 group-hover:border-[#F56FA1]/40 group-hover:bg-[#F56FA1]/5 group-active:scale-90 transition-all duration-300\" data-kid=\"1-3-1-1\" data-name=\"flash button container\">\n<i class=\"ti ti-bolt text-xl text-white/70 group-hover:text-[#F7E7CE]\" data-kid=\"1-3-1-1-1\" data-name=\"bolt icon\"></i>\n</div>\n<span class=\"text-[8px] uppercase tracking-[0.2em] font-black text-white/50 drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] group-hover:text-white transition-colors\" data-kid=\"1-3-1-2\" data-name=\"flash setting label\">Flash</span>\n</button>\n<button class=\"flex flex-col items-center gap-1.5 group cursor-pointer\" data-kid=\"1-3-2\" data-name=\"timer settings button\">\n<div class=\"w-11 h-11 rounded-xl bg-black/15 backdrop-blur-2xl flex items-center justify-center border border-white/10 group-hover:border-[#F56FA1]/40 group-hover:bg-[#F56FA1]/5 group-active:scale-90 transition-all duration-300\" data-kid=\"1-3-2-1\" data-name=\"timer button container\">\n<i class=\"ti ti-clock text-xl text-white/70 group-hover:text-[#F7E7CE]\" data-kid=\"1-3-2-1-1\" data-name=\"timer icon\"></i>\n</div>\n<span class=\"text-[8px] uppercase tracking-[0.2em] font-black text-white/50 drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] group-hover:text-white transition-colors\" data-kid=\"1-3-2-2\" data-name=\"timer setting label\">Timer</span>\n</button>\n<button class=\"flex flex-col items-center gap-1.5 group cursor-pointer\" data-kid=\"1-3-3\" data-name=\"glam effect button\">\n<div class=\"w-11 h-11 rounded-xl bg-black/15 backdrop-blur-2xl flex items-center justify-center border border-white/10 group-hover:border-[#F56FA1]/40 group-hover:bg-[#F56FA1]/5 group-active:scale-90 transition-all duration-300\" data-kid=\"1-3-3-1\" data-name=\"glam button container\">\n<i class=\"ti ti-wand text-xl text-white/70 group-hover:text-[#F7E7CE]\" data-kid=\"1-3-3-1-1\" data-name=\"wand icon\"></i>\n</div>\n<span class=\"text-[8px] uppercase tracking-[0.2em] font-black text-white/50 drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] group-hover:text-white transition-colors\" data-kid=\"1-3-3-2\" data-name=\"glam setting label\">Filter</span>\n</button>\n</div>\n\n<div class=\"absolute top-0 inset-x-0 h-40 bg-gradient-to-b from-black/60 to-transparent pointer-events-none z-10\" data-kid=\"1-4\" data-name=\"top edge gradient shadow\"></div>\n<div class=\"absolute bottom-0 inset-x-0 h-64 bg-gradient-to-t from-black/80 via-black/40 to-transparent pointer-events-none z-10\" data-kid=\"1-5\" data-name=\"bottom edge gradient shadow\"></div>\n\n<div class=\"absolute bottom-12 left-1/2 -translate-x-1/2 w-full max-w-[340px] px-4 z-30\" data-kid=\"1-6\" data-name=\"bottom dock bar container\">\n<nav class=\"flex items-center justify-between p-4 bg-white/5 backdrop-blur-[40px] rounded-[44px] border border-white/10 shadow-[0_24px_48px_-12px_rgba(0,0,0,0.5)]\" data-kid=\"1-6-1\" data-name=\"dock navigation menu\">\n\n<button class=\"w-12 h-12 flex items-center justify-center text-white/70 hover:text-[#F56FA1] transition-all active:scale-90 cursor-pointer\" data-kid=\"1-6-1-1\" data-name=\"camera rotation button\">\n<i class=\"ti ti-camera-rotate text-2xl\" data-kid=\"1-6-1-1-1\" data-name=\"camera rotate icon\"></i>\n</button>\n\n<div class=\"relative group cursor-pointer\" data-kid=\"1-6-1-2\" data-name=\"shutter button wrapper\" id=\"shutter-container\">\n\n<div class=\"absolute -inset-6 bg-[#F7E7CE]/10 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-all duration-700 group-hover:scale-125\" data-kid=\"1-6-1-2-1\" data-name=\"shutter outer glow halo\"></div>\n\n<div class=\"relative w-22 h-22 rounded-full border-[6px] border-[#F7E7CE] flex items-center justify-center p-1.5 group-hover:border-white\" data-kid=\"1-6-1-2-2\" data-name=\"shutter physical button\" id=\"shutter-btn\">\n\n<div class=\"w-full h-full rounded-full bg-[#F7E7CE]/5 border border-[#F7E7CE]/20 group-hover:bg-[#F7E7CE]/20 transition-colors duration-300\" data-kid=\"1-6-1-2-2-1\" data-name=\"inner active circle\"></div>\n\n<svg class=\"absolute inset-0 -rotate-90 pointer-events-none\" data-kid=\"1-6-1-2-2-2\" data-name=\"shutter progress ring svg\" viewbox=\"0 0 100 100\">\n<circle class=\"shutter-progress\" cx=\"50\" cy=\"50\" fill=\"none\" r=\"44\" stroke=\"#F56FA1\" stroke-dasharray=\"276\" stroke-dashoffset=\"276\" stroke-width=\"4\" data-kid=\"0\"></circle>\n</svg>\n</div>\n</div>\n\n<button class=\"relative w-14 h-14 rounded-2xl overflow-hidden border-2 border-white/20 active:scale-90 transition-all group cursor-pointer\" data-kid=\"1-6-1-3\" data-name=\"gallery preview button\">\n<img alt=\"Gallery thumbnail\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" data-kid=\"1-6-1-3-1\" data-name=\"gallery thumbnail image\" src=\"https://images.pexels.com/photos/20178565/pexels-photo-20178565.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=150&amp;q=80\">\n<div class=\"absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors\" data-kid=\"1-6-1-3-2\" data-name=\"thumbnail overlay\"></div>\n</button>\n</nav>\n</div>\n\n<div class=\"fixed inset-0 z-50 pointer-events-none opacity-0 flex flex-col items-center justify-center\" data-kid=\"1-7\" data-name=\"flash color-wipe overlay\" id=\"flash-overlay\">\n\n<div class=\"flash-block w-full h-full bg-[#F7E7CE]\" data-kid=\"1-7-1\" data-name=\"horizontal wipe block\"></div>\n</div>\n\n<div class=\"fixed inset-0 z-[60] flex items-center justify-center pointer-events-none scale-50 opacity-0\" data-kid=\"1-8\" data-name=\"capture indicator container\" id=\"capture-indicator\">\n<img class=\"w-24 h-24\" data-kid=\"1-8-1\" data-name=\"capture diamond icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cut-diamond.svg\" style=\"color: #F7E7CE;\">\n</div>\n</div>\n<style data-kid=\"2\">\n@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;600&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n:root {\n    --onyx: #111111;\n    --violet: #301934;\n    --rose: #F56FA1;\n    --champagne: #F7E7CE;\n}\n\n/* Custom Scrollbar Removal */\n::-webkit-scrollbar {\n    display: none;\n}\n\n/* Base styles */\nbody {\n    background-color: #111111;\n    margin: 0;\n    overflow: hidden;\n}\n\n/* Animation Classes */\n.shutter-progress {\n    transition: stroke-dashoffset 0.1s linear;\n}\n\n#flash-overlay .flash-block {\n    clip-path: inset(0 100% 0 0);\n}\n</style>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"3\"></script>\n<script data-kid=\"4\">\n    document.addEventListener('DOMContentLoaded', () => {\n        const shutterBtn = document.getElementById('shutter-container');\n        const flashOverlay = document.getElementById('flash-overlay');\n        const flashBlock = document.querySelector('.flash-block');\n        const captureIndicator = document.getElementById('capture-indicator');\n        const counter = document.querySelector('.photo-counter');\n\n        let isCapturing = false;\n\n        shutterBtn.addEventListener('click', () => {\n            if (isCapturing) return;\n            isCapturing = true;\n\n            // 1. Shutter Press Animation\n            gsap.to('#shutter-btn', {\n                scale: 0.9,\n                duration: 0.1,\n                yoyo: true,\n                repeat: 1,\n                ease: 'power2.inOut'\n            });\n\n            // 2. Color Wipe Flash Effect\n            const tl = gsap.timeline({\n                onComplete: () => {\n                    isCapturing = false;\n                    // Reset flash state\n                    gsap.set(flashBlock, { clipPath: 'inset(0 100% 0 0)' });\n                    gsap.set(flashOverlay, { opacity: 0 });\n                }\n            });\n\n            // Appear flash overlay\n            gsap.set(flashOverlay, { opacity: 1 });\n\n            tl.to(flashBlock, {\n                clipPath: 'inset(0 0% 0 0)',\n                duration: 0.3,\n                ease: 'power4.in'\n            })\n            .to(flashBlock, {\n                clipPath: 'inset(0 0 0 100%)',\n                duration: 0.3,\n                ease: 'power4.out',\n                delay: 0.05\n            });\n\n            // 3. Capture Diamond Popup\n            gsap.fromTo(captureIndicator, \n                { scale: 0.5, opacity: 0, rotate: -45 },\n                { \n                    scale: 1, \n                    opacity: 1, \n                    rotate: 0, \n                    duration: 0.4, \n                    ease: 'back.out(2)',\n                    delay: 0.1\n                }\n            );\n            gsap.to(captureIndicator, {\n                scale: 1.5,\n                opacity: 0,\n                duration: 0.3,\n                delay: 0.5,\n                ease: 'power2.in'\n            });\n\n            // 4. Update Counter (Visual Only for Demo)\n            setTimeout(() => {\n                counter.innerText = '2/4';\n                gsap.from(counter, {\n                    scale: 1.2,\n                    duration: 0.5,\n                    ease: 'elastic.out(1, 0.3)'\n                });\n            }, 350);\n        });\n\n        // Entrance Animation\n        gsap.from('header', { y: -50, opacity: 0, duration: 1, ease: 'power3.out', delay: 0.2 });\n        gsap.from('nav', { y: 100, opacity: 0, duration: 1, ease: 'power3.out', delay: 0.4 });\n        gsap.from('.side-tools button', { \n            x: 50, \n            opacity: 0, \n            duration: 0.8, \n            stagger: 0.1, \n            ease: 'back.out(1.7)',\n            delay: 0.6 \n        });\n    });\n</script>\n",
      "comments": [],
      "created": "2026-07-12T07:00:41.218187+00:00",
      "modified": "2026-07-12T07:00:41.218187+00:00",
      "id": "var_0d7613a006aa"
    },
