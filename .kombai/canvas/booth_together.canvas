      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&family=Nunito+Sans:wght@300;400;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .no-scrollbar::-webkit-scrollbar {\n        display: none;\n    }\n    .no-scrollbar {\n        -ms-overflow-style: none;\n        scrollbar-width: none;\n    }\n\n    .diagonal-stripes {\n        background: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(0,0,0,0.03) 10px, rgba(0,0,0,0.03) 20px);\n    }\n\n    #final-result-page {\n        background-color: #FDF5E6;\n        height: 100dvh;\n        display: flex;\n        flex-direction: column;\n        overflow: hidden;\n    }\n</style>\n<div class=\"font-['Nunito_Sans'] text-gray-900 relative\" data-kid=\"1\" id=\"final-result-page\">\n\n<div class=\"absolute top-[-10%] left-[-10%] w-[60%] h-[40%] bg-[#B57EDC]/15 blur-[100px] rounded-full pointer-events-none z-0\" data-kid=\"1-1\" data-name=\"glowing purple background aura\"></div>\n<div class=\"absolute bottom-[20%] right-[-10%] w-[50%] h-[50%] bg-[#89CFF0]/15 blur-[120px] rounded-full pointer-events-none z-0\" data-kid=\"1-2\" data-name=\"glowing blue background aura\"></div>\n<div class=\"absolute top-[30%] right-[-5%] w-[30%] h-[30%] bg-[#FFD1DC]/20 blur-[80px] rounded-full pointer-events-none z-0\" data-kid=\"1-3\" data-name=\"glowing pink background aura\"></div>\n\n<div class=\"max-w-[375px] mx-auto w-full h-full flex flex-col relative z-10\" data-kid=\"1-4\" data-name=\"main page container\">\n\n<header class=\"px-6 pt-10 pb-4 flex items-center justify-between backdrop-blur-md bg-[#FDF5E6]/60 shrink-0 z-20\" data-kid=\"1-4-1\" data-name=\"header bar\">\n<button class=\"w-10 h-10 flex items-center justify-center rounded-full bg-white shadow-sm text-gray-600 active:scale-90\" data-kid=\"1-4-1-1\" data-name=\"back button\">\n<i class=\"ti ti-chevron-left text-xl\" data-kid=\"1-4-1-1-1\" data-name=\"left chevron icon\"></i>\n</button>\n<h1 class=\"font-['Quicksand'] font-bold text-lg text-gray-800 tracking-tight\" data-kid=\"1-4-1-2\" data-name=\"page title text\">Your Photostrip</h1>\n<div class=\"w-10 h-10 flex items-center justify-center rounded-full bg-white shadow-sm text-[#B57EDC]\" data-kid=\"1-4-1-3\" data-name=\"sparkles icon container\">\n<i class=\"ti ti-sparkles text-xl animate-pulse\" data-dynamic=\"true\" data-kid=\"1-4-1-3-1\" data-name=\"sparkles icon\" data-reason=\"pulsing animation applied by css class\"></i>\n</div>\n</header>\n\n<main class=\"flex-1 overflow-y-auto no-scrollbar px-6 flex flex-col items-center relative z-10\" data-kid=\"1-4-2\" data-name=\"scrollable content area\">\n\n<div class=\"relative mt-4 group mb-8\" data-kid=\"1-4-2-1\" data-name=\"photo strip card container\" id=\"photo-strip-container\">\n<div class=\"bg-white p-[12px] shadow-[0_25px_60px_rgba(0,0,0,0.15)] border-[16px] border-white w-[280px] flex flex-col gap-2 transform\" data-dynamic=\"true\" data-kid=\"1-4-2-1-1\" data-name=\"photo strip frame\" data-reason=\"style attributes background-color and border-color replaced by user selection script\" id=\"photo-strip\">\n<div class=\"photo-item aspect-[3/4] overflow-hidden bg-gray-50 rounded-[2px]\" data-kid=\"1-4-2-1-1-1\" data-name=\"first photo container\">\n<img alt=\"Laughing friends\" class=\"w-full h-full object-cover\" data-kid=\"1-4-2-1-1-1-1\" data-name=\"laughing friends photo\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/10549067/pexels-photo-10549067.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n</div>\n<div class=\"photo-item aspect-[3/4] overflow-hidden bg-gray-50 rounded-[2px]\" data-kid=\"1-4-2-1-1-2\" data-name=\"second photo container\">\n<img alt=\"Smiling friends\" class=\"w-full h-full object-cover\" data-kid=\"1-4-2-1-1-2-1\" data-name=\"smiling friends photo\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/7283539/pexels-photo-7283539.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n</div>\n<div class=\"photo-item aspect-[3/4] overflow-hidden bg-gray-50 rounded-[2px]\" data-kid=\"1-4-2-1-1-3\" data-name=\"third photo container\">\n<img alt=\"Happy friends\" class=\"w-full h-full object-cover\" data-kid=\"1-4-2-1-1-3-1\" data-name=\"happy friends photo\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/10549076/pexels-photo-10549076.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n</div>\n<div class=\"photo-item aspect-[3/4] overflow-hidden bg-gray-50 rounded-[2px] relative\" data-kid=\"1-4-2-1-1-4\" data-name=\"fourth photo container\">\n<img alt=\"Fun friends\" class=\"w-full h-full object-cover\" data-kid=\"1-4-2-1-1-4-1\" data-name=\"fun friends photo\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4926675/pexels-photo-4926675.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n<div class=\"absolute bottom-2 right-2 flex items-center gap-1 opacity-50\" data-kid=\"1-4-2-1-1-4-2\" data-name=\"photo booth branding container\">\n<span class=\"font-['Quicksand'] text-[8px] font-bold tracking-widest text-white uppercase\" data-kid=\"1-4-2-1-1-4-2-1\" data-name=\"photo booth brand name text\">BoothTogether</span>\n</div>\n</div>\n</div>\n\n<div class=\"absolute -top-4 -right-4 bg-[#B57EDC] text-white text-[10px] font-bold px-3 py-1 rounded-full shadow-lg transform rotate-12 font-['Quicksand'] uppercase tracking-wider\" data-kid=\"1-4-2-1-2\" data-name=\"limited edition badge\">\n                    Limited Edition\n                </div>\n</div>\n\n<section class=\"w-full mt-4 mb-12\" data-kid=\"1-4-2-2\" data-name=\"frame selection section\" id=\"frame-picker\">\n<div class=\"flex items-center justify-between mb-6 px-1\" data-kid=\"1-4-2-2-1\" data-name=\"frame selection header\">\n<h2 class=\"font-['Quicksand'] font-bold text-gray-400 text-[10px] uppercase tracking-[0.3em]\" data-kid=\"1-4-2-2-1-1\" data-name=\"frame style label text\">Frame Color</h2>\n<span class=\"text-[9px] bg-linear-to-r from-[#B57EDC] to-[#89CFF0] text-white px-3 py-1 rounded-full font-bold uppercase tracking-wider shadow-sm shadow-[#B57EDC]/30\" data-kid=\"1-4-2-2-1-2\" data-name=\"frame style count text\">Premium</span>\n</div>\n<div class=\"flex gap-4 overflow-x-auto no-scrollbar py-2 -mx-6 px-6\" data-kid=\"1-4-2-2-2\" data-name=\"frame swatches list container\">\n\n<button class=\"frame-swatch shrink-0 w-20 h-20 rounded-[32px] bg-white border border-gray-100 shadow-xs flex items-center justify-center active:scale-90 ring-4 ring-[#B57EDC]/20 transition-all\" data-kid=\"1-4-2-2-2-1\" data-name=\"white frame swatch button\" onclick=\"changeFrameColor(this, 'white')\">\n<div class=\"w-14 h-14 rounded-[24px] bg-white border border-gray-100 shadow-inner\" data-kid=\"1-4-2-2-2-1-1\" data-name=\"white frame swatch preview\"></div>\n</button>\n<button class=\"frame-swatch shrink-0 w-20 h-20 rounded-[32px] bg-white border border-gray-100 shadow-xs flex items-center justify-center active:scale-90 transition-all\" data-kid=\"1-4-2-2-2-2\" data-name=\"purple frame swatch button\" onclick=\"changeFrameColor(this, '#B57EDC')\">\n<div class=\"w-14 h-14 rounded-[24px] bg-[#B57EDC] shadow-inner\" data-kid=\"1-4-2-2-2-2-1\" data-name=\"purple frame swatch preview\"></div>\n</button>\n<button class=\"frame-swatch shrink-0 w-20 h-20 rounded-[32px] bg-white border border-gray-100 shadow-xs flex items-center justify-center active:scale-90 transition-all\" data-kid=\"1-4-2-2-2-3\" data-name=\"blue frame swatch button\" onclick=\"changeFrameColor(this, '#89CFF0')\">\n<div class=\"w-14 h-14 rounded-[24px] bg-[#89CFF0] shadow-inner\" data-kid=\"1-4-2-2-2-3-1\" data-name=\"blue frame swatch preview\"></div>\n</button>\n<button class=\"frame-swatch shrink-0 w-20 h-20 rounded-[32px] bg-white border border-gray-100 shadow-xs flex items-center justify-center active:scale-90 transition-all\" data-kid=\"1-4-2-2-2-4\" data-name=\"pink frame swatch button\" onclick=\"changeFrameColor(this, '#FFD1DC')\">\n<div class=\"w-14 h-14 rounded-[24px] bg-[#FFD1DC] shadow-inner\" data-kid=\"1-4-2-2-2-4-1\" data-name=\"pink frame swatch preview\"></div>\n</button>\n<button class=\"frame-swatch shrink-0 w-20 h-20 rounded-[32px] bg-white border border-gray-100 shadow-xs flex items-center justify-center active:scale-90 transition-all\" data-kid=\"1-4-2-2-2-5\" data-name=\"striped frame swatch button\" onclick=\"changeFrameColor(this, 'stripes')\">\n<div class=\"w-14 h-14 rounded-[24px] bg-gray-50 diagonal-stripes shadow-inner\" data-kid=\"1-4-2-2-2-5-1\" data-name=\"striped frame swatch preview\"></div>\n</button>\n<button class=\"frame-swatch shrink-0 w-20 h-20 rounded-[32px] bg-white border border-gray-100 shadow-xs flex items-center justify-center active:scale-90 transition-all\" data-kid=\"1-4-2-2-2-6\" data-name=\"yellow frame swatch button\" onclick=\"changeFrameColor(this, '#FDFD96')\">\n<div class=\"w-14 h-14 rounded-[24px] bg-[#FDFD96] shadow-inner\" data-kid=\"1-4-2-2-2-6-1\" data-name=\"yellow frame swatch preview\"></div>\n</button>\n<button class=\"frame-swatch shrink-0 w-20 h-20 rounded-[32px] bg-white border border-gray-100 shadow-xs flex items-center justify-center active:scale-90 transition-all\" data-kid=\"1-4-2-2-2-7\" data-name=\"green frame swatch button\" onclick=\"changeFrameColor(this, '#77DD77')\">\n<div class=\"w-14 h-14 rounded-[24px] bg-[#77DD77] shadow-inner\" data-kid=\"1-4-2-2-2-7-1\" data-name=\"green frame swatch preview\"></div>\n</button>\n</div>\n</section>\n</main>\n\n<div class=\"px-6 py-8 bg-linear-to-t from-[#FDF5E6] via-[#FDF5E6]/95 to-transparent shrink-0\" data-kid=\"1-4-3\" data-name=\"bottom action row container\">\n<div class=\"flex items-center gap-3\" data-kid=\"1-4-3-1\" data-name=\"actions button bar\">\n<button class=\"action-btn flex-1 h-14 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center gap-2 group active:scale-95\" data-kid=\"1-4-3-1-1\" data-name=\"save button\">\n<i class=\"ti ti-download text-xl text-gray-700 group-hover:text-[#B57EDC]\" data-kid=\"1-4-3-1-1-1\" data-name=\"download icon\"></i>\n<span class=\"font-['Quicksand'] font-bold text-gray-700\" data-kid=\"1-4-3-1-1-2\" data-name=\"save button text\">Save</span>\n</button>\n<button class=\"action-btn flex-[1.4] h-14 bg-[#B57EDC] rounded-2xl shadow-[0_10px_30px_-5px_rgba(181,126,220,0.5)] flex items-center justify-center gap-2 text-white active:scale-95\" data-kid=\"1-4-3-1-2\" data-name=\"share button\">\n<i class=\"ti ti-share text-xl\" data-kid=\"1-4-3-1-2-1\" data-name=\"share icon\"></i>\n<span class=\"font-['Quicksand'] font-bold\" data-kid=\"1-4-3-1-2-2\" data-name=\"share button text\">Share</span>\n</button>\n<button class=\"action-btn w-14 h-14 bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center text-gray-700 active:scale-95\" data-kid=\"1-4-3-1-3\" data-name=\"print button\">\n<i class=\"ti ti-printer text-xl\" data-kid=\"1-4-3-1-3-1\" data-name=\"printer icon\"></i>\n</button>\n</div>\n</div>\n</div>\n</div>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script data-kid=\"3\">\n    function changeFrameColor(el, color) {\n        const strip = document.getElementById('photo-strip');\n        \n        // Update frame\n        if (color === 'stripes') {\n            strip.style.backgroundColor = '#FFFFFF';\n            strip.style.borderColor = '#FFFFFF';\n            strip.classList.add('diagonal-stripes');\n        } else {\n            strip.classList.remove('diagonal-stripes');\n            strip.style.backgroundColor = color === 'white' ? '#FFFFFF' : color;\n            strip.style.borderColor = color === 'white' ? '#FFFFFF' : color;\n        }\n\n        // Visual feedback for swatches\n        document.querySelectorAll('.frame-swatch').forEach(swatch => {\n            swatch.classList.remove('ring-4', 'ring-[#B57EDC]/20');\n        });\n        el.classList.add('ring-4', 'ring-[#B57EDC]/20');\n\n        // Small pop animation for the strip\n        gsap.fromTo(\"#photo-strip\", \n            { scale: 0.98 }, \n            { scale: 1, duration: 0.4, ease: \"back.out(2)\" }\n        );\n    }\n\n    window.onload = () => {\n        // Entrance animations\n        gsap.from(\"#photo-strip\", {\n            y: 50,\n            opacity: 0,\n            duration: 1.2,\n            ease: \"expo.out\",\n            rotate: -5\n        });\n\n        gsap.from(\".photo-item\", {\n            scale: 0.8,\n            opacity: 0,\n            stagger: 0.1,\n            duration: 0.8,\n            ease: \"back.out(1.7)\",\n            delay: 0.3\n        });\n\n        gsap.from(\"#frame-picker\", {\n            y: 30,\n            opacity: 0,\n            duration: 1,\n            delay: 0.6,\n            ease: \"power2.out\"\n        });\n\n        gsap.from(\".action-btn\", {\n            y: 40,\n            opacity: 0,\n            stagger: 0.1,\n            duration: 0.8,\n            delay: 0.8,\n            ease: \"power3.out\"\n        });\n    };\n</script>\n",
