    "var_c4f428775c7c": {
      "type": "variant",
      "label": "V3: Preview (Y2K)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 5225,
        "y": 0,
        "w": 375,
        "h": 812
      },
      "html": "\n<div class=\"min-h-screen bg-[#FF00FF] font-['Space_Grotesk'] text-black overflow-x-clip selection:bg-[#00FFFF] selection:text-black\" data-kid=\"1\" data-name=\"page layout container\">\n\n<div class=\"fixed inset-0 pointer-events-none opacity-20 bg-[repeating-radial-gradient(circle,#00FFFF_1px,transparent_1px,transparent_10px)] bg-[length:10px_10px]\" data-kid=\"1-1\" data-name=\"halftone pattern overlay\"></div>\n<style data-kid=\"0\">\n        @import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@400;700&display=swap');\n\n        .font-anton { font-family: 'Anton', sans-serif; }\n        \n        .brutalist-border { border: 3px solid #000; }\n        .hard-offset { box-shadow: 6px 6px 0px #000; }\n        .hard-offset-sm { box-shadow: 4px 4px 0px #000; }\n        .retro-shadow { box-shadow: 3px 3px 0px #00FFFF, 6px 6px 0px #FFFF00, 9px 9px 0px #000; }\n        \n        .masonry-grid {\n            display: flex;\n            gap: 1rem;\n            padding: 1rem;\n            padding-bottom: 8rem;\n        }\n        .masonry-col {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            gap: 1.5rem;\n        }\n\n        .sticker-card {\n            position: relative;\n            cursor: move;\n        }\n\n        .washi-tape {\n            position: absolute;\n            height: 24px;\n            width: 80px;\n            background: #00FFFFcc;\n            backdrop-filter: blur(1px);\n            transform: rotate(-10deg);\n            top: -12px;\n            left: 50%;\n            margin-left: -40px;\n            z-index: 10;\n            clip-path: polygon(0% 10%, 10% 0%, 20% 10%, 30% 0%, 40% 10%, 50% 0%, 60% 10%, 70% 0%, 80% 10%, 90% 0%, 100% 10%, 100% 90%, 90% 100%, 80% 90%, 70% 100%, 60% 90%, 50% 100%, 40% 90%, 30% 100%, 20% 90%, 10% 100%, 0% 90%);\n        }\n\n        /* Color filters for black SVGs with white die-cut outline + black shadow */\n        .die-cut {\n            filter: \n                drop-shadow(2px 0 0 #fff) \n                drop-shadow(-2px 0 0 #fff) \n                drop-shadow(0 2px 0 #fff) \n                drop-shadow(0 -2px 0 #fff)\n                drop-shadow(4px 4px 0 #000);\n        }\n        .filter-yellow { filter: invert(93%) sepia(76%) saturate(2250%) hue-rotate(352deg) brightness(108%) contrast(106%); }\n        .filter-cyan { filter: invert(88%) sepia(35%) saturate(1478%) hue-rotate(130deg) brightness(103%) contrast(101%); }\n        .filter-magenta { filter: invert(13%) sepia(93%) saturate(7469%) hue-rotate(299deg) brightness(101%) contrast(116%); }\n\n        .speed-dial-item {\n            transform: scale(0);\n        }\n        .speed-dial-active .speed-dial-item {\n            transform: scale(1);\n        }\n\n        .marquee-container {\n            overflow: hidden;\n            white-space: nowrap;\n            background: #000;\n            color: #FFFF00;\n            padding: 8px 0;\n            border-bottom: 3px solid #000;\n        }\n        .marquee-content {\n            display: inline-block;\n            animation: marquee 20s linear infinite;\n        }\n        @keyframes marquee {\n            0% { transform: translateX(0); }\n            100% { transform: translateX(-50%); }\n        }\n    </style>\n\n<div class=\"marquee-container sticky top-0 z-50\" data-kid=\"1-2\" data-name=\"marquee container\">\n<div class=\"marquee-content font-anton text-2xl uppercase italic tracking-widest\" data-kid=\"1-2-1\" data-name=\"scrolling text content\">\n            BOOTH TOGETHER • PHOTO PREVIEW • EDIT MODE ACTIVE • STICKER PACKS UNLOCKED • BOOTH TOGETHER • PHOTO PREVIEW • EDIT MODE ACTIVE • STICKER PACKS UNLOCKED • \n        </div>\n</div>\n\n<header class=\"p-6 flex justify-between items-center relative z-10\" data-kid=\"1-3\" data-name=\"header section\">\n<div data-kid=\"1-3-1\" data-name=\"title container\">\n<h1 class=\"font-anton text-5xl text-white italic drop-shadow-[4px_4px_0_rgba(0,0,0,1)] uppercase leading-none\" data-kid=\"1-3-1-1\" data-name=\"page title headline\">Your<br data-kid=\"1-3-1-1-1\" data-name=\"line break\">Shots</h1>\n</div>\n<div class=\"flex flex-col items-end gap-2\" data-kid=\"1-3-2\" data-name=\"header action group\">\n<span class=\"bg-[#FFFF00] px-3 py-1 font-bold text-xs brutalist-border uppercase\" data-kid=\"1-3-2-1\" data-name=\"edit status badge\">Edit Active</span>\n<button class=\"bg-[#00FFFF] brutalist-border px-6 py-2 font-anton text-xl uppercase italic hard-offset hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all\" data-kid=\"1-3-2-2\" data-name=\"save button\" id=\"save-btn\">\n                Save\n            </button>\n</div>\n</header>\n\n<main class=\"masonry-grid relative z-10\" data-kid=\"1-4\" data-name=\"balanced columns grid\">\n\n<div class=\"masonry-col\" data-kid=\"1-4-1\" data-name=\"masonry column 1\">\n<div class=\"sticker-card rotate-[-2deg] hover:rotate-0\" data-kid=\"1-4-1-1\" data-name=\"photo card 1\">\n<div class=\"washi-tape\" data-kid=\"1-4-1-1-1\" data-name=\"washi tape decoration 1\"></div>\n<div class=\"brutalist-border bg-white p-2 hard-offset\" data-kid=\"1-4-1-1-2\" data-name=\"photo wrapper 1\">\n<img alt=\"Fun teens\" class=\"w-full h-auto\" data-kid=\"1-4-1-1-2-1\" data-name=\"photo image 1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858880/pexels-photo-4858880.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=400&amp;q=80\">\n</div>\n<div class=\"sticker die-cut absolute -top-6 -left-6 w-16 h-16 hover:scale-110 transition-transform\" data-kid=\"1-4-1-1-3\" data-name=\"sticker overlay 1\">\n<img class=\"w-full h-full filter-yellow\" data-kid=\"1-4-1-1-3-1\" data-name=\"bright explosion icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/bright-explosion.svg\">\n</div>\n</div>\n<div class=\"sticker-card rotate-[1deg] hover:rotate-0\" data-kid=\"1-4-1-2\" data-name=\"photo card 2\">\n<div class=\"brutalist-border bg-white p-2 hard-offset\" data-kid=\"1-4-1-2-1\" data-name=\"photo wrapper 2\">\n<img alt=\"Cool style\" class=\"w-full h-auto\" data-kid=\"1-4-1-2-1-1\" data-name=\"photo image 2\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858867/pexels-photo-4858867.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=400&amp;q=80\">\n</div>\n<div class=\"sticker die-cut absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 hover:scale-110 transition-transform\" data-kid=\"1-4-1-2-2\" data-name=\"sticker overlay 2\">\n<img class=\"w-full h-full filter-yellow\" data-kid=\"1-4-1-2-2-1\" data-name=\"lightning storm icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/lightning-storm.svg\">\n</div>\n</div>\n<div class=\"sticker-card rotate-[-3deg] hover:rotate-0\" data-kid=\"1-4-1-3\" data-name=\"photo card 3\">\n<div class=\"washi-tape\" data-kid=\"1-4-1-3-1\" data-name=\"washi tape decoration 3\" style=\"width: 50px; left: 15px; rotate: 5deg;\"></div>\n<div class=\"brutalist-border bg-[#00FFFF] p-2 hard-offset\" data-kid=\"1-4-1-3-2\" data-name=\"photo wrapper 3\">\n<img alt=\"Pose\" class=\"w-full h-auto\" data-kid=\"1-4-1-3-2-1\" data-name=\"photo image 3\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1746587224861-521244472226?auto=format&amp;w=400&amp;q=80&amp;fit=crop\">\n</div>\n</div>\n</div>\n\n<div class=\"masonry-col\" data-kid=\"1-4-2\" data-name=\"masonry column 2\">\n<div class=\"sticker-card rotate-[3deg] hover:rotate-0\" data-kid=\"1-4-2-1\" data-name=\"photo card 4\">\n<div class=\"brutalist-border bg-[#00FFFF] p-2 hard-offset\" data-kid=\"1-4-2-1-1\" data-name=\"photo wrapper 4\">\n<img alt=\"Teenager portrait\" class=\"w-full h-auto\" data-kid=\"1-4-2-1-1-1\" data-name=\"photo image 4\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858873/pexels-photo-4858873.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=400&amp;q=80\">\n</div>\n<div class=\"sticker die-cut absolute -bottom-4 -right-2 w-14 h-14 hover:scale-110 transition-transform\" data-kid=\"1-4-2-1-2\" data-name=\"sticker overlay 4\">\n<img class=\"w-full h-full filter-magenta\" data-kid=\"1-4-2-1-2-1\" data-name=\"chat bubble icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/chat-bubble.svg\">\n</div>\n</div>\n<div class=\"sticker-card rotate-[2deg] hover:rotate-0\" data-kid=\"1-4-2-2\" data-name=\"photo card 5\">\n<div class=\"washi-tape\" data-kid=\"1-4-2-2-1\" data-name=\"washi tape decoration 5\" style=\"background: rgba(255, 0, 255, 0.6); rotate: 10deg; width: 60px;\"></div>\n<div class=\"brutalist-border bg-[#FFFF00] p-2 hard-offset\" data-kid=\"1-4-2-2-2\" data-name=\"photo wrapper 5\">\n<img alt=\"Teenagers\" class=\"w-full h-auto\" data-kid=\"1-4-2-2-2-1\" data-name=\"photo image 5\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858870/pexels-photo-4858870.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=400&amp;q=80\">\n</div>\n</div>\n<div class=\"sticker-card rotate-[-1.5deg] hover:rotate-0\" data-kid=\"1-4-2-3\" data-name=\"photo card 6\">\n<div class=\"brutalist-border bg-white p-2 hard-offset\" data-kid=\"1-4-2-3-1\" data-name=\"photo wrapper 6\">\n<img alt=\"Smiling\" class=\"w-full h-auto\" data-kid=\"1-4-2-3-1-1\" data-name=\"photo image 6\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858865/pexels-photo-4858865.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=400&amp;q=80\">\n</div>\n<div class=\"sticker die-cut absolute -top-4 right-0 w-12 h-12 hover:scale-110 transition-transform\" data-kid=\"1-4-2-3-2\" data-name=\"sticker overlay 6\">\n<img class=\"w-full h-full filter-cyan\" data-kid=\"1-4-2-3-2-1\" data-name=\"bright explosion icon 6\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/bright-explosion.svg\">\n</div>\n</div>\n</div>\n</main>\n\n<div class=\"fixed bottom-0 left-0 right-0 h-28 bg-[#FF00FF] border-t-3 border-black z-40 flex items-center px-6 gap-4\" data-kid=\"1-5\" data-name=\"footer dock container\">\n\n<div class=\"flex-1 flex gap-3\" data-kid=\"1-5-1\" data-name=\"bottom action button group\">\n<button class=\"bg-black text-white brutalist-border px-6 py-3 font-anton text-xl uppercase italic hard-offset hover:bg-[#333] w-full flex items-center justify-center gap-2\" data-kid=\"1-5-1-1\" data-name=\"add text button\" id=\"add-text-btn\">\n<i class=\"ti ti-pencil\" data-kid=\"1-5-1-1-1\" data-name=\"typography pencil icon\"></i> Text\n            </button>\n<button class=\"bg-[#FFFF00] brutalist-border p-3 hard-offset hover:bg-yellow-400\" data-kid=\"1-5-1-2\" data-name=\"share button\">\n<i class=\"ti ti-share text-2xl\" data-kid=\"1-5-1-2-1\" data-name=\"share icon\"></i>\n</button>\n</div>\n\n<div class=\"relative flex flex-col-reverse items-center gap-4 mb-20\" data-kid=\"1-5-2\" data-name=\"fab speed dial main container\" id=\"fab-container\">\n\n<button class=\"w-16 h-16 bg-[#FFFF00] brutalist-border rounded-full flex items-center justify-center hard-offset active:translate-x-1 active:translate-y-1 active:shadow-none cursor-pointer\" data-kid=\"1-5-2-1\" data-name=\"main fab toggle button\" id=\"fab-main\">\n<i class=\"ti ti-plus text-4xl font-bold\" data-kid=\"1-5-2-1-1\" data-name=\"plus icon\"></i>\n</button>\n\n<div class=\"absolute bottom-20 flex flex-col-reverse items-center gap-3\" data-kid=\"1-5-2-2\" data-name=\"speed dial sub-menu\">\n<button class=\"speed-dial-item w-12 h-12 bg-[#00FFFF] brutalist-border rounded-full flex items-center justify-center hard-offset-sm hover:scale-110 cursor-pointer\" data-kid=\"1-5-2-2-1\" data-name=\"sticker option button 1\">\n<img class=\"w-7 h-7\" data-kid=\"1-5-2-2-1-1\" data-name=\"sticker icon 1\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/bright-explosion.svg\">\n</button>\n<button class=\"speed-dial-item w-12 h-12 bg-[#FF00FF] brutalist-border rounded-full flex items-center justify-center hard-offset-sm hover:scale-110 cursor-pointer\" data-kid=\"1-5-2-2-2\" data-name=\"sticker option button 2\">\n<img class=\"w-7 h-7\" data-kid=\"1-5-2-2-2-1\" data-name=\"sticker icon 2\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/lightning-storm.svg\">\n</button>\n<button class=\"speed-dial-item w-12 h-12 bg-white brutalist-border rounded-full flex items-center justify-center hard-offset-sm hover:scale-110 cursor-pointer\" data-kid=\"1-5-2-2-3\" data-name=\"sticker option button 3\">\n<img class=\"w-7 h-7\" data-kid=\"1-5-2-2-3-1\" data-name=\"sticker icon 3\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/chat-bubble.svg\">\n</button>\n</div>\n</div>\n</div>\n\n<link data-kid=\"1-6\" data-name=\"tabler icons stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\">\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script type=\"module\" data-kid=\"3\">\n        import { animate, hover } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n        // FAB Speed Dial Toggle\n        const fabMain = document.getElementById('fab-main');\n        const fabContainer = document.getElementById('fab-container');\n        const fabIcon = fabMain.querySelector('i');\n\n        fabMain.addEventListener('click', () => {\n            fabContainer.classList.toggle('speed-dial-active');\n            gsap.to(fabIcon, {\n                rotate: fabContainer.classList.contains('speed-dial-active') ? 45 : 0,\n                duration: 0.3,\n                ease: \"back.out(1.7)\"\n            });\n            \n            // Stagger entrance of sub-buttons\n            const items = document.querySelectorAll('.speed-dial-item');\n            if(fabContainer.classList.contains('speed-dial-active')) {\n                gsap.to(items, {\n                    scale: 1,\n                    opacity: 1,\n                    y: 0,\n                    stagger: 0.05,\n                    duration: 0.4,\n                    ease: \"back.out(1.7)\"\n                });\n            } else {\n                gsap.to(items, {\n                    scale: 0,\n                    opacity: 0,\n                    y: 20,\n                    stagger: 0.05,\n                    duration: 0.2,\n                    ease: \"power2.in\"\n                });\n            }\n        });\n\n        // Sticker Wobble Animation\n        const stickers = document.querySelectorAll('.sticker');\n        stickers.forEach(sticker => {\n            sticker.addEventListener('click', () => {\n                animate(sticker, { x: [0, -8, 6, -4, 2, 0] }, { duration: 0.6, ease: \"easeOut\" });\n            });\n        });\n\n        // Hover Icon Jiggle\n        const buttons = document.querySelectorAll('button');\n        buttons.forEach(btn => {\n            hover(btn, el => {\n                const icon = btn.querySelector('i');\n                if(icon) {\n                    animate(icon, { rotate: [-8, 8, -5, 5, 0] }, { duration: 0.5, ease: \"easeOut\" });\n                }\n            });\n        });\n\n        // Entrance animation for photo cards\n        gsap.from(\".sticker-card\", {\n            opacity: 0,\n            y: 50,\n            rotate: 10,\n            stagger: 0.1,\n            duration: 0.8,\n            ease: \"power3.out\",\n            delay: 0.5\n        });\n\n        // Initial state for speed dial items\n        gsap.set('.speed-dial-item', { scale: 0, opacity: 0, y: 20 });\n\n    </script>\n</div>\n",
