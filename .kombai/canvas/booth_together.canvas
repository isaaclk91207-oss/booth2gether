      "html": "\n<div class=\"main-container relative min-h-screen w-full bg-[#00FFFF] font-['Space_Grotesk'] text-black overflow-x-clip p-4 flex flex-col items-center\" data-kid=\"1\" data-name=\"page layout container\">\n\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;500;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-anton { font-family: 'Anton', sans-serif; }\n    \n    .brutalist-border {\n      border: 4px solid #000000;\n    }\n    \n    .hard-shadow {\n      box-shadow: 6px 6px 0px #000000;\n    }\n\n    .hard-shadow-sm {\n      box-shadow: 4px 4px 0px #000000;\n    }\n\n    .halftone-bg {\n      background-image: radial-gradient(#000000 1.5px, transparent 1.5px);\n      background-size: 14px 14px;\n      opacity: 0.1;\n    }\n\n    .starburst-magenta {\n      clip-path: polygon(50% 0%, 56% 28%, 83% 10%, 68% 36%, 100% 40%, 72% 54%, 90% 82%, 60% 66%, 50% 100%, 40% 66%, 10% 82%, 28% 54%, 0% 40%, 32% 36%, 17% 10%, 44% 28%);\n      background: #FF00FF;\n    }\n\n    .sticker-wobble { cursor: pointer; }\n\n    .blob {\n      position: absolute;\n      width: 300px;\n      height: 300px;\n      background: #FF00FF;\n      filter: blur(80px);\n      border-radius: 50%;\n      z-index: 0;\n      opacity: 0.3;\n      animation: drift 20s infinite alternate;\n    }\n\n    @keyframes drift {\n      from { transform: translate(-10%, -10%); }\n      to { transform: translate(10%, 10%); }\n    }\n\n    .marquee-text {\n      white-space: nowrap;\n      animation: marquee 15s linear infinite;\n    }\n\n    @keyframes marquee {\n      0% { transform: translateX(0); }\n      100% { transform: translateX(-50%); }\n    }\n  </style>\n\n<div class=\"fixed inset-0 halftone-bg pointer-events-none\" data-kid=\"1-1\" data-name=\"background halftone texture layer\"></div>\n<div class=\"blob top-[-50px] left-[-50px]\" data-kid=\"1-2\" data-name=\"drifting magenta blob decoration\"></div>\n<div class=\"blob bottom-[-50px] right-[-50px]\" data-kid=\"1-3\" data-name=\"drifting yellow blob decoration\" style=\"background: #FFFF00; animation-delay: -10s;\"></div>\n\n<header class=\"relative z-10 w-full max-w-[375px] mb-6 pt-6\" data-kid=\"1-4\" data-name=\"header section\">\n<div class=\"flex items-center justify-between bg-[#FFFF00] brutalist-border hard-shadow p-3 rotate-[-1deg]\" data-kid=\"1-4-1\" data-name=\"header content container\">\n<h1 class=\"font-anton text-3xl uppercase tracking-tighter leading-none\" data-kid=\"1-4-1-1\" data-name=\"brand title text\">BoothTogether</h1>\n<div class=\"flex gap-2\" data-kid=\"1-4-1-2\" data-name=\"header icon wrapper\">\n<i class=\"ti ti-bolt text-2xl\" data-kid=\"1-4-1-2-1\" data-name=\"lightning bolt icon\"></i>\n</div>\n</div>\n</header>\n\n<main class=\"relative z-10 w-full max-w-[375px] grid grid-cols-2 gap-4\" data-kid=\"1-5\" data-name=\"bento grid main content area\">\n\n<section class=\"bento-item col-span-2 bg-[#FF00FF] brutalist-border hard-shadow p-6 relative overflow-hidden\" data-kid=\"1-5-1\" data-name=\"join room section\" id=\"join-room-tile\">\n<div class=\"absolute -top-4 -right-4 w-24 h-24 bg-[#FFFF00] brutalist-border rounded-full flex items-center justify-center rotate-12 z-0\" data-kid=\"1-5-1-1\" data-name=\"decorative star badge container\">\n<i class=\"ti ti-star-filled text-3xl\" data-kid=\"1-5-1-1-1\" data-name=\"star icon\"></i>\n</div>\n<div class=\"relative z-10\" data-kid=\"1-5-1-2\" data-name=\"join room form content wrapper\">\n<h2 class=\"font-anton text-5xl text-white uppercase italic tracking-tight mb-6 drop-shadow-[3px_3px_0_#000]\" data-kid=\"1-5-1-2-1\" data-name=\"join room headline\">Join Room</h2>\n<div class=\"flex flex-col gap-5\" data-kid=\"1-5-1-2-2\" data-name=\"form fields container\">\n<div class=\"group\" data-kid=\"1-5-1-2-2-1\" data-name=\"room code input group\">\n<label class=\"block font-bold uppercase text-xs tracking-widest text-white mb-2 ml-1\" data-kid=\"1-5-1-2-2-1-1\" data-name=\"room code label\">Room Code</label>\n<input class=\"w-full bg-white brutalist-border hard-shadow-sm p-4 text-2xl font-anton uppercase placeholder:text-gray-500 focus:outline-none focus:-translate-y-1 transition-transform\" data-kid=\"1-5-1-2-2-1-2\" data-name=\"room code text input\" placeholder=\"X-Y-Z-A\" type=\"text\">\n</div>\n<button class=\"w-full bg-[#FFFF00] brutalist-border hard-shadow p-4 font-anton text-3xl uppercase hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[8px_8px_0px_#000] active:translate-x-0 active:translate-y-0 active:shadow-none transition-all cursor-pointer\" data-kid=\"1-5-1-2-2-2\" data-name=\"enter room call-to-action button\" id=\"join-btn\">\n            Enter Room\n          </button>\n</div>\n</div>\n</section>\n\n<div class=\"bento-item bg-white brutalist-border hard-shadow-sm p-2 rotate-[-4deg] relative group\" data-kid=\"1-5-2\" data-name=\"recent photo card 1\">\n<img alt=\"Kevin Torres on Unsplash - Friends in photobooth posing happily\" class=\"w-full aspect-square object-cover brutalist-border\" data-kid=\"1-5-2-1\" data-name=\"photo image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1746587224861-521244472226?auto=format&amp;w=300&amp;q=80&amp;fit=crop\">\n<div class=\"mt-2 flex justify-between items-center\" data-kid=\"1-5-2-2\" data-name=\"photo metadata footer\">\n<span class=\"text-[10px] font-bold uppercase italic\" data-kid=\"1-5-2-2-1\" data-name=\"photo author handle\">@vibe_check</span>\n<i class=\"ti ti-heart-filled text-[#FF00FF] text-xs\" data-kid=\"1-5-2-2-2\" data-name=\"heart icon\"></i>\n</div>\n\n<div class=\"sticker-wobble absolute -top-2 -right-2 bg-[#FFFF00] p-1 brutalist-border text-[8px] font-black uppercase rotate-12 z-20\" data-kid=\"1-5-2-3\" data-name=\"new badge sticker\">New!</div>\n</div>\n\n<div class=\"bento-item bg-white brutalist-border hard-shadow-sm p-2 rotate-[3deg] relative\" data-kid=\"1-5-3\" data-name=\"recent photo card 2\">\n<img alt=\"cottonbro studio on Pexels - Fun candid moment in photobooth\" class=\"w-full aspect-square object-cover brutalist-border\" data-kid=\"1-5-3-1\" data-name=\"photo image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858880/pexels-photo-4858880.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=300&amp;q=80\">\n<div class=\"mt-2 flex justify-between items-center\" data-kid=\"1-5-3-2\" data-name=\"photo caption footer\">\n<span class=\"text-[10px] font-bold uppercase italic\" data-kid=\"1-5-3-2-1\" data-name=\"photo caption text\">Recap: Lollapalooza</span>\n</div>\n<div class=\"sticker-wobble absolute -bottom-3 -left-3 w-10 h-10 starburst-magenta flex items-center justify-center rotate-[-10deg] z-20\" data-kid=\"1-5-3-3\" data-name=\"decorative starburst sticker\">\n<i class=\"ti ti-star text-white text-sm\" data-kid=\"1-5-3-3-1\" data-name=\"star icon\"></i>\n</div>\n</div>\n\n<div class=\"bento-item col-span-2 bg-[#000000] brutalist-border hard-shadow p-4 flex items-center justify-between overflow-hidden relative min-h-[80px]\" data-kid=\"1-5-4\" data-name=\"community sticker tile\">\n<div alt=\"Tasha Kostyuk on Unsplash - Collage of stickers\" class=\"absolute inset-0 opacity-40 bg-[url('https://images.unsplash.com/photo-1753430708971-892048584cf3?auto=format&amp;w=400&amp;q=80&amp;fit=crop')] bg-cover bg-center\" data-kid=\"1-5-4-1\" data-name=\"tile background image container\"></div>\n<div class=\"relative z-10 w-full flex justify-between items-center gap-4\" data-kid=\"1-5-4-2\" data-name=\"tile content wrapper\">\n<div class=\"font-anton text-3xl text-white uppercase italic tracking-tighter marquee-container overflow-hidden flex-1 flex\" data-kid=\"1-5-4-2-1\" data-name=\"marquee text container\">\n<div class=\"marquee-text flex gap-8 shrink-0\" data-kid=\"1-5-4-2-1-1\" data-name=\"scrolling marquee text\">\n<span data-kid=\"1-5-4-2-1-1-1\" data-name=\"marquee text segment 1\">JOIN THE COMMUNITY</span> <span data-kid=\"1-5-4-2-1-1-2\" data-name=\"marquee separator 1\">★</span> <span data-kid=\"1-5-4-2-1-1-3\" data-name=\"marquee text segment 2\">RECENT CLIPS</span> <span data-kid=\"1-5-4-2-1-1-4\" data-name=\"marquee separator 2\">★</span> <span data-kid=\"1-5-4-2-1-1-5\" data-name=\"marquee text segment 3\">POPULAR NOW</span> <span data-kid=\"1-5-4-2-1-1-6\" data-name=\"marquee separator 3\">★</span>\n<span data-kid=\"1-5-4-2-1-1-7\" data-name=\"marquee text segment 4\">JOIN THE COMMUNITY</span> <span data-kid=\"1-5-4-2-1-1-8\" data-name=\"marquee separator 4\">★</span> <span data-kid=\"1-5-4-2-1-1-9\" data-name=\"marquee text segment 5\">RECENT CLIPS</span> <span data-kid=\"1-5-4-2-1-1-10\" data-name=\"marquee separator 5\">★</span> <span data-kid=\"1-5-4-2-1-1-11\" data-name=\"marquee text segment 6\">POPULAR NOW</span> <span data-kid=\"1-5-4-2-1-1-12\" data-name=\"marquee separator 6\">★</span>\n</div>\n</div>\n<button class=\"shrink-0 bg-[#FF00FF] brutalist-border border-white p-2 px-6 text-white font-anton text-sm uppercase hover:bg-[#FFFF00] hover:text-black transition-colors cursor-pointer\" data-kid=\"1-5-4-2-2\" data-name=\"view all call-to-action button\">\n          View All\n        </button>\n</div>\n</div>\n\n<div class=\"bento-item col-span-2 mt-4 pb-8 flex flex-col items-center gap-4\" data-kid=\"1-5-5\" data-name=\"footer action area\">\n<div class=\"bg-[#FFFF00] brutalist-border px-4 py-1 rotate-1\" data-kid=\"1-5-5-1\" data-name=\"footer help text wrapper\">\n<p class=\"text-center font-black uppercase text-xs tracking-widest text-[#000]\" data-kid=\"1-5-5-1-1\" data-name=\"footer help text\">Don't have a code?</p>\n</div>\n<button class=\"w-full flex items-center justify-center gap-3 bg-white brutalist-border hard-shadow p-5 font-anton text-2xl uppercase hover:bg-[#FFFF00] transition-colors cursor-pointer group\" data-kid=\"1-5-5-2\" data-name=\"create room call-to-action button\">\n<i class=\"ti ti-plus text-2xl\" data-kid=\"1-5-5-2-1\" data-name=\"plus icon\"></i>\n        Create Your Own Room\n      </button>\n</div>\n</main>\n\n<div class=\"sticker-wobble fixed top-1/6 -right-10 w-32 h-32 flex items-center justify-center rotate-12 pointer-events-auto z-20\" data-kid=\"1-6\" data-name=\"floating lightning storm sticker container\" style=\"filter: drop-shadow(4px 4px 0 #000);\">\n<i class=\"ti ti-bolt text-8xl text-[#FFFF00]\" data-kid=\"1-6-1\" data-name=\"lightning storm icon\"></i>\n</div>\n<div class=\"sticker-wobble fixed bottom-20 -left-6 w-24 h-24 starburst-magenta rotate-[-20deg] flex items-center justify-center pointer-events-auto shadow-lg z-20\" data-kid=\"1-7\" data-name=\"floating booth magic sticker\">\n<span class=\"font-anton text-white text-[11px] text-center px-1 leading-none drop-shadow-sm\" data-kid=\"1-7-1\" data-name=\"booth magic text label\">STICKER<br data-kid=\"1-7-1-1\" data-name=\"line break\">SWAG</span>\n</div>\n<div class=\"sticker-wobble fixed top-1/2 -right-6 w-20 h-20 bg-[#FFFF00] brutalist-border rounded-full flex items-center justify-center rotate-[15deg] pointer-events-auto z-20 shadow-xl\" data-kid=\"1-8\" data-name=\"floating mood smile sticker\">\n<i class=\"ti ti-mood-smile-filled text-black text-5xl\" data-kid=\"1-8-1\" data-name=\"mood smile icon\"></i>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script type=\"module\" data-kid=\"3\">\n    import { animate } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n\n    // GSAP Mask Wipe for entrance\n    gsap.from(\"#join-room-tile\", {\n      clipPath: \"inset(0 100% 0 0)\",\n      duration: 1.2,\n      ease: \"power4.inOut\",\n      delay: 0.2\n    });\n\n    // Staggered entrance for photos\n    gsap.from(\".bento-item\", {\n        y: 50,\n        opacity: 0,\n        stagger: 0.1,\n        duration: 0.8,\n        ease: \"back.out(1.7)\",\n        delay: 0.5\n    });\n\n    // Motion Jiggle on button hover\n    const joinBtn = document.getElementById('join-btn');\n    joinBtn.addEventListener('mouseenter', () => {\n      animate(joinBtn, { rotate: [-2, 2, -1, 1, 0] }, { duration: 0.4, ease: \"easeOut\" });\n    });\n\n    document.querySelectorAll('.bento-item button').forEach(btn => {\n      btn.addEventListener('mouseenter', () => {\n        animate(btn, { scale: 1.05 }, { duration: 0.2 });\n      });\n      btn.addEventListener('mouseleave', () => {\n        animate(btn, { scale: 1 }, { duration: 0.2 });\n      });\n    });\n\n    // Anime Spring Wobble on stickers\n    // Using simple hover effect for stickers as per pattern suggestion\n    document.querySelectorAll('.sticker-wobble').forEach(sticker => {\n      sticker.addEventListener('mouseenter', () => {\n        animate(sticker, { \n          x: [0, -10, 8, -5, 3, 0], \n          scale: [1, 1.1, 1]\n        }, { \n          duration: 0.6, \n          ease: \"easeOut\" \n        });\n      });\n    });\n\n  </script>\n</div>\n",
