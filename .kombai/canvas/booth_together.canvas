      },
      "html": "\n<div class=\"w-[375px] h-[667px] relative bg-[#111111] overflow-hidden font-['Inter'] text-[#F7E7CE]\" data-kid=\"1\" data-name=\"page layout container\">\n\n<div class=\"absolute inset-0 z-0 bg-[#111111]\" data-kid=\"1-1\" data-name=\"cinematic background layer container\" id=\"video-bg\">\n<img alt=\"Cinematic Bokeh Background\" class=\"w-full h-full object-cover opacity-40 scale-105\" data-kid=\"1-1-1\" data-name=\"cinematic bokeh background image\" decoding=\"async\" id=\"bg-image\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1432847712612-926caafaa802?auto=format&amp;w=1000&amp;q=80&amp;fit=crop\">\n\n<div class=\"absolute inset-0 bg-gradient-to-b from-[#111111]/60 via-transparent to-[#111111]\" data-kid=\"1-1-2\" data-name=\"dark atmosphere gradient overlay\"></div>\n<div class=\"absolute inset-0 bg-[#301934]/25 mix-blend-color-burn\" data-kid=\"1-1-3\" data-name=\"purple tint overlay\"></div>\n<div class=\"absolute inset-0 bg-gradient-to-tr from-[#301934]/40 via-transparent to-transparent\" data-kid=\"1-1-4\" data-name=\"corner light gradient overlay\"></div>\n</div>\n\n<header class=\"absolute top-0 left-0 w-full pt-10 px-8 flex justify-between items-center z-10\" data-kid=\"1-2\" data-name=\"header navigation bar\" id=\"header\">\n<div class=\"flex items-center gap-2.5\" data-kid=\"1-2-1\" data-name=\"brand logo area\">\n<div class=\"w-9 h-9 rounded-xl bg-[#F56FA1] flex items-center justify-center shadow-[0_8px_20px_rgba(245,111,161,0.5)] rotate-3 ring-1 ring-white/20\" data-kid=\"1-2-1-1\" data-name=\"logo icon container\">\n<i class=\"ti ti-camera-selfie text-white text-xl\" data-kid=\"1-2-1-1-1\" data-name=\"camera selfie icon\"></i>\n</div>\n<span class=\"text-xl font-['Playfair_Display'] font-bold tracking-tight text-[#F7E7CE]\" data-kid=\"1-2-1-2\" data-name=\"brand name text\">Booth<span class=\"text-[#F56FA1] ml-0.5\" data-kid=\"1-2-1-2-1\" data-name=\"brand suffix text\">Together</span></span>\n</div>\n<button class=\"w-9 h-9 rounded-full bg-white/5 backdrop-blur-md flex items-center justify-center border border-white/10 hover:bg-white/15 cursor-pointer\" data-kid=\"1-2-2\" data-name=\"help button\">\n<i class=\"ti ti-help text-lg text-[#F7E7CE] opacity-60\" data-kid=\"1-2-2-1\" data-name=\"help icon\"></i>\n</button>\n</header>\n\n<div class=\"absolute bottom-0 left-0 w-full z-20 translate-y-[100%]\" data-kid=\"1-3\" data-name=\"bottom sheet container\" id=\"bottom-sheet\">\n<div class=\"bg-white/10 backdrop-blur-[45px] border-t border-x border-white/20 rounded-t-[48px] p-8 pb-10 shadow-[0_-20px_50px_rgba(0,0,0,0.6)]\" data-kid=\"1-3-1\" data-name=\"bottom sheet content wrapper\">\n\n<div class=\"w-12 h-1 bg-[#F7E7CE]/20 rounded-full mx-auto mb-6\" data-kid=\"1-3-1-1\" data-name=\"drag handle decorative element\"></div>\n\n<div class=\"space-y-6\" data-kid=\"1-3-1-2\" data-name=\"sheet content area\">\n<div class=\"space-y-2 animate-item\" data-kid=\"1-3-1-2-1\" data-name=\"header text block\">\n<h1 class=\"font-['Playfair_Display'] text-[38px] text-[#F7E7CE] leading-tight\" data-kid=\"1-3-1-2-1-1\" data-name=\"headline text\">Enter the <br data-kid=\"1-3-1-2-1-1-1\" data-name=\"headline line break\">Booth</h1>\n<p class=\"text-[#F7E7CE]/70 text-sm max-w-[90%] leading-relaxed font-light\" data-kid=\"1-3-1-2-1-2\" data-name=\"description text\">Join your crew for an exclusive photobooth session.</p>\n</div>\n<div class=\"space-y-5\" data-kid=\"1-3-1-2-2\" data-name=\"form inputs container\">\n\n<div class=\"group space-y-2 animate-item\" data-kid=\"1-3-1-2-2-1\" data-name=\"session code input group\">\n<label class=\"block text-[10px] uppercase tracking-[0.2em] font-bold text-[#F56FA1] ml-1 opacity-70\" data-kid=\"1-3-1-2-2-1-1\" data-name=\"input label text\">Access Code</label>\n<div class=\"relative\" data-kid=\"1-3-1-2-2-1-2\" data-name=\"input wrapper\">\n<input class=\"w-full bg-[#111111]/70 border border-white/10 rounded-xl py-3 px-5 text-[#F7E7CE] placeholder-[#F7E7CE]/15 text-base font-medium outline-hidden focus:border-[#F56FA1] focus:outline focus:outline-1 focus:outline-[#F56FA1]/40 focus:outline-offset-4 transition-all\" data-kid=\"1-3-1-2-2-1-2-1\" data-name=\"session code input field\" placeholder=\"BT-ROOM-001\" type=\"text\">\n<button class=\"absolute right-3 top-1/2 -translate-y-1/2 w-8 h-8 rounded-lg flex items-center justify-center text-[#F7E7CE]/30 hover:text-[#F56FA1] cursor-pointer\" data-kid=\"1-3-1-2-2-1-2-2\" data-name=\"scan QR code action button\">\n<i class=\"ti ti-qrcode text-xl\" data-kid=\"1-3-1-2-2-1-2-2-1\" data-name=\"qr code icon\"></i>\n</button>\n</div>\n</div>\n\n<button class=\"animate-item w-full bg-linear-to-r from-[#F56FA1] to-[#F56FA1]/90 text-white py-4 rounded-xl font-bold text-base shadow-[0_12px_32px_-8px_rgba(245,111,161,0.6)] cursor-pointer\" data-kid=\"1-3-1-2-2-2\" data-name=\"start session button\" id=\"join-btn\">\n                        Start Session\n                    </button>\n\n<div class=\"text-center animate-item\" data-kid=\"1-3-1-2-2-3\" data-name=\"secondary link container\">\n<a class=\"text-[11px] font-bold uppercase tracking-[0.1em] text-[#F7E7CE]/30 hover:text-[#F7E7CE] transition-colors\" data-kid=\"1-3-1-2-2-3-1\" data-name=\"host new room link\" href=\"#\">Host a new room?</a>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\nbody {\n    background-color: #111111;\n    margin: 0;\n}\n\n\n/* Scroll Smoothing and other visual tweaks */\n.backdrop-blur-\\[40px\\] {\n    backdrop-filter: blur(40px);\n}\n</style>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script type=\"module\" data-kid=\"3\">\n    import { animate, hover } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    // Entrance Animation\n    window.addEventListener('DOMContentLoaded', () => {\n        const tl = gsap.timeline();\n        \n        // 1. Initial background zoom and fade\n        tl.from(\"#bg-image\", {\n            duration: 2,\n            scale: 1.3,\n            opacity: 0,\n            ease: \"power2.out\"\n        });\n\n        // 2. Header slide down\n        tl.from(\"#header\", {\n            duration: 1,\n            y: -50,\n            opacity: 0,\n            ease: \"power3.out\"\n        }, \"-=1.5\");\n\n        // 3. Bottom sheet rise\n        tl.to(\"#bottom-sheet\", {\n            duration: 1.2,\n            y: 0,\n            ease: \"power4.out\"\n        }, \"-=1\");\n\n        // Staggered reveal of form elements inside sheet using the simple class\n        tl.from(\".animate-item\", {\n            duration: 0.8,\n            y: 30,\n            opacity: 0,\n            stagger: 0.12,\n            ease: \"power2.out\"\n        }, \"-=0.6\");\n    });\n\n    // #motion-hover-glow on the primary action button\n    const joinBtn = document.querySelector(\"#join-btn\");\n    hover(joinBtn, (element) => {\n        animate(element, { \n            boxShadow: \"0 20px 45px rgba(245, 111, 161, 0.7)\",\n            y: -2,\n            scale: 1.02\n        }, { duration: 0.3 });\n        return () => animate(element, { \n            boxShadow: \"0 12px 32px rgba(245, 111, 161, 0.6)\",\n            y: 0,\n            scale: 1\n        }, { duration: 0.3 });\n    });\n\n</script>\n",
