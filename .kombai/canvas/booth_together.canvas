      "html": "\n<div class=\"w-full min-h-screen bg-[#FDF5E6] flex justify-center selection:bg-[#B57EDC]/30 overflow-x-clip\" data-kid=\"1\">\n<div class=\"w-full max-w-[375px] min-h-screen bg-[#FDF5E6] bg-diagonal-stripes font-['Nunito_Sans'] text-gray-800 relative overflow-hidden flex flex-col\" data-kid=\"1-1\">\n<style data-kid=\"0\">\n            @import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&family=Nunito+Sans:wght@400;600;700&display=swap');\n            @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n            .font-quicksand { font-family: 'Quicksand', sans-serif; }\n            \n            .bg-diagonal-stripes {\n                background-image: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(181, 126, 220, 0.02) 20px, rgba(181, 126, 220, 0.02) 40px);\n            }\n\n            .photo-tilt-1 { transform: rotate(-1.2deg); }\n            .photo-tilt-2 { transform: rotate(1.8deg); }\n            .photo-tilt-3 { transform: rotate(-1.5deg); }\n            .photo-tilt-4 { transform: rotate(0.8deg); }\n\n            .glass-sheet {\n                background: rgba(255, 255, 255, 0.98);\n                backdrop-filter: blur(12px);\n            }\n\n            .no-scrollbar::-webkit-scrollbar { display: none; }\n            .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n        </style>\n\n<div class=\"absolute top-[-5%] right-[-10%] w-64 h-64 bg-[#B57EDC]/15 rounded-full blur-3xl pointer-events-none\" data-kid=\"1-1-1\"></div>\n<div class=\"absolute bottom-[20%] left-[-15%] w-80 h-80 bg-[#89CFF0]/15 rounded-full blur-3xl pointer-events-none\" data-kid=\"1-1-2\"></div>\n\n<header class=\"sticky top-0 z-30 px-6 py-6 flex items-center justify-between bg-[#FDF5E6]/80 backdrop-blur-md shrink-0 border-b border-[#B57EDC]/5\" data-kid=\"1-1-3\">\n<button class=\"w-11 h-11 rounded-[16px] bg-white flex items-center justify-center shadow-sm text-gray-400 active:scale-90 transition-transform\" data-kid=\"1-1-3-1\">\n<i class=\"ti ti-arrow-left text-xl\" data-kid=\"1-1-3-1-1\"></i>\n</button>\n<div class=\"text-center\" data-kid=\"1-1-3-2\">\n<h1 class=\"text-xl font-quicksand font-bold tracking-tight text-gray-800\" data-kid=\"1-1-3-2-1\">Your Photos</h1>\n<p class=\"text-[11px] uppercase tracking-widest text-[#B57EDC] font-extrabold mt-0.5\" data-kid=\"1-1-3-2-2\">Perfect shots! ✨</p>\n</div>\n<button class=\"w-11 h-11 rounded-[16px] bg-white flex items-center justify-center shadow-sm text-[#B57EDC] active:scale-90 transition-transform\" data-kid=\"1-1-3-3\">\n<i class=\"ti ti-adjustments-horizontal text-xl\" data-kid=\"1-1-3-3-1\"></i>\n</button>\n</header>\n\n<main class=\"px-5 pt-2 pb-44 overflow-y-auto grow no-scrollbar\" data-kid=\"1-1-4\">\n<div class=\"columns-2 gap-4 space-y-5\" data-kid=\"1-1-4-1\" id=\"photo-grid\">\n\n<div class=\"photo-card photo-tilt-1 break-inside-avoid bg-white p-3.5 rounded-[30px] shadow-lg shadow-gray-200/50 border border-white cursor-pointer group hover:z-10\" data-kid=\"1-1-4-1-1\" onclick=\"openEditor('Shot 01', 'https://images.pexels.com/photos/4926675/pexels-photo-4926675.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80')\">\n<div class=\"relative overflow-hidden rounded-[20px] aspect-[3/4.5]\" data-kid=\"1-1-4-1-1-1\">\n<img alt=\"Two friends smiling\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" data-kid=\"1-1-4-1-1-1-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4926675/pexels-photo-4926675.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n\n<div class=\"absolute top-2 right-2 bg-white/90 p-1.5 rounded-full shadow-sm animate-bounce\" data-kid=\"1-1-4-1-1-1-2\">\n<i class=\"ti ti-sparkles text-[#B57EDC] text-xs\" data-kid=\"1-1-4-1-1-1-2-1\"></i>\n</div>\n<div class=\"absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center\" data-kid=\"1-1-4-1-1-1-3\">\n<div class=\"bg-white/95 p-3 rounded-2xl shadow-xl scale-90 group-hover:scale-100 transition-transform\" data-kid=\"1-1-4-1-1-1-3-1\">\n<i class=\"ti ti-brush text-[#B57EDC] text-xl\" data-kid=\"1-1-4-1-1-1-3-1-1\"></i>\n</div>\n</div>\n</div>\n<div class=\"mt-3 flex justify-between items-center px-1.5\" data-kid=\"1-1-4-1-1-2\">\n<span class=\"text-[11px] font-extrabold text-[#B57EDC] tracking-widest font-quicksand uppercase\" data-kid=\"1-1-4-1-1-2-1\">Shot 01</span>\n<div class=\"flex items-center gap-1.5\" data-kid=\"1-1-4-1-1-2-2\" data-name=\"photo card menu and status container\">\n<i class=\"ti ti-sticker text-[#B57EDC]/30 text-xs\" data-kid=\"1-1-4-1-1-2-2-1\" data-name=\"sticker indicator icon\"></i>\n<i class=\"ti ti-dots-vertical text-gray-300\" data-kid=\"1-1-4-1-1-2-2-2\" data-name=\"options menu icon\"></i>\n</div>\n</div>\n</div>\n\n<div class=\"photo-card photo-tilt-2 break-inside-avoid bg-white p-3.5 rounded-[30px] shadow-lg shadow-gray-200/50 border border-white cursor-pointer group hover:z-10\" data-kid=\"1-1-4-1-2\" onclick=\"openEditor('Shot 02', 'https://images.pexels.com/photos/7283539/pexels-photo-7283539.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80')\">\n<div class=\"relative overflow-hidden rounded-[20px] aspect-[4/5]\" data-kid=\"1-1-4-1-2-1\">\n<img alt=\"Two friends laughing\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" data-kid=\"1-1-4-1-2-1-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/7283539/pexels-photo-7283539.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n<div class=\"absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center\" data-kid=\"1-1-4-1-2-1-2\">\n<div class=\"bg-white/95 p-3 rounded-2xl shadow-xl scale-90 group-hover:scale-100 transition-transform\" data-kid=\"1-1-4-1-2-1-2-1\">\n<i class=\"ti ti-brush text-[#B57EDC] text-xl\" data-kid=\"1-1-4-1-2-1-2-1-1\"></i>\n</div>\n</div>\n</div>\n<div class=\"mt-3 flex justify-between items-center px-1.5\" data-kid=\"1-1-4-1-2-2\">\n<span class=\"text-[11px] font-extrabold text-[#B57EDC] tracking-widest font-quicksand uppercase\" data-kid=\"1-1-4-1-2-2-1\">Shot 02</span>\n</div>\n</div>\n\n<div class=\"photo-card photo-tilt-3 break-inside-avoid bg-white p-3.5 rounded-[30px] shadow-lg shadow-gray-200/50 border border-white cursor-pointer group hover:z-10\" data-kid=\"1-1-4-1-3\" onclick=\"openEditor('Shot 03', 'https://images.pexels.com/photos/10159332/pexels-photo-10159332.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80')\">\n<div class=\"relative overflow-hidden rounded-[20px] aspect-[3/5]\" data-kid=\"1-1-4-1-3-1\">\n<img alt=\"Friends laughing outdoors\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" data-kid=\"1-1-4-1-3-1-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/10159332/pexels-photo-10159332.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n<div class=\"absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center\" data-kid=\"1-1-4-1-3-1-2\">\n<div class=\"bg-white/95 p-3 rounded-2xl shadow-xl scale-90 group-hover:scale-100 transition-transform\" data-kid=\"1-1-4-1-3-1-2-1\">\n<i class=\"ti ti-brush text-[#B57EDC] text-xl\" data-kid=\"1-1-4-1-3-1-2-1-1\"></i>\n</div>\n</div>\n</div>\n<div class=\"mt-3 flex justify-between items-center px-1.5\" data-kid=\"1-1-4-1-3-2\">\n<span class=\"text-[11px] font-extrabold text-[#B57EDC] tracking-widest font-quicksand uppercase\" data-kid=\"1-1-4-1-3-2-1\">Shot 03</span>\n</div>\n</div>\n\n<div class=\"photo-card photo-tilt-4 break-inside-avoid bg-white p-3.5 rounded-[30px] shadow-lg shadow-gray-200/50 border border-white cursor-pointer group hover:z-10\" data-kid=\"1-1-4-1-4\" onclick=\"openEditor('Shot 04', 'https://images.pexels.com/photos/6135162/pexels-photo-6135162.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80')\">\n<div class=\"relative overflow-hidden rounded-[20px] aspect-[4/5.5]\" data-kid=\"1-1-4-1-4-1\">\n<img alt=\"Friends looking at camera\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" data-kid=\"1-1-4-1-4-1-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/6135162/pexels-photo-6135162.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n<div class=\"absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center\" data-kid=\"1-1-4-1-4-1-2\">\n<div class=\"bg-white/95 p-3 rounded-2xl shadow-xl scale-90 group-hover:scale-100 transition-transform\" data-kid=\"1-1-4-1-4-1-2-1\">\n<i class=\"ti ti-brush text-[#B57EDC] text-xl\" data-kid=\"1-1-4-1-4-1-2-1-1\"></i>\n</div>\n</div>\n</div>\n<div class=\"mt-3 flex justify-between items-center px-1.5\" data-kid=\"1-1-4-1-4-2\">\n<span class=\"text-[11px] font-extrabold text-[#B57EDC] tracking-widest font-quicksand uppercase\" data-kid=\"1-1-4-1-4-2-1\">Shot 04</span>\n</div>\n</div>\n</div>\n</main>\n\n<div class=\"absolute bottom-0 left-0 right-0 z-40 p-8 pt-10 bg-gradient-to-t from-[#FDF5E6] via-[#FDF5E6] to-transparent\" data-kid=\"1-1-5\">\n<div class=\"w-full\" data-kid=\"1-1-5-1\">\n<button class=\"w-full bg-[#B57EDC] text-white font-quicksand font-bold py-5 rounded-[24px] shadow-[0_12px_24px_-6px_rgba(181,126,220,0.5)] flex items-center justify-center gap-3 active:scale-[0.97] group\" data-kid=\"1-1-5-1-1\" id=\"next-btn\">\n<span class=\"text-lg tracking-wide\" data-kid=\"1-1-5-1-1-1\">Looks good!</span>\n<i class=\"ti ti-arrow-right text-xl group-hover:translate-x-1 transition-transform\" data-kid=\"1-1-5-1-1-2\"></i>\n</button>\n<p class=\"text-center text-[10px] text-gray-400 mt-4 font-bold uppercase tracking-[0.2em]\" data-kid=\"1-1-5-1-2\">Next: Print or Share</p>\n</div>\n</div>\n\n<div class=\"absolute inset-0 z-50 bg-black/40 hidden backdrop-blur-sm transition-opacity duration-300 opacity-0\" data-kid=\"1-1-6\" id=\"bottom-sheet-overlay\" onclick=\"closeEditor()\"></div>\n\n<div class=\"absolute bottom-0 left-0 right-0 z-50 glass-sheet rounded-t-[40px] shadow-2xl translate-y-full transition-transform duration-500 ease-out\" data-kid=\"1-1-7\" id=\"bottom-sheet\">\n<div class=\"w-full p-6 pb-12\" data-kid=\"1-1-7-1\">\n\n<div class=\"w-12 h-1.5 bg-gray-200 rounded-full mx-auto mb-6\" data-kid=\"1-1-7-1-1\"></div>\n<div class=\"flex items-center justify-between mb-8\" data-kid=\"1-1-7-1-2\">\n<div data-kid=\"1-1-7-1-2-1\">\n<h2 class=\"text-xl font-quicksand font-bold text-gray-800\" data-dynamic=\"true\" data-kid=\"1-1-7-1-2-1-1\" data-name=\"editor title\" data-reason=\"text replaced by script when photo is selected\" id=\"editor-title\">Edit Shot</h2>\n<p class=\"text-xs text-gray-400\" data-kid=\"1-1-7-1-2-1-2\">Personalize with stickers &amp; more</p>\n</div>\n<button class=\"w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center text-gray-400\" data-kid=\"1-1-7-1-2-2\" onclick=\"closeEditor()\">\n<i class=\"ti ti-x text-lg\" data-kid=\"1-1-7-1-2-2-1\"></i>\n</button>\n</div>\n\n<div class=\"flex gap-4 mb-8 overflow-x-auto no-scrollbar py-1\" data-kid=\"1-1-7-1-3\">\n<button class=\"flex flex-col items-center gap-2 min-w-[72px]\" data-kid=\"1-1-7-1-3-1\">\n<div class=\"w-16 h-16 rounded-[24px] bg-[#B57EDC] text-white flex items-center justify-center shadow-lg shadow-[#B57EDC]/30\" data-kid=\"1-1-7-1-3-1-1\">\n<i class=\"ti ti-sticker text-2xl\" data-kid=\"1-1-7-1-3-1-1-1\"></i>\n</div>\n<span class=\"text-xs font-bold text-gray-800\" data-kid=\"1-1-7-1-3-1-2\">Stickers</span>\n</button>\n<button class=\"flex flex-col items-center gap-2 min-w-[72px] opacity-40\" data-kid=\"1-1-7-1-3-2\">\n<div class=\"w-16 h-16 rounded-[24px] bg-white border-2 border-dashed border-gray-100 flex items-center justify-center text-gray-400\" data-kid=\"1-1-7-1-3-2-1\">\n<i class=\"ti ti-brush text-2xl\" data-kid=\"1-1-7-1-3-2-1-1\"></i>\n</div>\n<span class=\"text-xs font-bold\" data-kid=\"1-1-7-1-3-2-2\">Draw</span>\n</button>\n<button class=\"flex flex-col items-center gap-2 min-w-[72px] opacity-40\" data-kid=\"1-1-7-1-3-3\">\n<div class=\"w-16 h-16 rounded-[24px] bg-white border-2 border-dashed border-gray-100 flex items-center justify-center text-gray-400\" data-kid=\"1-1-7-1-3-3-1\">\n<i class=\"ti ti-typography text-2xl\" data-kid=\"1-1-7-1-3-3-1-1\"></i>\n</div>\n<span class=\"text-xs font-bold\" data-kid=\"1-1-7-1-3-3-2\">Text</span>\n</button>\n<button class=\"flex flex-col items-center gap-2 min-w-[72px] opacity-40\" data-kid=\"1-1-7-1-3-4\">\n<div class=\"w-16 h-16 rounded-[24px] bg-white border-2 border-dashed border-gray-100 flex items-center justify-center text-gray-400\" data-kid=\"1-1-7-1-3-4-1\">\n<i class=\"ti ti-filter text-2xl\" data-kid=\"1-1-7-1-3-4-1-1\"></i>\n</div>\n<span class=\"text-xs font-bold\" data-kid=\"1-1-7-1-3-4-2\">Filters</span>\n</button>\n</div>\n\n<div class=\"grid grid-cols-4 gap-4 mb-8\" data-kid=\"1-1-7-1-4\">\n<div class=\"aspect-square bg-[#FDF5E6] rounded-[24px] flex items-center justify-center cursor-pointer hover:scale-105 active:scale-95 border border-[#B57EDC]/10 shadow-sm\" data-kid=\"1-1-7-1-4-1\">\n<img class=\"w-8 h-8 opacity-80\" data-kid=\"1-1-7-1-4-1-1\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/bubbles.svg\" style=\"filter: invert(65%) sepia(21%) saturate(2202%) hue-rotate(228deg) brightness(91%) contrast(84%);\">\n</div>\n<div class=\"aspect-square bg-[#89CFF0]/10 rounded-[24px] flex items-center justify-center cursor-pointer hover:scale-105 active:scale-95 border border-[#89CFF0]/10 shadow-sm\" data-kid=\"1-1-7-1-4-2\">\n<img class=\"w-8 h-8 opacity-80\" data-kid=\"1-1-7-1-4-2-1\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/sparkles.svg\" style=\"filter: invert(80%) sepia(20%) saturate(1000%) hue-rotate(180deg) brightness(95%) contrast(90%);\">\n</div>\n<div class=\"aspect-square bg-pink-50 rounded-[24px] flex items-center justify-center cursor-pointer hover:scale-105 active:scale-95 border border-pink-100 shadow-sm\" data-kid=\"1-1-7-1-4-3\">\n<i class=\"ti ti-heart-filled text-pink-400 text-2xl\" data-kid=\"1-1-7-1-4-3-1\"></i>\n</div>\n<div class=\"aspect-square bg-yellow-50 rounded-[24px] flex items-center justify-center cursor-pointer hover:scale-105 active:scale-95 border border-yellow-100 shadow-sm\" data-kid=\"1-1-7-1-4-4\">\n<i class=\"ti ti-star-filled text-yellow-400 text-2xl\" data-kid=\"1-1-7-1-4-4-1\"></i>\n</div>\n<div class=\"aspect-square bg-green-50 rounded-[24px] flex items-center justify-center cursor-pointer hover:scale-105 active:scale-95 border border-green-100 shadow-sm\" data-kid=\"1-1-7-1-4-5\" data-name=\"sticker choice with leaf icon\">\n<i class=\"ti ti-leaf text-green-400 text-2xl\" data-kid=\"1-1-7-1-4-5-1\" data-name=\"leaf icon\"></i>\n</div>\n<div class=\"aspect-square bg-purple-50 rounded-[24px] flex items-center justify-center cursor-pointer hover:scale-105 active:scale-95 border border-purple-100 shadow-sm\" data-kid=\"1-1-7-1-4-6\" data-name=\"sticker choice with smile icon\">\n<i class=\"ti ti-mood-smile text-purple-400 text-2xl\" data-kid=\"1-1-7-1-4-6-1\" data-name=\"smile icon\"></i>\n</div>\n<div class=\"aspect-square bg-blue-50 rounded-[24px] flex items-center justify-center cursor-pointer hover:scale-105 active:scale-95 border border-blue-100 shadow-sm\" data-kid=\"1-1-7-1-4-7\" data-name=\"sticker choice with cloud icon\">\n<i class=\"ti ti-cloud-filled text-blue-300 text-2xl\" data-kid=\"1-1-7-1-4-7-1\" data-name=\"cloud icon\"></i>\n</div>\n<div class=\"aspect-square bg-gray-50 rounded-[24px] flex items-center justify-center cursor-pointer hover:scale-105 active:scale-95 border border-dashed border-gray-200\" data-kid=\"1-1-7-1-4-8\" data-name=\"add more stickers button\">\n<i class=\"ti ti-plus text-gray-400 text-xl\" data-kid=\"1-1-7-1-4-8-1\" data-name=\"plus icon\"></i>\n</div>\n</div>\n<button class=\"w-full bg-[#B57EDC] text-white font-quicksand font-bold py-4 rounded-[20px] shadow-lg shadow-[#B57EDC]/30 active:scale-95 transition-transform\" data-kid=\"1-1-7-1-5\" onclick=\"closeEditor()\">\n                    Save &amp; Apply\n                </button>\n</div>\n</div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"5\"></script>\n<script type=\"module\" data-kid=\"6\">\n        import { animate, spring, stagger } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n        window.openEditor = (title, imgSrc) => {\n            const overlay = document.getElementById('bottom-sheet-overlay');\n            const sheet = document.getElementById('bottom-sheet');\n            const editorTitle = document.getElementById('editor-title');\n            \n            editorTitle.innerText = `Edit ${title}`;\n            overlay.classList.remove('hidden');\n            \n            setTimeout(() => {\n                overlay.style.opacity = '1';\n                sheet.style.transform = 'translateY(0)';\n            }, 10);\n        };\n\n        window.closeEditor = () => {\n            const overlay = document.getElementById('bottom-sheet-overlay');\n            const sheet = document.getElementById('bottom-sheet');\n            \n            overlay.style.opacity = '0';\n            sheet.style.transform = 'translateY(100%)';\n            \n            setTimeout(() => {\n                overlay.classList.add('hidden');\n            }, 300);\n        };\n\n        // Entrance Animations\n        window.addEventListener('load', () => {\n            // GSAP Stagger Entrance for Cards\n            gsap.from(\".photo-card\", {\n                opacity: 0,\n                y: 40,\n                rotation: -5,\n                duration: 0.8,\n                stagger: 0.15,\n                ease: \"back.out(1.7)\"\n            });\n\n            // Motion spring for next button\n            animate(\"#next-btn\", { scale: [0.95, 1], opacity: [0, 1] }, { duration: 0.6, easing: spring() });\n        });\n    </script>\n</div>\n<p class=\"text-center text-[10px] text-gray-400 mt-4 font-bold uppercase tracking-[0.2em]\" data-kid=\"2\">Next: Print or Share</p>\n\n\n\n<div class=\"fixed inset-0 z-50 bg-black/40 hidden backdrop-blur-sm transition-opacity duration-300 opacity-0\" data-kid=\"3\" id=\"bottom-sheet-overlay\" onclick=\"closeEditor()\"></div>\n\n<div class=\"fixed bottom-0 left-0 right-0 z-50 glass-sheet rounded-t-[40px] shadow-2xl translate-y-full transition-transform duration-500 ease-out\" data-kid=\"4\" id=\"bottom-sheet\">\n<div class=\"max-w-[375px] mx-auto p-6 pb-12\" data-kid=\"4-1\">\n\n<div class=\"w-12 h-1.5 bg-gray-200 rounded-full mx-auto mb-6\" data-kid=\"4-1-1\"></div>\n<div class=\"flex items-center justify-between mb-8\" data-kid=\"4-1-2\">\n<div data-kid=\"4-1-2-1\">\n<h2 class=\"text-xl font-quicksand font-bold text-gray-800\" data-kid=\"4-1-2-1-1\" id=\"editor-title\">Edit Shot</h2>\n<p class=\"text-xs text-gray-400\" data-kid=\"4-1-2-1-2\">Personalize with stickers &amp; more</p>\n</div>\n<button class=\"w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center text-gray-400\" data-kid=\"4-1-2-2\" onclick=\"closeEditor()\">\n<i class=\"ti ti-x text-lg\" data-kid=\"4-1-2-2-1\"></i>\n</button>\n</div>\n\n<div class=\"flex gap-4 mb-8 overflow-x-auto no-scrollbar py-1\" data-kid=\"4-1-3\">\n<button class=\"flex flex-col items-center gap-2 min-w-[72px]\" data-kid=\"4-1-3-1\">\n<div class=\"w-16 h-16 rounded-[24px] bg-[#B57EDC] text-white flex items-center justify-center shadow-lg shadow-[#B57EDC]/30\" data-kid=\"4-1-3-1-1\">\n<i class=\"ti ti-sticker text-2xl\" data-kid=\"4-1-3-1-1-1\"></i>\n</div>\n<span class=\"text-xs font-bold text-gray-800\" data-kid=\"4-1-3-1-2\">Stickers</span>\n</button>\n<button class=\"flex flex-col items-center gap-2 min-w-[72px] opacity-40\" data-kid=\"4-1-3-2\">\n<div class=\"w-16 h-16 rounded-[24px] bg-white border-2 border-dashed border-gray-100 flex items-center justify-center text-gray-400\" data-kid=\"4-1-3-2-1\">\n<i class=\"ti ti-brush text-2xl\" data-kid=\"4-1-3-2-1-1\"></i>\n</div>\n<span class=\"text-xs font-bold\" data-kid=\"4-1-3-2-2\">Draw</span>\n</button>\n<button class=\"flex flex-col items-center gap-2 min-w-[72px] opacity-40\" data-kid=\"4-1-3-3\">\n<div class=\"w-16 h-16 rounded-[24px] bg-white border-2 border-dashed border-gray-100 flex items-center justify-center text-gray-400\" data-kid=\"4-1-3-3-1\">\n<i class=\"ti ti-typography text-2xl\" data-kid=\"4-1-3-3-1-1\"></i>\n</div>\n<span class=\"text-xs font-bold\" data-kid=\"4-1-3-3-2\">Text</span>\n</button>\n<button class=\"flex flex-col items-center gap-2 min-w-[72px] opacity-40\" data-kid=\"4-1-3-4\">\n<div class=\"w-16 h-16 rounded-[24px] bg-white border-2 border-dashed border-gray-100 flex items-center justify-center text-gray-400\" data-kid=\"4-1-3-4-1\">\n<i class=\"ti ti-filter text-2xl\" data-kid=\"4-1-3-4-1-1\"></i>\n</div>\n<span class=\"text-xs font-bold\" data-kid=\"4-1-3-4-2\">Filters</span>\n</button>\n</div>\n\n<div class=\"grid grid-cols-4 gap-4 mb-8\" data-kid=\"4-1-4\">\n<div class=\"aspect-square bg-[#FDF5E6] rounded-[20px] flex items-center justify-center cursor-pointer hover:scale-105 transition-transform active:scale-95\" data-kid=\"4-1-4-1\">\n<img class=\"w-8 h-8 opacity-70\" data-kid=\"4-1-4-1-1\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/bubbles.svg\" style=\"filter: invert(65%) sepia(21%) saturate(2202%) hue-rotate(228deg) brightness(91%) contrast(84%);\">\n</div>\n<div class=\"aspect-square bg-[#89CFF0]/10 rounded-[20px] flex items-center justify-center cursor-pointer hover:scale-105 transition-transform active:scale-95\" data-kid=\"4-1-4-2\">\n<img class=\"w-8 h-8 opacity-70\" data-kid=\"4-1-4-2-1\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/sparkles.svg\" 