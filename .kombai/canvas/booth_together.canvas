      "html": "\n<div class=\"fixed inset-0 bg-[#111111] font-['Inter'] text-[#F7E7CE] overflow-hidden select-none\" data-kid=\"1\">\n\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600;700&display=swap');\n\n    .glass {\n      background: rgba(255, 255, 255, 0.06);\n      backdrop-filter: blur(24px);\n      -webkit-backdrop-filter: blur(24px);\n      border: 1px solid rgba(255, 255, 255, 0.15);\n    }\n\n    .rose-glow {\n      box-shadow: 0 0 40px rgba(245, 111, 161, 0.5);\n    }\n\n    .scanlines {\n      background: linear-gradient(\n        to bottom,\n        rgba(255, 255, 255, 0) 50%,\n        rgba(255, 255, 255, 0.03) 50%\n      );\n      background-size: 100% 4px;\n      pointer-events: none;\n    }\n\n    .pulse-halo {\n      animation: pulse-ring 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n    }\n\n    @keyframes pulse-ring {\n      0% { transform: scale(0.9); opacity: 0.3; }\n      50% { transform: scale(1.15); opacity: 0.6; }\n      100% { transform: scale(0.9); opacity: 0.3; }\n    }\n\n    /* Hide scrollbars just in case */\n    body {\n      margin: 0;\n      padding: 0;\n      overflow: hidden;\n    }\n  </style>\n\n<div class=\"absolute inset-0 z-0 overflow-hidden\" data-kid=\"1-1\">\n<img alt=\"Host Preview\" class=\"w-full h-full object-cover grayscale-[15%] brightness-[60%] contrast-[1.1]\" data-kid=\"1-1-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/7062060/pexels-photo-7062060.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=1440&amp;q=80\">\n<div class=\"absolute inset-0 scanlines opacity-30\" data-kid=\"1-1-2\"></div>\n\n<div class=\"absolute inset-0 bg-gradient-to-b from-[#111111]/90 via-[#111111]/20 to-[#111111]/95\" data-kid=\"1-1-3\"></div>\n<div class=\"absolute inset-0 bg-gradient-to-tr from-[#301934]/60 via-transparent to-transparent\" data-kid=\"1-1-4\"></div>\n</div>\n\n<header class=\"absolute top-0 left-0 w-full pt-10 pb-4 px-5 z-20 flex flex-col gap-4\" data-kid=\"1-2\">\n<div class=\"flex justify-between items-start w-full\" data-kid=\"1-2-1\">\n<div class=\"flex flex-col gap-0.5\" data-kid=\"1-2-1-1\">\n<span class=\"text-[9px] uppercase tracking-[0.25em] text-[#F56FA1] font-bold opacity-90\" data-kid=\"1-2-1-1-1\">Midnight Romance Room</span>\n<h1 class=\"font-['Playfair_Display'] text-xl leading-tight text-[#F7E7CE]\" data-kid=\"1-2-1-1-2\">The Neon Gallery</h1>\n</div>\n<div class=\"flex items-center gap-2 glass px-3 py-1.5 rounded-full border-white/10 rose-glow\" data-kid=\"1-2-1-2\" data-name=\"live status badge container\">\n<div class=\"w-1.5 h-1.5 bg-[#F56FA1] rounded-full animate-pulse shadow-[0_0_8px_rgba(245,111,161,0.8)]\" data-kid=\"1-2-1-2-1\" data-name=\"live indicator pulsing dot\"></div>\n<span class=\"text-[10px] font-black tracking-[0.2em] text-white\" data-kid=\"1-2-1-2-2\" data-name=\"live status text\">LIVE</span>\n</div>\n</div>\n</header>\n\n<main class=\"absolute inset-0 z-10 flex flex-col items-center justify-center pointer-events-none px-8\" data-kid=\"1-3\">\n<div class=\"relative group pointer-events-auto cursor-default\" data-kid=\"1-3-1\">\n\n<div class=\"absolute -inset-8 bg-[#F56FA1]/15 rounded-full blur-[60px] pulse-halo\" data-kid=\"1-3-1-1\"></div>\n\n<div class=\"relative z-10 glass px-8 py-7 rounded-[40px] border-[#F56FA1]/30 flex flex-col items-center gap-3 rose-glow shadow-2xl\" data-kid=\"1-3-1-2\" data-name=\"waiting badge card\">\n<div class=\"relative w-14 h-14 rounded-full bg-gradient-to-br from-[#F56FA1]/20 to-transparent flex items-center justify-center border border-[#F56FA1]/20 mb-1 shadow-inner\" data-kid=\"1-3-1-2-1\" data-name=\"waiting badge icon container\">\n<i class=\"ti ti-heart-filled text-[#F56FA1] text-2xl animate-pulse\" data-kid=\"1-3-1-2-1-1\" data-name=\"heart filled icon\"></i>\n<div class=\"absolute inset-0 rounded-full border border-[#F56FA1]/10 scale-125 animate-ping opacity-20\" data-kid=\"1-3-1-2-1-2\" data-name=\"waiting badge icon pulse ring\"></div>\n</div>\n<div class=\"text-center\" data-kid=\"1-3-1-2-2\" data-name=\"waiting message text group\">\n<span class=\"block font-['Playfair_Display'] text-2xl text-white tracking-tight italic\" data-kid=\"1-3-1-2-2-1\" data-name=\"waiting headline text\">Waiting for host</span>\n<div class=\"flex items-center justify-center gap-1.5 mt-2\" data-kid=\"1-3-1-2-2-2\" data-name=\"loading animation dot container\">\n<div class=\"w-1 h-1 bg-[#F56FA1] rounded-full animate-bounce [animation-delay:-0.3s]\" data-kid=\"1-3-1-2-2-2-1\" data-name=\"first loading dot\"></div>\n<div class=\"w-1 h-1 bg-[#F56FA1] rounded-full animate-bounce [animation-delay:-0.15s]\" data-kid=\"1-3-1-2-2-2-2\" data-name=\"second loading dot\"></div>\n<div class=\"w-1 h-1 bg-[#F56FA1] rounded-full animate-bounce\" data-kid=\"1-3-1-2-2-2-3\" data-name=\"third loading dot\"></div>\n</div>\n</div>\n</div>\n</div>\n</main>\n\n<div class=\"absolute z-30 top-[18%] right-6 w-[100px] h-[140px] rounded-2xl glass border-white/30 overflow-hidden cursor-move shadow-2xl ring-1 ring-white/5\" data-dynamic=\"true\" data-kid=\"1-4\" data-name=\"draggable user video island\" data-reason=\"position animation added by script\" id=\"user-island\">\n<img alt=\"User Preview\" class=\"w-full h-full object-cover opacity-90\" data-kid=\"1-4-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1770357552576-131ee6ac2a31?auto=format&amp;w=400&amp;q=80&amp;fit=crop\">\n<div class=\"absolute bottom-2 left-2 px-2 py-0.5 rounded bg-black/60 backdrop-blur-md border border-white/10\" data-kid=\"1-4-2\">\n<span class=\"text-[8px] uppercase tracking-widest text-white font-black\" data-kid=\"1-4-2-1\">YOU</span>\n</div>\n\n<div class=\"absolute top-1.5 left-1/2 -translate-x-1/2 w-8 h-1 bg-white/30 rounded-full shadow-inner\" data-kid=\"1-4-3\"></div>\n</div>\n\n<footer class=\"absolute bottom-0 left-0 w-full p-6 pb-10 z-20\" data-kid=\"1-5\">\n<button class=\"group relative w-full py-5 rounded-full bg-[#F56FA1] text-[#111111] font-bold text-sm tracking-[0.25em] shadow-[0_20px_60px_rgba(245,111,161,0.4)] overflow-hidden active:scale-[0.98] border-t border-white/40\" data-kid=\"1-5-1\" id=\"ready-btn\">\n<span class=\"relative z-10 flex items-center justify-center gap-3\" data-kid=\"1-5-1-1\">\n<i class=\"ti ti-star-filled text-xs\" data-kid=\"1-5-1-1-1\"></i>\n        ENTER THE BOOTH\n        <i class=\"ti ti-arrow-narrow-right text-xl group-hover:translate-x-2 transition-transform duration-300\" data-kid=\"1-5-1-1-2\"></i>\n</span>\n\n<div class=\"absolute top-0 -left-[100%] w-full h-full bg-gradient-to-r from-transparent via-white/50 to-transparent group-hover:left-[100%] transition-all duration-1000 ease-in-out\" data-kid=\"1-5-1-2\"></div>\n</button>\n<div class=\"flex items-center justify-center gap-4 mt-8\" data-kid=\"1-5-2\">\n<div class=\"h-[1px] w-10 bg-gradient-to-r from-transparent to-white/10\" data-kid=\"1-5-2-1\" data-name=\"left footer decorative line\"></div>\n<p class=\"text-[10px] text-[#F7E7CE]/40 tracking-[0.35em] uppercase whitespace-nowrap font-bold\" data-kid=\"1-5-2-2\" data-name=\"footer premium booth disclaimer text\">\n        Premium Luxury Booth\n      </p>\n<div class=\"h-[1px] w-10 bg-gradient-to-l from-transparent to-white/10\" data-kid=\"1-5-2-3\" data-name=\"right footer decorative line\"></div>\n</div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/Draggable.min.js\" data-kid=\"3\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/InertiaPlugin.min.js\" data-kid=\"4\"></script>\n<link data-kid=\"1-6\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\">\n<script data-kid=\"5\">\n    gsap.registerPlugin(Draggable, InertiaPlugin);\n\n    // Initialize Draggable for the user island\n    const islandDraggable = Draggable.create(\"#user-island\", {\n      bounds: \"window\",\n      inertia: true,\n      edgeResistance: 0.85,\n      type: \"x,y\",\n      onPress: function() {\n        gsap.to(this.target, { scale: 1.05, duration: 0.2 });\n        if (bobbingTween) bobbingTween.pause();\n      },\n      onRelease: function() {\n        gsap.to(this.target, { scale: 1, duration: 0.2 });\n        // Resume bobbing from current position\n        gsap.to(this.target, { y: \"+=0\", duration: 0.1, onComplete: () => bobbingTween.play() });\n      }\n    });\n\n    // Subtle bobbing animation for the island\n    const bobbingTween = gsap.to(\"#user-island\", {\n      y: \"-=15\",\n      duration: 2.5,\n      repeat: -1,\n      yoyo: true,\n      ease: \"sine.inOut\"\n    });\n\n    // Entrance Animations\n    window.addEventListener('DOMContentLoaded', () => {\n      const tl = gsap.timeline();\n      \n      tl.from(\"header\", {\n        y: -50,\n        opacity: 0,\n        duration: 0.8,\n        ease: \"power3.out\"\n      })\n      .from(\"main .relative\", {\n        scale: 0.8,\n        opacity: 0,\n        duration: 1,\n        ease: \"back.out(1.7)\"\n      }, \"-=0.4\")\n      .from(\"#user-island\", {\n        x: 100,\n        opacity: 0,\n        duration: 0.8,\n        ease: \"power2.out\"\n      }, \"-=0.6\")\n      .from(\"footer\", {\n        y: 100,\n        opacity: 0,\n        duration: 0.8,\n        ease: \"power3.out\"\n      }, \"-=0.6\");\n    });\n\n    // Hover effect on button using Motion API logic via GSAP for better integration\n    const btn = document.querySelector('#ready-btn');\n    btn.addEventListener('mouseenter', () => {\n      gsap.to(btn, {\n        boxShadow: \"0 25px 60px rgba(245, 111, 161, 0.5)\",\n        duration: 0.3\n      });\n    });\n    btn.addEventListener('mouseleave', () => {\n      gsap.to(btn, {\n        boxShadow: \"0 20px 50px rgba(245, 111, 161, 0.3)\",\n        duration: 0.3\n      });\n    });\n  </script>\n</div>\n",
