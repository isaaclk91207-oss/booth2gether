      "rect": {
        "x": 1900,
        "y": 0,
        "w": 375,
        "h": 812
      },
      "html": "\n<div class=\"min-h-screen bg-[#FDF5E6] flex items-center justify-center p-4 font-['Nunito_Sans'] overflow-hidden relative\" data-kid=\"1\" data-name=\"page layout container\">\n<style data-kid=\"0\">\n        @import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&family=Nunito+Sans:wght@400;600;700&display=swap');\n        \n        .chunky-shadow {\n            box-shadow: 0 6px 0 0 #9458C3;\n        }\n        \n        .chunky-shadow:active {\n            box-shadow: 0 0px 0 0 #9458C3;\n            transform: translateY(4px);\n        }\n\n        .soft-glow {\n            filter: blur(80px);\n        }\n    </style>\n\n<div class=\"absolute -top-20 -right-20 w-80 h-80 bg-[#89CFF0]/20 rounded-full soft-glow\" data-kid=\"1-1\" data-name=\"decorative soft glow shape top right\"></div>\n<div class=\"absolute -bottom-20 -left-20 w-96 h-96 bg-[#B57EDC]/10 rounded-full soft-glow\" data-kid=\"1-2\" data-name=\"decorative soft glow shape bottom left\"></div>\n\n<div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full opacity-25 pointer-events-none z-0\" data-kid=\"1-3\" data-name=\"background blob container\">\n<img alt=\"\" class=\"w-[140%] h-[140%] max-w-none blur-3xl\" data-kid=\"1-3-1\" data-name=\"blob shape icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/gooey-molecule.svg\" style=\"color: #89CFF0; opacity: 0.6;\">\n</div>\n\n<div class=\"bg-white w-full max-w-[350px] rounded-[3.5rem] p-10 shadow-[0_30px_70px_-15px_rgba(181,126,220,0.15)] relative z-10\" data-kid=\"1-4\" data-name=\"main join card\" id=\"join-modal\">\n\n<div class=\"text-center mb-10\" data-kid=\"1-4-1\" data-name=\"app header section\">\n<div class=\"inline-flex items-center justify-center w-16 h-16 bg-[#FDF5E6] rounded-[2rem] mb-5 text-[#B57EDC] shadow-sm\" data-kid=\"1-4-1-1\" data-name=\"header icon wrapper\">\n<i class=\"ti ti-camera text-3xl\" data-kid=\"1-4-1-1-1\" data-name=\"camera icon\"></i>\n</div>\n<h1 class=\"font-['Quicksand'] text-3xl font-bold text-[#333333] tracking-tight\" data-kid=\"1-4-1-2\" data-name=\"app title text\">Join a Booth!</h1>\n<p class=\"text-[#8E8E8E] text-sm mt-2 font-medium\" data-kid=\"1-4-1-3\" data-name=\"app subtitle text\">Connect with friends &amp; start shooting</p>\n</div>\n\n<div class=\"space-y-5\" data-kid=\"1-4-2\" data-name=\"input section\">\n<div class=\"relative\" data-kid=\"1-4-2-1\" data-name=\"room code input field container\">\n<input class=\"w-full bg-[#F8F7F4] border-2 border-[#E5E0D5]/60 focus:border-[#B57EDC]/50 focus:bg-white outline-none rounded-full py-5 px-6 text-center text-xl font-extrabold tracking-[0.2em] text-[#B57EDC] placeholder:text-[#919191] placeholder:font-bold placeholder:tracking-normal transition-all shadow-xs\" data-kid=\"1-4-2-1-1\" data-name=\"room code input field\" placeholder=\"ROOM CODE\" type=\"text\">\n</div>\n<button class=\"w-full bg-[#B57EDC] text-white font-['Quicksand'] font-bold py-5 rounded-full chunky-shadow text-xl flex items-center justify-center gap-2 cursor-pointer hover:brightness-105\" data-kid=\"1-4-2-2\" data-name=\"join room primary button\" id=\"join-btn\">\n<span data-kid=\"1-4-2-2-1\" data-name=\"join room button text\">Join Room</span>\n<i class=\"ti ti-sparkles text-2xl\" data-kid=\"1-4-2-2-2\" data-name=\"sparkle icon\"></i>\n</button>\n\n<button class=\"w-full py-3 rounded-full text-[#B57EDC] font-bold text-sm flex items-center justify-center gap-3 hover:bg-[#B57EDC]/5 transition-all cursor-pointer group\" data-kid=\"1-4-2-3\" data-name=\"scan qr secondary button\">\n<i class=\"ti ti-scan text-xl group-hover:rotate-12 transition-transform\" data-kid=\"1-4-2-3-1\" data-name=\"scan qr icon\"></i>\n<span data-kid=\"1-4-2-3-2\" data-name=\"scan qr button text\">Scan QR Code</span>\n</button>\n</div>\n\n<div class=\"relative flex items-center gap-3 mt-10 mb-8\" data-kid=\"1-4-3\" data-name=\"friends divider\">\n<div class=\"h-[1px] grow bg-[#E5E0D5]\" data-kid=\"1-4-3-1\" data-name=\"left divider line\"></div>\n<span class=\"text-[#A1A1A1] text-[10px] font-bold uppercase tracking-[0.15em] whitespace-nowrap\" data-kid=\"1-4-3-2\" data-name=\"divider text\">Or join friends</span>\n<div class=\"h-[1px] grow bg-[#E5E0D5]\" data-kid=\"1-4-3-3\" data-name=\"right divider line\"></div>\n</div>\n\n<div class=\"flex justify-between items-center px-1\" data-kid=\"1-4-4\" data-name=\"friends avatar list container\" id=\"friends-list\">\n<div class=\"friend-item flex flex-col items-center gap-2.5\" data-kid=\"1-4-4-1\" data-name=\"friend item alex\">\n<div class=\"w-14 h-14 rounded-[1.25rem] overflow-hidden ring-4 ring-[#FDF5E6] shadow-md cursor-pointer hover:scale-105 active:scale-95 transition-all\" data-kid=\"1-4-4-1-1\" data-name=\"avatar image wrapper\">\n<img alt=\"Alex\" class=\"w-full h-full object-cover\" data-kid=\"1-4-4-1-1-1\" data-name=\"alex avatar image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&amp;w=120&amp;q=80&amp;fit=crop\">\n</div>\n<span class=\"text-xs font-bold text-[#8E8E8E]\" data-kid=\"1-4-4-1-2\" data-name=\"alex name text\">Alex</span>\n</div>\n<div class=\"friend-item flex flex-col items-center gap-2.5\" data-kid=\"1-4-4-2\" data-name=\"friend item sarah\">\n<div class=\"w-14 h-14 rounded-[1.25rem] overflow-hidden ring-4 ring-[#FDF5E6] shadow-md cursor-pointer hover:scale-105 active:scale-95 transition-all\" data-kid=\"1-4-4-2-1\" data-name=\"avatar image wrapper\">\n<img alt=\"Sarah\" class=\"w-full h-full object-cover\" data-kid=\"1-4-4-2-1-1\" data-name=\"sarah avatar image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&amp;w=120&amp;q=80&amp;fit=crop\">\n</div>\n<span class=\"text-xs font-bold text-[#8E8E8E]\" data-kid=\"1-4-4-2-2\" data-name=\"sarah name text\">Sarah</span>\n</div>\n<div class=\"friend-item flex flex-col items-center gap-2.5\" data-kid=\"1-4-4-3\" data-name=\"friend item mia\">\n<div class=\"w-14 h-14 rounded-[1.25rem] overflow-hidden ring-4 ring-[#FDF5E6] shadow-md cursor-pointer hover:scale-105 active:scale-95 transition-all\" data-kid=\"1-4-4-3-1\" data-name=\"avatar image wrapper\">\n<img alt=\"Mia\" class=\"w-full h-full object-cover\" data-kid=\"1-4-4-3-1-1\" data-name=\"mia avatar image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1580489944761-15a19d654956?auto=format&amp;w=120&amp;q=80&amp;fit=crop\">\n</div>\n<span class=\"text-xs font-bold text-[#8E8E8E]\" data-kid=\"1-4-4-3-2\" data-name=\"mia name text\">Mia</span>\n</div>\n<div class=\"friend-item flex flex-col items-center gap-2.5\" data-kid=\"1-4-4-4\" data-name=\"friend item invite\">\n<div class=\"w-14 h-14 rounded-[1.25rem] bg-[#89CFF0]/10 flex items-center justify-center border-2 border-dashed border-[#89CFF0]/30 text-[#89CFF0] cursor-pointer hover:bg-[#89CFF0]/20 active:scale-95 transition-all\" data-kid=\"1-4-4-4-1\" data-name=\"invite button wrapper\">\n<i class=\"ti ti-plus text-xl\" data-kid=\"1-4-4-4-1-1\" data-name=\"plus icon\"></i>\n</div>\n<span class=\"text-xs font-bold text-[#8E8E8E]\" data-kid=\"1-4-4-4-2\" data-name=\"invite label text\">Invite</span>\n</div>\n</div>\n</div>\n\n<div class=\"bg-sparkle absolute top-20 left-10 text-[#89CFF0]/20 text-4xl opacity-50\" data-dynamic=\"true\" data-kid=\"1-5\" data-name=\"decorative sparkle icon container\" data-reason=\"vertical float animation applied by GSAP\">\n<i class=\"ti ti-sparkles\" data-kid=\"1-5-1\" data-name=\"sparkle icon\"></i>\n</div>\n<div class=\"bg-sparkle absolute bottom-20 right-10 text-[#B57EDC]/20 text-4xl opacity-50\" data-dynamic=\"true\" data-kid=\"1-6\" data-name=\"decorative sparkle icon container\" data-reason=\"vertical float animation applied by GSAP\">\n<i class=\"ti ti-sparkles\" data-kid=\"1-6-1\" data-name=\"sparkle icon\"></i>\n</div>\n\n<link data-kid=\"1-7\" data-name=\"tabler icons stylesheet link\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\">\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script data-kid=\"3\">\n        document.addEventListener('DOMContentLoaded', () => {\n            // #motion-modal-fade-scale entrance\n            gsap.from(\"#join-modal\", {\n                opacity: 0,\n                scale: 0.92,\n                duration: 0.6,\n                ease: \"back.out(1.7)\"\n            });\n\n            // #motion-stagger-list-on-enter for friends\n            gsap.from(\".friend-item\", {\n                opacity: 0,\n                y: 20,\n                duration: 0.5,\n                stagger: 0.08,\n                ease: \"power2.out\",\n                delay: 0.4\n            });\n\n            // Sparkles float animation\n            gsap.to(\".bg-sparkle\", {\n                y: -15,\n                repeat: -1,\n                yoyo: true,\n                duration: 2.5,\n                ease: \"sine.inOut\",\n                stagger: {\n                    each: 1,\n                    from: \"random\"\n                }\n            });\n\n            // #motion-spring-button interaction\n            const joinBtn = document.getElementById('join-btn');\n            joinBtn.addEventListener('mousedown', () => {\n                gsap.to(joinBtn, { scale: 0.96, duration: 0.1 });\n            });\n            joinBtn.addEventListener('mouseup', () => {\n                gsap.to(joinBtn, { scale: 1, duration: 0.4, ease: \"elastic.out(1, 0.3)\" });\n            });\n            joinBtn.addEventListener('mouseleave', () => {\n                gsap.to(joinBtn, { scale: 1, duration: 0.4, ease: \"elastic.out(1, 0.3)\" });\n            });\n        });\n    </script>\n</div>\n",
      "comments": [],
      "created": "2026-07-12T07:00:42.153710+00:00",
