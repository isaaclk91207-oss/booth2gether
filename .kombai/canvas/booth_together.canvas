      "html": "\n<div class=\"min-h-screen bg-[#111111] bg-mesh text-[#F7E7CE] font-['Inter'] relative overflow-x-clip selection:bg-[#F56FA1]/30\" data-kid=\"1\">\n<style data-kid=\"0\">\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n        @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n        :root {\n            --color-onyx: #111111;\n            --color-violet: #301934;\n            --color-rose: #F56FA1;\n            --color-champagne: #F7E7CE;\n        }\n\n        .font-serif { font-family: 'Playfair Display', serif; }\n        .font-sans { font-family: 'Inter', sans-serif; }\n\n        .bg-mesh {\n            background-color: var(--color-onyx);\n            background-image: \n                radial-gradient(circle at 20% 20%, rgba(48, 25, 52, 0.6) 0%, transparent 50%),\n                radial-gradient(circle at 80% 80%, rgba(48, 25, 52, 0.6) 0%, transparent 50%);\n            position: relative;\n        }\n\n        .bg-mesh::before {\n            content: \"\";\n            position: absolute;\n            inset: 0;\n            background-image: url(\"https://www.transparenttextures.com/patterns/carbon-fibre.png\");\n            opacity: 0.03;\n            pointer-events: none;\n        }\n\n        .embossed-border {\n            border-top: 1px solid rgba(255, 255, 255, 0.1);\n            border-left: 1px solid rgba(255, 255, 255, 0.05);\n            box-shadow: 0 20px 50px rgba(0,0,0,0.8), inset 0 1px 0 rgba(255,255,255,0.1);\n        }\n\n        .ticket-shadow {\n            box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.7), 0 18px 36px -18px rgba(0, 0, 0, 0.7);\n        }\n\n        .polaroid {\n            background: white;\n            padding: 10px 10px 36px 10px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.6);\n            transform-origin: center;\n        }\n\n        .rose-button-glow {\n            box-shadow: 0 0 0 0 rgba(245, 111, 161, 0);\n            transition: box-shadow 0.3s ease;\n        }\n        .rose-button-glow:hover {\n            box-shadow: 0 0 25px rgba(245, 111, 161, 0.5);\n        }\n\n        /* Custom scrollbar for clean look */\n        ::-webkit-scrollbar { width: 4px; }\n        ::-webkit-scrollbar-track { background: var(--color-onyx); }\n        ::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }\n\n        #progress-bar {\n            transform-origin: left;\n            transform: scaleX(var(--scroll, 0));\n        }\n    </style>\n\n<div class=\"fixed top-0 left-0 w-full h-1 bg-gradient-to-r from-[var(--color-rose)] to-[var(--color-champagne)] z-[100]\" data-dynamic=\"true\" data-kid=\"1-1\" data-name=\"scroll progress bar\" data-reason=\"width/scale set by scroll progress script\" id=\"progress-bar\"></div>\n\n<header class=\"pt-20 pb-12 px-8 text-center relative z-10\" data-kid=\"1-2\" id=\"header\">\n<h1 class=\"font-serif text-5xl text-[var(--color-champagne)] mb-3 tracking-tight italic gsap-reveal\" data-kid=\"1-2-1\">Final Result</h1>\n<div class=\"flex items-center justify-center gap-4 text-[var(--color-champagne)]/50 text-xs tracking-[0.2em] uppercase gsap-reveal\" data-kid=\"1-2-2\" data-name=\"header details container\">\n<span data-kid=\"1-2-2-1\">July 12, 2024</span>\n<div class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-rose)] shadow-[0_0_8px_var(--color-rose)]\" data-kid=\"1-2-2-2\"></div>\n<span data-kid=\"1-2-2-3\">Room #Midnight-Romance</span>\n</div>\n</header>\n\n<main class=\"max-w-[1280px] mx-auto px-4 pb-72\" data-kid=\"1-3\">\n<div class=\"relative flex flex-col items-center\" data-kid=\"1-3-1\">\n\n<div class=\"w-full max-w-[340px] bg-white text-[var(--color-onyx)] rounded-2xl overflow-hidden ticket-shadow relative z-20 border border-white/10\" data-kid=\"1-3-1-1\" id=\"main-ticket\">\n\n<div class=\"p-8 bg-[var(--color-violet)] text-[var(--color-champagne)] relative overflow-hidden\" data-kid=\"1-3-1-1-1\">\n<div class=\"absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]\" data-kid=\"1-3-1-1-1-1\"></div>\n<div class=\"relative z-10 flex justify-between items-end mb-6\" data-kid=\"1-3-1-1-1-2\">\n<div data-kid=\"1-3-1-1-1-2-1\">\n<p class=\"text-[11px] uppercase tracking-widest opacity-60 mb-1\" data-kid=\"1-3-1-1-1-2-1-1\">Boarding Area</p>\n<h2 class=\"font-serif text-3xl leading-none\" data-kid=\"1-3-1-1-1-2-1-2\">Vibe Check</h2>\n</div>\n<div class=\"text-right\" data-kid=\"1-3-1-1-1-2-2\">\n<p class=\"text-[11px] uppercase tracking-widest opacity-60 mb-1\" data-kid=\"1-3-1-1-1-2-2-1\">Pass No.</p>\n<h2 class=\"font-serif text-2xl leading-none italic\" data-kid=\"1-3-1-1-1-2-2-2\">BT-991</h2>\n</div>\n</div>\n<div class=\"relative z-10 flex items-center gap-4 py-4\" data-kid=\"1-3-1-1-1-3\">\n<div class=\"flex-1 h-[1px] bg-[var(--color-champagne)]/20\" data-kid=\"1-3-1-1-1-3-1\"></div>\n<div class=\"w-10 h-10 rounded-full border border-[var(--color-champagne)]/30 flex items-center justify-center\" data-kid=\"1-3-1-1-1-3-2\">\n<i class=\"ti ti-hearts text-[var(--color-rose)] text-xl\" data-kid=\"1-3-1-1-1-3-2-1\"></i>\n</div>\n<div class=\"flex-1 h-[1px] bg-[var(--color-champagne)]/20\" data-kid=\"1-3-1-1-1-3-3\"></div>\n</div>\n<div class=\"relative z-10 flex justify-between text-xs tracking-widest uppercase opacity-80\" data-kid=\"1-3-1-1-1-4\">\n<span data-kid=\"1-3-1-1-1-4-1\">Lounge: Neon City</span>\n<span data-kid=\"1-3-1-1-1-4-2\">Gate: 4A</span>\n</div>\n\n<div class=\"absolute -bottom-4 -left-4 w-8 h-8 bg-[#111111] rounded-full z-20\" data-kid=\"1-3-1-1-1-5\"></div>\n<div class=\"absolute -bottom-4 -right-4 w-8 h-8 bg-[#111111] rounded-full z-20\" data-kid=\"1-3-1-1-1-6\"></div>\n</div>\n\n<div class=\"p-5 space-y-5 bg-[#fafafa]\" data-kid=\"1-3-1-1-2\">\n<div class=\"aspect-[3/4] rounded-lg overflow-hidden bg-neutral-100 shadow-inner group\" data-kid=\"1-3-1-1-2-1\">\n<img alt=\"Julian and Clara neon\" class=\"w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-700\" data-kid=\"1-3-1-1-2-1-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1766068968885-800bebe3d1eb?auto=format&amp;w=800&amp;q=80&amp;fit=crop\">\n</div>\n<div class=\"aspect-[3/4] rounded-lg overflow-hidden bg-neutral-100 shadow-inner group\" data-kid=\"1-3-1-1-2-2\">\n<img alt=\"Romantic embrace\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000\" data-kid=\"1-3-1-1-2-2-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/20580991/pexels-photo-20580991.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=800&amp;q=80\">\n</div>\n<div class=\"aspect-[3/4] rounded-lg overflow-hidden bg-neutral-100 shadow-inner group\" data-kid=\"1-3-1-1-2-3\">\n<img alt=\"Neon lights Bokeh\" class=\"w-full h-full object-cover group-hover:brightness-110 transition-all\" data-kid=\"1-3-1-1-2-3-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1770357552576-131ee6ac2a31?auto=format&amp;w=800&amp;q=80&amp;fit=crop\">\n</div>\n</div>\n\n<div class=\"p-8 border-t border-dashed border-neutral-300 relative bg-white\" data-kid=\"1-3-1-1-3\">\n\n<div class=\"absolute -top-4 -left-4 w-8 h-8 bg-[#111111] rounded-full z-20\" data-kid=\"1-3-1-1-3-1\"></div>\n<div class=\"absolute -top-4 -right-4 w-8 h-8 bg-[#111111] rounded-full z-20\" data-kid=\"1-3-1-1-3-2\"></div>\n<div class=\"grid grid-cols-2 gap-y-6 mb-8\" data-kid=\"1-3-1-1-3-3\">\n<div data-kid=\"1-3-1-1-3-3-1\">\n<p class=\"text-[11px] text-neutral-400 uppercase tracking-widest mb-1\" data-kid=\"1-3-1-1-3-3-1-1\">Passenger</p>\n<p class=\"font-semibold text-base\" data-kid=\"1-3-1-1-3-3-1-2\">Julian &amp; Clara</p>\n</div>\n<div class=\"text-right\" data-kid=\"1-3-1-1-3-3-2\">\n<p class=\"text-[11px] text-neutral-400 uppercase tracking-widest mb-1\" data-kid=\"1-3-1-1-3-3-2-1\">Date</p>\n<p class=\"font-semibold text-base\" data-kid=\"1-3-1-1-3-3-2-2\">12.07.2024</p>\n</div>\n<div data-kid=\"1-3-1-1-3-3-3\">\n<p class=\"text-[11px] text-neutral-400 uppercase tracking-widest mb-1\" data-kid=\"1-3-1-1-3-3-3-1\">Seat</p>\n<p class=\"font-semibold text-base\" data-kid=\"1-3-1-1-3-3-3-2\">VIP LOUNGE</p>\n</div>\n<div class=\"text-right\" data-kid=\"1-3-1-1-3-3-4\">\n<p class=\"text-[11px] text-neutral-400 uppercase tracking-widest mb-1\" data-kid=\"1-3-1-1-3-3-4-1\">Time</p>\n<p class=\"font-semibold text-base\" data-kid=\"1-3-1-1-3-3-4-2\">23:45 PM</p>\n</div>\n</div>\n<div class=\"flex flex-col items-center gap-4\" data-kid=\"1-3-1-1-3-4\">\n<div class=\"w-full h-12 flex items-center justify-center opacity-70\" data-kid=\"1-3-1-1-3-4-1\">\n\n<div class=\"flex gap-[1px] h-full items-end\" data-kid=\"1-3-1-1-3-4-1-1\">\n<div class=\"w-1.5 h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-1\" data-name=\"barcode bar 1\"></div><div class=\"w-[3px] h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-2\" data-name=\"barcode bar 2\"></div><div class=\"w-1.5 h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-3\" data-name=\"barcode bar 3\"></div>\n<div class=\"w-0.5 h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-4\" data-name=\"barcode bar 4\"></div><div class=\"w-[4px] h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-5\" data-name=\"barcode bar 5\"></div><div class=\"w-1.5 h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-6\" data-name=\"barcode bar 6\"></div>\n<div class=\"w-0.5 h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-7\" data-name=\"barcode bar 7\"></div><div class=\"w-1.5 h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-8\" data-name=\"barcode bar 8\"></div><div class=\"w-[3px] h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-9\" data-name=\"barcode bar 9\"></div>\n<div class=\"w-[5px] h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-10\" data-name=\"barcode bar 10\"></div><div class=\"w-0.5 h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-11\" data-name=\"barcode bar 11\"></div><div class=\"w-2.5 h-full bg-black\" data-kid=\"1-3-1-1-3-4-1-1-12\" data-name=\"barcode bar 12\"></div>\n</div>\n</div>\n<p class=\"text-[10px] tracking-[0.4em] text-neutral-400 uppercase\" data-kid=\"1-3-1-1-3-4-2\">BoothTogether Premium Experience</p>\n</div>\n</div>\n</div>\n\n<div class=\"w-full max-w-[360px] relative mt-24 px-4\" data-kid=\"1-3-1-2\" id=\"polaroid-container\">\n<div class=\"flex items-center gap-4 mb-12\" data-kid=\"1-3-1-2-1\" data-name=\"additional shots section header wrapper\">\n<div class=\"flex-1 h-px bg-[var(--color-champagne)]/10\" data-kid=\"1-3-1-2-1-1\" data-name=\"left decorative line\"></div>\n<h3 class=\"font-serif text-2xl text-[var(--color-champagne)]/60 italic\" data-kid=\"1-3-1-2-1-2\" data-name=\"additional shots section title\">Additional Shots</h3>\n<div class=\"flex-1 h-px bg-[var(--color-champagne)]/10\" data-kid=\"1-3-1-2-1-3\" data-name=\"right decorative line\"></div>\n</div>\n<div class=\"relative grid grid-cols-2 gap-x-6 gap-y-10 pb-20\" data-kid=\"1-3-1-2-2\" data-name=\"polaroids grid container\">\n<div class=\"polaroid w-full -rotate-[6deg] z-10 gsap-polaroid\" data-kid=\"1-3-1-2-2-1\" data-name=\"polaroid photo card 1\">\n<div class=\"aspect-square bg-neutral-200 overflow-hidden\" data-kid=\"1-3-1-2-2-1-1\" data-name=\"polaroid image container 1\">\n<img alt=\"Extra 1\" class=\"w-full h-full object-cover grayscale-[10%]\" data-kid=\"1-3-1-2-2-1-1-1\" data-name=\"polaroid image 1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/20178565/pexels-photo-20178565.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n</div>\n</div>\n<div class=\"polaroid w-full rotate-[8deg] z-20 mt-8 gsap-polaroid\" data-kid=\"1-3-1-2-2-2\" data-name=\"polaroid photo card 2\">\n<div class=\"aspect-square bg-neutral-100 overflow-hidden\" data-kid=\"1-3-1-2-2-2-1\" data-name=\"polaroid image container 2\">\n<img alt=\"Extra 2\" class=\"w-full h-full object-cover\" data-kid=\"1-3-1-2-2-2-1-1\" data-name=\"polaroid image 2\" src=\"https://images.pexels.com/photos/9880055/pexels-photo-9880055.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n</div>\n</div>\n<div class=\"polaroid w-full -rotate-[4deg] z-10 -mt-4 gsap-polaroid\" data-kid=\"1-3-1-2-2-3\" data-name=\"polaroid photo card 3\">\n<div class=\"aspect-square bg-neutral-100 overflow-hidden\" data-kid=\"1-3-1-2-2-3-1\" data-name=\"polaroid image container 3\">\n<img alt=\"Extra 3\" class=\"w-full h-full object-cover\" data-kid=\"1-3-1-2-2-3-1-1\" data-name=\"polaroid image 3\" src=\"https://images.unsplash.com/photo-1761775915877-5b282e59b0b7?auto=format&amp;w=600&amp;q=80&amp;fit=crop\">\n</div>\n</div>\n<div class=\"polaroid w-full rotate-[12deg] z-20 mt-2 gsap-polaroid\" data-kid=\"1-3-1-2-2-4\" data-name=\"polaroid photo card 4\">\n<div class=\"aspect-square bg-neutral-100 overflow-hidden\" data-kid=\"1-3-1-2-2-4-1\" data-name=\"polaroid image container 4\">\n<img alt=\"Extra 4\" class=\"w-full h-full object-cover\" data-kid=\"1-3-1-2-2-4-1-1\" data-name=\"polaroid image 4\" src=\"https://images.unsplash.com/photo-1703698144961-3386ae9b3598?auto=format&amp;w=600&amp;q=80&amp;fit=crop\">\n</div>\n</div>\n</div>\n</div>\n</div>\n</main>\n\n<div class=\"fixed bottom-0 left-0 right-0 p-6 z-50\" data-kid=\"1-4\">\n<div class=\"max-w-[500px] mx-auto bg-[#111111]/90 backdrop-blur-2xl border border-white/10 rounded-3xl p-4 shadow-2xl embossed-border\" data-kid=\"1-4-1\">\n<button class=\"w-full bg-[var(--color-rose)] text-white py-4 px-8 rounded-2xl font-semibold flex items-center justify-center gap-3 transition-all active:scale-95 rose-button-glow cursor-pointer\" data-kid=\"1-4-1-1\" id=\"save-button\">\n<i class=\"ti ti-download text-2xl\" data-kid=\"1-4-1-1-1\"></i>\n<span class=\"tracking-wide\" data-kid=\"1-4-1-1-2\">Save to Camera Roll</span>\n</button>\n<div class=\"flex justify-around items-center mt-4 px-2\" data-kid=\"1-4-1-2\">\n<button class=\"flex flex-col items-center gap-1 group\" data-kid=\"1-4-1-2-1\">\n<div class=\"w-10 h-10 rounded-full flex items-center justify-center group-hover:bg-white/5 transition-colors\" data-kid=\"1-4-1-2-1-1\">\n<i class=\"ti ti-share text-xl text-[var(--color-champagne)]/60 group-hover:text-[var(--color-champagne)] transition-colors\" data-kid=\"1-4-1-2-1-1-1\"></i>\n</div>\n<span class=\"text-[10px] uppercase tracking-[0.1em] text-[var(--color-champagne)]/40\" data-kid=\"1-4-1-2-1-2\">Share</span>\n</button>\n<button class=\"flex flex-col items-center gap-1 group\" data-kid=\"1-4-1-2-2\">\n<div class=\"w-10 h-10 rounded-full flex items-center justify-center group-hover:bg-white/5 transition-colors\" data-kid=\"1-4-1-2-2-1\">\n<i class=\"ti ti-heart-filled text-xl text-[var(--color-rose)] transition-colors\" data-kid=\"1-4-1-2-2-1-1\"></i>\n</div>\n<span class=\"text-[10px] uppercase tracking-[0.1em] text-[var(--color-champagne)]/40\" data-kid=\"1-4-1-2-2-2\">Favorite</span>\n</button>\n<button class=\"flex flex-col items-center gap-1 group\" data-kid=\"1-4-1-2-3\">\n<div class=\"w-10 h-10 rounded-full flex items-center justify-center group-hover:bg-white/5 transition-colors\" data-kid=\"1-4-1-2-3-1\">\n<i class=\"ti ti-history text-xl text-[var(--color-champagne)]/60 group-hover:text-[var(--color-champagne)] transition-colors\" data-kid=\"1-4-1-2-3-1-1\"></i>\n</div>\n<span class=\"text-[10px] uppercase tracking-[0.1em] text-[var(--color-champagne)]/40\" data-kid=\"1-4-1-2-3-2\">Recents</span>\n</button>\n</div>\n</div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"3\"></script>\n<script type=\"module\" data-kid=\"4\">\n        import Lenis from \"https://esm.sh/lenis@1\"\n        \n        // Initialize Lenis\n        const lenis = new Lenis();\n        function raf(time) {\n            lenis.raf(time);\n            requestAnimationFrame(raf);\n        }\n        requestAnimationFrame(raf);\n\n        // Scroll progress\n        lenis.on('scroll', ({ progress }) => {\n            document.documentElement.style.setProperty('--scroll', progress);\n        });\n\n        // Register ScrollTrigger\n        gsap.registerPlugin(ScrollTrigger);\n\n        // Entrance Animations\n        window.addEventListener('load', () => {\n            // Header reveals\n            gsap.from(\".gsap-reveal\", {\n                y: 30,\n                opacity: 0,\n                duration: 1,\n                stagger: 0.2,\n                ease: \"power3.out\"\n            });\n\n            // Ticket entrance\n            const ticket = document.querySelector(\"#main-ticket\");\n            gsap.from(ticket, {\n                scale: 0.8,\n                opacity: 0,\n                y: 100,\n                duration: 1.5,\n                ease: \"expo.out\",\n                delay: 0.5\n            });\n\n            // Hover scale for ticket (manual since CSS transition is removed)\n            ticket.addEventListener('mouseenter', () => gsap.to(ticket, { scale: 1.02, duration: 0.4, ease: \"power2.out\" }));\n            ticket.addEventListener('mouseleave', () => gsap.to(ticket, { scale: 1, duration: 0.4, ease: \"power2.out\" }));\n\n            // Polaroid scatter animation - Controlled for mobile\n            gsap.from(\".gsap-polaroid\", {\n                scale: 0.5,\n                opacity: 0,\n                y: 50,\n                rotation: () => (Math.random() - 0.5) * 30,\n                stagger: 0.15,\n                duration: 1,\n                ease: \"power2.out\",\n                scrollTrigger: {\n                    trigger: \"#polaroid-container\",\n                    start: \"top 85%\",\n                }\n            });\n\n            // Hover effects (handled as tap-ready interactions)\n            document.querySelectorAll('.gsap-polaroid').forEach(el => {\n                el.addEventListener('click', () => {\n                    gsap.to(el, { \n                        scale: 1.05, \n                        rotation: 0, \n                        zIndex: 60, \n                        duration: 0.4, \n                        ease: \"power2.out\",\n                        onComplete: () => {\n                            gsap.to(el, { scale: 1, rotation: (Math.random()-0.5)*10, duration: 0.4, delay: 1 });\n                        }\n                    });\n                });\n            });\n        });\n\n    </script>\n</div>\n",
