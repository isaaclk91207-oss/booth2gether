n            sheet.style.transform = 'translateY(100%)';\n            \n            setTimeout(() => {\n                overlay.classList.add('hidden');\n            }, 300);\n        };\n\n        // Entrance Animations\n        window.addEventListener('load', () => {\n            // GSAP Stagger Entrance for Cards\n            gsap.from(\".photo-card\", {\n                opacity: 0,\n                y: 40,\n                rotation: -5,\n                duration: 0.8,\n                stagger: 0.15,\n                ease: \"back.out(1.7)\"\n            });\n\n            // Motion spring for next button\n            animate(\"#next-btn\", { scale: [0.95, 1], opacity: [0, 1] }, { duration: 0.6, easing: spring() });\n        });\n    </script>\n\n",
