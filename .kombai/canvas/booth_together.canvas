      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n:root {\n    --magenta: #FF00FF;\n    --cyan: #00FFFF;\n    --yellow: #FFFF00;\n    --black: #000000;\n}\n\nbody {\n    margin: 0;\n    padding: 0;\n    background-color: var(--magenta);\n    font-family: 'Space Grotesk', sans-serif;\n    color: var(--black);\n    overflow-x: clip;\n}\n\n.font-anton { font-family: 'Anton', sans-serif; }\n\n@keyframes marquee {\n    0% { transform: translateX(0%); }\n    100% { transform: translateX(-50%); }\n}\n\n.animate-marquee {\n    display: flex;\n    width: max-content;\n    animation: marquee 15s linear infinite;\n}\n\n.brutalist-border {\n    border: 4px solid var(--black);\n}\n\n.hard-shadow {\n    box-shadow: 6px 6px 0px var(--black);\n}\n\n.retro-shadow {\n    box-shadow: 4px 4px 0 var(--black), 8px 8px 0 var(--cyan), 12px 12px 0 var(--yellow);\n}\n\n.halftone {\n    background-image: radial-gradient(var(--black) 15%, transparent 16%);\n    background-size: 8px 8px;\n    opacity: 0.1;\n}\n\n.ticket-notch-left::before,\n.ticket-notch-right::after {\n    content: '';\n    position: absolute;\n    top: 71%;\n    width: 32px;\n    height: 32px;\n    background-color: var(--magenta);\n    border: 4px solid var(--black);\n    border-radius: 999px;\n    transform: translateY(-50%);\n    z-index: 10;\n}\n\n.ticket-notch-left::before { left: -18px; }\n.ticket-notch-right::after { right: -18px; }\n\n.blob {\n    position: fixed;\n    filter: blur(80px);\n    z-index: -1;\n    border-radius: 50%;\n    animation: drift 20s infinite alternate;\n}\n\n@keyframes drift {\n    from { transform: translate(0, 0) scale(1); }\n    to { transform: translate(100px, 50px) scale(1.2); }\n}\n\n.washi-tape {\n    position: absolute;\n    height: 30px;\n    width: 100px;\n    background: rgba(255, 255, 0, 0.7);\n    border: 1px solid rgba(0,0,0,0.1);\n    backdrop-filter: blur(1px);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 10px;\n    font-weight: bold;\n    color: rgba(0,0,0,0.4);\n    pointer-events: none;\n    z-index: 20;\n}\n</style>\n<div class=\"relative min-h-screen pb-12\" data-kid=\"1\">\n\n<div class=\"fixed inset-0 halftone pointer-events-none\" data-kid=\"1-1\"></div>\n\n<div class=\"blob bg-cyan-400/40 w-[400px] h-[400px] -top-20 -left-20\" data-kid=\"1-2\"></div>\n<div class=\"blob bg-yellow-400/30 w-[300px] h-[300px] top-1/2 -right-20\" data-kid=\"1-3\" style=\"animation-delay: -5s;\"></div>\n\n<div class=\"sticker fixed top-20 -left-10 z-20 -rotate-12 select-none cursor-pointer\" data-kid=\"1-4\">\n<img alt=\"starburst\" class=\"w-40 h-40\" data-kid=\"1-4-1\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/bright-explosion.svg\" style=\"color: var(--yellow); filter: drop-shadow(4px 4px 0px black);\">\n</div>\n<div class=\"sticker fixed bottom-20 -right-10 z-20 rotate-12 select-none cursor-pointer\" data-kid=\"1-5\">\n<img alt=\"lightning\" class=\"w-40 h-40\" data-kid=\"1-5-1\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/power-lightning.svg\" style=\"color: var(--cyan); filter: drop-shadow(4px 4px 0px black);\">\n</div>\n<div class=\"sticker fixed top-1/2 left-4 z-20 -rotate-6 select-none cursor-pointer hidden md:block\" data-kid=\"1-6\">\n<img alt=\"star\" class=\"w-24 h-24\" data-kid=\"1-6-1\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/star-swirl.svg\" style=\"color: white; filter: drop-shadow(4px 4px 0px black);\">\n</div>\n\n<div class=\"sticky top-0 z-50 bg-white border-b-4 border-black overflow-hidden py-2\" data-kid=\"1-7\">\n<div class=\"animate-marquee whitespace-nowrap\" data-kid=\"1-7-1\">\n\n<span class=\"font-anton text-4xl mx-8\" data-kid=\"1-7-1-1\">BOOTH TOGETHER</span>\n<span class=\"font-anton text-4xl mx-8 text-cyan-400\" data-kid=\"1-7-1-2\">★</span>\n<span class=\"font-anton text-4xl mx-8\" data-kid=\"1-7-1-3\">MEMORIES MADE</span>\n<span class=\"font-anton text-4xl mx-8 text-yellow-400\" data-kid=\"1-7-1-4\">★</span>\n<span class=\"font-anton text-4xl mx-8\" data-kid=\"1-7-1-5\">BOOTH TOGETHER</span>\n<span class=\"font-anton text-4xl mx-8 text-magenta-400\" data-kid=\"1-7-1-6\">★</span>\n\n<span class=\"font-anton text-4xl mx-8\" data-kid=\"1-7-1-7\">BOOTH TOGETHER</span>\n<span class=\"font-anton text-4xl mx-8 text-cyan-400\" data-kid=\"1-7-1-8\">★</span>\n<span class=\"font-anton text-4xl mx-8\" data-kid=\"1-7-1-9\">MEMORIES MADE</span>\n<span class=\"font-anton text-4xl mx-8 text-yellow-400\" data-kid=\"1-7-1-10\">★</span>\n<span class=\"font-anton text-4xl mx-8\" data-kid=\"1-7-1-11\">BOOTH TOGETHER</span>\n<span class=\"font-anton text-4xl mx-8 text-magenta-400\" data-kid=\"1-7-1-12\">★</span>\n</div>\n</div>\n\n<main class=\"relative z-10 px-6 pt-10\" data-kid=\"1-8\">\n\n<div class=\"relative max-w-[340px] mx-auto bg-white brutalist-border p-5 ticket-notch-left ticket-notch-right hard-shadow bg-[url('https://www.transparenttextures.com/patterns/paper-fibers.png')]\" data-kid=\"1-8-1\" id=\"receipt-container\">\n\n<div class=\"text-center mb-6 space-y-1\" data-kid=\"1-8-1-1\">\n<h1 class=\"font-anton text-3xl tracking-tight leading-none\" data-kid=\"1-8-1-1-1\">FINAL RESULT</h1>\n<p class=\"text-[10px] uppercase font-bold tracking-widest opacity-60\" data-kid=\"1-8-1-1-2\">Photobooth Receipt #BT-2024-X</p>\n<div class=\"border-b-2 border-dashed border-black/20 w-full mt-4\" data-kid=\"1-8-1-1-3\"></div>\n</div>\n\n<div class=\"space-y-4 relative\" data-kid=\"1-8-1-2\">\n\n<div class=\"relative group\" data-kid=\"1-8-1-2-1\">\n<div class=\"washi-tape -top-2 -left-4 -rotate-12\" data-kid=\"1-8-1-2-1-1\">PHOTO_01</div>\n<div class=\"brutalist-border overflow-hidden bg-black\" data-kid=\"1-8-1-2-1-2\">\n<img alt=\"Fun moment\" class=\"w-full h-48 object-cover grayscale-0 group-hover:grayscale transition-all duration-300\" data-kid=\"1-8-1-2-1-2-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858880/pexels-photo-4858880.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n</div>\n</div>\n\n<div class=\"relative group\" data-kid=\"1-8-1-2-2\">\n<div class=\"washi-tape -top-1 -right-4 rotate-6 bg-cyan-400/70\" data-kid=\"1-8-1-2-2-1\">PHOTO_02</div>\n<div class=\"brutalist-border overflow-hidden bg-black\" data-kid=\"1-8-1-2-2-2\">\n<img alt=\"Trendy teenagers\" class=\"w-full h-48 object-cover\" data-kid=\"1-8-1-2-2-2-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858867/pexels-photo-4858867.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n</div>\n</div>\n\n<div class=\"relative group\" data-kid=\"1-8-1-2-3\">\n<div class=\"washi-tape bottom-2 -left-6 rotate-45 bg-pink-400/70 w-16\" data-kid=\"1-8-1-2-3-1\">PHOTO_03</div>\n<div class=\"brutalist-border overflow-hidden bg-black\" data-kid=\"1-8-1-2-3-2\">\n<img alt=\"Teens photo\" class=\"w-full h-48 object-cover\" data-kid=\"1-8-1-2-3-2-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858873/pexels-photo-4858873.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n</div>\n</div>\n\n<div class=\"relative group\" data-kid=\"1-8-1-2-4\">\n<div class=\"washi-tape -bottom-2 -right-2 -rotate-3 bg-yellow-400/70\" data-kid=\"1-8-1-2-4-1\">PHOTO_04</div>\n<div class=\"brutalist-border overflow-hidden bg-black\" data-kid=\"1-8-1-2-4-2\">\n<img alt=\"Trendy team\" class=\"w-full h-48 object-cover\" data-kid=\"1-8-1-2-4-2-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/4858863/pexels-photo-4858863.jpeg?auto=compress&amp;cs=tinysrgb&amp;w=600&amp;q=80\">\n</div>\n</div>\n</div>\n\n<div class=\"mt-8 border-t-4 border-double border-black pt-6 space-y-2 text-sm font-bold\" data-kid=\"1-8-1-3\">\n<div class=\"flex justify-between uppercase\" data-kid=\"1-8-1-3-1\">\n<span data-kid=\"1-8-1-3-1-1\">Captured by:</span>\n<span data-kid=\"1-8-1-3-1-2\">CREW_99</span>\n</div>\n<div class=\"flex justify-between uppercase\" data-kid=\"1-8-1-3-2\">\n<span data-kid=\"1-8-1-3-2-1\">Location:</span>\n<span data-kid=\"1-8-1-3-2-2\">NEO SEOUL</span>\n</div>\n<div class=\"flex justify-between uppercase text-xs opacity-60\" data-kid=\"1-8-1-3-3\">\n<span data-kid=\"1-8-1-3-3-1\">Date &amp; Time:</span>\n<span data-kid=\"1-8-1-3-3-2\">24.10.2024 / 23:59</span>\n</div>\n<div class=\"flex justify-center py-4\" data-kid=\"1-8-1-3-4\">\n<div class=\"bg-black text-white px-4 py-1 font-anton text-xl -rotate-1 tracking-widest\" data-kid=\"1-8-1-3-4-1\">\n                        TOTAL VIBES: 100%\n                    </div>\n</div>\n<div class=\"border-t-2 border-dashed border-black/20 pt-4 text-center relative\" data-kid=\"1-8-1-3-5\">\n<p class=\"text-[10px] uppercase opacity-60 mb-2\" data-kid=\"1-8-1-3-5-1\">Scan for Digital Copy</p>\n<div class=\"flex justify-center\" data-kid=\"1-8-1-3-5-2\">\n<div class=\"w-20 h-20 brutalist-border p-1 bg-white relative\" data-kid=\"1-8-1-3-5-2-1\">\n<div class=\"w-full h-full bg-[url('https://api.qrserver.com/v1/create-qr-code/?size=150x150&amp;data=BoothTogether')] bg-cover\" data-kid=\"1-8-1-3-5-2-1-1\"></div>\n<div class=\"absolute -top-3 -right-3 w-8 h-8 bg-yellow-400 border-2 border-black rounded-full flex items-center justify-center rotate-12\" data-kid=\"1-8-1-3-5-2-1-2\" data-name=\"qr code decorative lightning badge\">\n<i class=\"ti ti-zap text-black text-lg\" data-kid=\"1-8-1-3-5-2-1-2-1\" data-name=\"lightning zap icon\"></i>\n</div>\n</div>\n</div>\n</div>\n<div class=\"pt-6 text-center\" data-kid=\"1-8-1-3-6\">\n<p class=\"font-anton text-2xl italic tracking-tighter text-[#FF00FF]\" data-kid=\"1-8-1-3-6-1\">STAY CHAOTIC!</p>\n</div>\n</div>\n</div>\n\n<div class=\"mt-12 space-y-4 flex flex-col items-center\" data-kid=\"1-8-2\" id=\"action-buttons\">\n<button class=\"w-full max-w-[300px] bg-white border-4 border-black p-4 flex items-center justify-between group retro-shadow\" data-kid=\"1-8-2-1\">\n<span class=\"font-anton text-2xl\" data-kid=\"1-8-2-1-1\">PRINT STRIP</span>\n<i class=\"ti ti-printer text-3xl\" data-kid=\"1-8-2-1-2\"></i>\n</button>\n<button class=\"w-full max-w-[300px] bg-cyan-400 border-4 border-black p-4 flex items-center justify-between group hard-shadow\" data-kid=\"1-8-2-2\">\n<span class=\"font-anton text-2xl\" data-kid=\"1-8-2-2-1\">SHARE TO FEED</span>\n<i class=\"ti ti-share text-3xl\" data-kid=\"1-8-2-2-2\"></i>\n</button>\n<button class=\"w-full max-w-[300px] bg-black text-white border-4 border-black p-4 flex items-center justify-between group\" data-kid=\"1-8-2-3\">\n<span class=\"font-anton text-2xl\" data-kid=\"1-8-2-3-1\">SAVE TO GALLERY</span>\n<i class=\"ti ti-download text-3xl\" data-kid=\"1-8-2-3-2\"></i>\n</button>\n</div>\n\n<div class=\"mt-12 text-center pb-8 relative\" data-kid=\"1-8-3\">\n<div class=\"flex justify-center gap-4 mb-2\" data-kid=\"1-8-3-1\" data-name=\"footer star icons container\">\n<i class=\"ti ti-star-filled text-yellow-400\" data-kid=\"1-8-3-1-1\" data-name=\"yellow star icon\"></i>\n<i class=\"ti ti-star-filled text-cyan-400\" data-kid=\"1-8-3-1-2\" data-name=\"cyan star icon\"></i>\n<i class=\"ti ti-star-filled text-white\" data-kid=\"1-8-3-1-3\" data-name=\"white star icon\"></i>\n</div>\n<p class=\"text-[10px] font-bold uppercase tracking-[0.2em]\" data-kid=\"1-8-3-2\" data-name=\"copyright notice text\">BoothTogether © 2024 <br data-kid=\"1-8-3-2-1\" data-name=\"line break element\"> Made with Chaos</p>\n</div>\n</main>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"2\"></script>\n<script data-kid=\"3\">\n    document.addEventListener('DOMContentLoaded', () => {\n        // Entrance animation for the receipt\n        gsap.from(\"#receipt-container\", {\n            y: 100,\n            opacity: 0,\n            rotate: -5,\n            duration: 1.2,\n            ease: \"power4.out\"\n        });\n\n        // Entrance animation for buttons with stagger\n        gsap.from(\"#action-buttons button\", {\n            x: -50,\n            opacity: 0,\n            duration: 0.8,\n            stagger: 0.2,\n            ease: \"back.out(1.7)\",\n            delay: 0.5\n        });\n\n        // Hover jiggles for buttons (Non-conflicting with GSAP transforms)\n        const buttons = document.querySelectorAll('#action-buttons button');\n        buttons.forEach(btn => {\n            btn.addEventListener('mouseenter', () => {\n                gsap.to(btn, { scale: 1.05, duration: 0.2 });\n            });\n            btn.addEventListener('mouseleave', () => {\n                gsap.to(btn, { scale: 1, duration: 0.2 });\n            });\n        });\n\n        // Sticker Wobble Interaction\n        const stickers = document.querySelectorAll('.sticker');\n        stickers.forEach(sticker => {\n            sticker.addEventListener('mouseenter', () => {\n                gsap.to(sticker, {\n                    x: \"random(-10, 10)\",\n                    y: \"random(-10, 10)\",\n                    rotation: \"random(-20, 20)\",\n                    duration: 0.1,\n                    repeat: 3,\n                    yoyo: true,\n                    ease: \"power1.inOut\"\n                });\n            });\n        });\n    });\n</script>\n",
